  .srv-card-body { padding: 14px 16px; }
  .srv-meta { display: flex; gap: 16px; margin-bottom: 12px; }
  .srv-meta-item { display: flex; align-items: center; gap: 5px; font-family: var(--font-mono); font-size: 0.7rem; color: var(--muted); }
  .srv-bar-wrap { margin-bottom: 12px; }
  .srv-bar-hdr  { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
  .srv-bar-lbl  { font-family: var(--font-mono); font-size: 0.64rem; color: var(--muted); display: flex; align-items: center; gap: 5px; }
  .srv-bar-count { font-family: var(--font-mono); font-size: 0.64rem; font-weight: 600; }
  .srv-bar      { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
  .srv-bar-fill { height: 100%; border-radius: 2px; transition: width 0.6s ease; }
  .srv-players  { display: flex; flex-wrap: wrap; gap: 4px; }
  .srv-player   { font-family: var(--font-mono); font-size: 0.6rem; padding: 2px 7px; background: rgba(56,189,248,0.06); border: 1px solid rgba(56,189,248,0.15); border-radius: 3px; color: var(--muted); max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .srv-player-more { color: var(--muted); border-style: dashed; }
  .srv-offline  { padding: 20px 16px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 6px; color: var(--muted); }
  .srv-offline .ti { font-size: 22px; opacity: 0.3; }
  .srv-offline span { font-size: 0.76rem; }
  .srv-card-foot { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-top: 1px solid var(--border); }
  .srv-card-ip { font-family: var(--font-mono); font-size: 0.68rem; color: var(--muted); }
  .srv-copy-btn { display: flex; align-items: center; gap: 5px; padding: 5px 10px; background: none; border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--muted); font-family: var(--font-mono); font-size: 0.66rem; cursor: pointer; }
  .srv-copy-btn:hover { border-color: var(--accent); color: var(--accent-dark); }
</style>