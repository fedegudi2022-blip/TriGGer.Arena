---
export const prerender = false;
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import { RESET_COOKIE, peekPasswordResetToken } from '../../lib/auth';

const resetToken = Astro.cookies.get(RESET_COOKIE)?.value;
const validUserId = await peekPasswordResetToken(resetToken);
const hasSession = !!validUserId;
---

<!DOCTYPE html>
<html lang="es-AR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nueva Contraseña · TriGGer.Arena</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/webp" href="/trigger_fondo.webp" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" />

  <style>
    :root {
      --bg: #05070a;
      --card: rgba(10, 15, 25, 0.85);
      --border: rgba(56, 182, 255, 0.15);
      --accent: #38b6ff;
      --accent-glow: rgba(56, 182, 255, 0.25);
      --text: #e2e8f0;
      --text-muted: #64748b;
      --success: #38ffb6;
      --error: #ff4d4d;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ── BG ── */
    .bg-grid { position: fixed; inset: 0; background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px); background-size: 40px 40px; z-index: -2; opacity: 0.2; }
    .bg-glow { position: fixed; inset: 0; background: radial-gradient(circle at 50% -10%, rgba(56,182,255,0.15), transparent 70%); z-index: -1; }
    .bg-scanline { position: fixed; inset: 0; background: linear-gradient(rgba(18,16,16,0) 50%, rgba(0,0,0,0.07) 50%); background-size: 100% 4px; pointer-events: none; z-index: 10; }

    /* ── LAYOUT ── */
    .wrap { width: 100%; max-width: 400px; padding: 20px; z-index: 1; display: flex; flex-direction: column; gap: 20px; }

    /* ── CARD ── */
    .card { background: var(--card); backdrop-filter: blur(16px); border: 1px solid var(--border); border-radius: 16px; position: relative; overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
    .card-accent { position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--accent), transparent); }
    .card-accent.success { background: linear-gradient(90deg, transparent, var(--success), transparent); }
    .card-body { padding: 40px 32px; }

    /* ── STATE VIEWS ── */
    .state-view { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 20px; }

    .icon-circle { width: 68px; height: 68px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; }
    .icon-circle.default { background: rgba(56,182,255,0.1); border: 1px solid var(--border); color: var(--accent); }
    .icon-circle.success { background: rgba(56,255,182,0.1); border: 1px solid rgba(56,255,182,0.2); color: var(--success); }
    .icon-circle.error { background: rgba(255,77,77,0.1); border: 1px solid rgba(255,77,77,0.2); color: var(--error); }

    h2 { font-family: 'JetBrains Mono', monospace; font-size: 1.2rem; font-weight: 700; }
    .state-desc { color: var(--text-muted); font-size: 0.88rem; line-height: 1.65; max-width: 280px; }

    /* ── FORM ── */
    .form-stack { display: flex; flex-direction: column; gap: 18px; width: 100%; text-align: left; margin-top: 4px; }
    .field { display: flex; flex-direction: column; gap: 6px; }
    .field label { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; font-weight: 700; color: var(--text-muted); letter-spacing: 1px; text-transform: uppercase; }
    .input-group { position: relative; }
    .input-group .input-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 1rem; pointer-events: none; }
    .input-group input { width: 100%; background: rgba(0,0,0,0.35); border: 1px solid var(--border); border-radius: 10px; padding: 13px 44px 13px 42px; color: #fff; font-family: inherit; font-size: 0.9rem; transition: border-color 0.2s, box-shadow 0.2s; }
    .input-group input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(56,182,255,0.08); }
    .input-group input.has-error { border-color: var(--error); }

    /* FIX: el botón eye tiene su propio selector data-target — no usa previousElementSibling */
    .btn-eye { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 6px; line-height: 1; transition: color 0.2s; }
    .btn-eye:hover { color: var(--accent); }

    .error-text { color: var(--error); font-size: 0.75rem; min-height: 14px; }
    .form-error { color: var(--error); font-size: 0.8rem; text-align: center; padding: 10px; background: rgba(255,77,77,0.07); border: 1px solid rgba(255,77,77,0.2); border-radius: 8px; display: none; }
    .form-error.visible { display: block; }

    /* ── STRENGTH ── */
    .strength-meter { height: 3px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden; margin-top: 8px; }
    .strength-bar { height: 100%; width: 0; transition: width 0.3s ease, background-color 0.3s ease; border-radius: 2px; }

    .pass-reqs { list-style: none; display: flex; flex-direction: column; gap: 4px; margin-top: 8px; }
    .pass-reqs li { font-size: 0.72rem; color: var(--text-muted); display: flex; align-items: center; gap: 6px; transition: color 0.2s; }
    .pass-reqs li.met { color: var(--success); }
    .pass-reqs li .ti-check { display: none; }
    .pass-reqs li .ti-x { display: inline; }
    .pass-reqs li.met .ti-check { display: inline; }
    .pass-reqs li.met .ti-x { display: none; }

    /* ── BUTTONS ── */
    .btn-primary { background: var(--accent); color: #000; border: none; padding: 14px; border-radius: 10px; font-weight: 800; font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; letter-spacing: 0.5px; cursor: pointer; width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px; transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s; margin-top: 4px; }
    .btn-primary:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 4px 20px var(--accent-glow); }
    .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn-secondary { background: rgba(255,255,255,0.04); color: var(--text); border: 1px solid var(--border); padding: 13px; border-radius: 10px; font-weight: 600; font-size: 0.85rem; cursor: pointer; width: 100%; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.2s; }
    .btn-secondary:hover { background: rgba(255,255,255,0.08); }

    /* ── LOADER ── */
    .spinner { display: none; width: 18px; height: 18px; border: 2.5px solid rgba(0,0,0,0.15); border-top-color: #000; border-radius: 50%; animation: spin 0.8s linear infinite; }
    .loading .btn-text { display: none; }
    .loading .spinner { display: block; }

    /* ── BACK ── */
    .page-back { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 700; color: var(--text-muted); text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 8px; transition: color 0.2s; }
    .page-back:hover { color: var(--accent); }

    /* ── ANIMATIONS ── */
    .anim-fade-in { animation: fadeIn 0.4s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>

  <div class="bg-grid"></div>
  <div class="bg-glow"></div>
  <div class="bg-scanline"></div>

  <main class="wrap">

    <!-- ── TOKEN INVÁLIDO / SIN SESIÓN ── -->
    {!hasSession && (
      <div class="card anim-fade-in">
        <div class="card-accent" style="background: linear-gradient(90deg, transparent, var(--error), transparent);"></div>
        <div class="card-body">
          <div class="state-view">
            <div class="icon-circle error"><i class="ti ti-clock-stop"></i></div>
            <h2>Enlace expirado</h2>
            <p class="state-desc">Por seguridad, los enlaces de recuperación tienen una duración limitada. Solicitá uno nuevo para continuar.</p>
            <a href="/auth/reset" class="btn-secondary" style="margin-top: 4px;">
              <i class="ti ti-refresh"></i> Pedir nuevo enlace
            </a>
          </div>
        </div>
      </div>
    )}

    <!-- ── FORMULARIO ── -->
    {hasSession && (
      <>
        <div class="card" id="form-card">
          <div class="card-accent"></div>
          <div class="card-body">
            <div class="state-view">
              <div class="icon-circle default"><i class="ti ti-shield-lock"></i></div>
              <h2>Nueva Contraseña</h2>
              <p class="state-desc">Elegí una contraseña segura para proteger tu cuenta de TriGGer.Arena.</p>

              <form id="updateForm" class="form-stack" novalidate>

                <div class="field">
                  <label for="pass">Contraseña nueva</label>
                  <div class="input-group">
                    <i class="input-icon ti ti-lock"></i>
                    <input type="password" id="pass" name="password" required placeholder="Mínimo 8 caracteres" autocomplete="new-password" />
                    <!-- FIX: data-target apunta al id del input, no usa previousElementSibling -->
                    <button type="button" class="btn-eye" data-target="pass" aria-label="Mostrar contraseña">
                      <i class="ti ti-eye"></i>
                    </button>
                  </div>
                  <div class="strength-meter"><div id="strength-bar" class="strength-bar"></div></div>
                  <ul class="pass-reqs" id="pass-reqs">
                    <li data-req="length"><i class="ti ti-x"></i><i class="ti ti-check"></i> Mínimo 8 caracteres</li>
                    <li data-req="upper"><i class="ti ti-x"></i><i class="ti ti-check"></i> Una mayúscula</li>
                    <li data-req="number"><i class="ti ti-x"></i><i class="ti ti-check"></i> Un número</li>
                  </ul>
                  <p class="error-text" id="pass-error"></p>
                </div>

                <div class="field">
                  <label for="pass-confirm">Confirmar contraseña</label>
                  <div class="input-group">
                    <i class="input-icon ti ti-lock-check"></i>
                    <input type="password" id="pass-confirm" name="confirm" required placeholder="Repetí tu contraseña" autocomplete="new-password" />
                    <button type="button" class="btn-eye" data-target="pass-confirm" aria-label="Mostrar contraseña">
                      <i class="ti ti-eye"></i>
                    </button>
                  </div>
                  <p class="error-text" id="confirm-error"></p>
                </div>

                <p class="form-error" id="form-error"></p>

                <button type="submit" id="submitBtn" class="btn-primary">
                  <span class="btn-text">ACTUALIZAR CONTRASEÑA</span>
                  <div class="spinner"></div>
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- Vista de éxito (oculta inicialmente) -->
        <div class="card hidden anim-fade-in" id="success-card">
          <div class="card-accent success"></div>
          <div class="card-body">
            <div class="state-view">
              <div class="icon-circle success"><i class="ti ti-circle-check"></i></div>
              <h2>¡Contraseña actualizada!</h2>
              <p class="state-desc">Tu contraseña fue cambiada correctamente. Redirigiendo al inicio de sesión...</p>
              <div style="width:100%;background:rgba(255,255,255,0.05);border-radius:4px;height:4px;overflow:hidden;margin-top:4px;">
                <div id="redirect-bar" style="height:100%;background:var(--success);width:0;transition:width 3s linear;border-radius:4px;"></div>
              </div>
            </div>
          </div>
        </div>
      </>
    )}

    <a href="/" class="page-back"><i class="ti ti-arrow-narrow-left"></i> VOLVER AL INICIO</a>

  </main>

  <script>
    // ── Password toggle (FIX: usa data-target para encontrar el input por ID) ──
    document.querySelectorAll<HTMLButtonElement>('.btn-eye').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target')!;
        const input = document.getElementById(targetId) as HTMLInputElement;
        const icon = btn.querySelector('i')!;
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        icon.classList.toggle('ti-eye', !isPassword);
        icon.classList.toggle('ti-eye-off', isPassword);
      });
    });

    // ── Password strength ─────────────────────────────────────────────────────
    const passInput = document.getElementById('pass') as HTMLInputElement | null;
    const strengthBar = document.getElementById('strength-bar') as HTMLElement | null;
    const passReqs = document.getElementById('pass-reqs');

    const reqs = {
      length: (v: string) => v.length >= 8,
      upper: (v: string) => /[A-Z]/.test(v),
      number: (v: string) => /[0-9]/.test(v),
    };
    const colors = ['#ff4d4d', '#ffa64d', '#38b6ff', '#38ffb6'];

    passInput?.addEventListener('input', () => {
      const val = passInput.value;
      let score = 0;
      (Object.entries(reqs) as [string, (v: string) => boolean][]).forEach(([key, fn]) => {
        const met = fn(val);
        if (met) score++;
        const li = passReqs?.querySelector<HTMLElement>(`[data-req="${key}"]`);
        li?.classList.toggle('met', met);
      });
      if (strengthBar) {
        strengthBar.style.width = val ? `${(score / 3) * 100}%` : '0';
        strengthBar.style.backgroundColor = val ? (colors[score - 1] || colors[0]) : '';
      }
    });

    // ── Form submit ───────────────────────────────────────────────────────────
    const form = document.getElementById('updateForm') as HTMLFormElement | null;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const btn = document.getElementById('submitBtn') as HTMLButtonElement;
      const pass = (document.getElementById('pass') as HTMLInputElement).value;
      const confirm = (document.getElementById('pass-confirm') as HTMLInputElement).value;
      const passError = document.getElementById('pass-error')!;
      const confirmError = document.getElementById('confirm-error')!;
      const formError = document.getElementById('form-error')!;

      // Reset errors
      passError.textContent = '';
      confirmError.textContent = '';
      formError.textContent = '';
      formError.classList.remove('visible');
      document.getElementById('pass')?.classList.remove('has-error');
      document.getElementById('pass-confirm')?.classList.remove('has-error');

      let valid = true;

      if (!reqs.length(pass) || !reqs.upper(pass) || !reqs.number(pass)) {
        passError.textContent = 'La contraseña no cumple los requisitos';
        document.getElementById('pass')?.classList.add('has-error');
        valid = false;
      }

      if (pass !== confirm) {
        confirmError.textContent = 'Las contraseñas no coinciden';
        document.getElementById('pass-confirm')?.classList.add('has-error');
        valid = false;
      }

      if (!valid) return;

      btn.classList.add('loading');
      btn.disabled = true;

      const res = await fetch('/api/update-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pass }),
      });

      if (!res.ok) {
        btn.classList.remove('loading');
        btn.disabled = false;
        const data = await res.json().catch(() => ({}));
        formError.textContent = data.error || 'Error al actualizar la contraseña. Intentá de nuevo.';
        formError.classList.add('visible');
      } else {
        // Mostrar éxito con barra de progreso de redirect
        document.getElementById('form-card')?.classList.add('hidden');
        const successCard = document.getElementById('success-card')!;
        successCard.classList.remove('hidden');

        // Activar barra de progreso (CSS transition de 3s)
        requestAnimationFrame(() => {
          const bar = document.getElementById('redirect-bar')!;
          bar.style.width = '100%';
        });

        setTimeout(() => window.location.href = '/auth', 3200);
      }
    });
  </script>

</body>
</html>