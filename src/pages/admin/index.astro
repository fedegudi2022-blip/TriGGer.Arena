  // ── Mensajes: filtro por fecha ────────────────────────────
  function filterMessages() {
    const q  = (document.getElementById('msgSearch') as HTMLInputElement)?.value.toLowerCase() ?? '';
    const f  = (document.getElementById('msgFilter') as HTMLSelectElement)?.value ?? '';
    const df = (document.getElementById('msgDateFrom') as HTMLInputElement)?.value ?? '';
    const dt = (document.getElementById('msgDateTo') as HTMLInputElement)?.value ?? '';
    const rows = document.querySelectorAll<HTMLElement>('#msgBody tr');
    let visible = 0;
    rows.forEach(row => {
      const nombre = row.dataset.nombre ?? '';
      const asunto = row.dataset.asunto ?? '';
      const dateStr = row.dataset.date ?? '';
      const rowDate = dateStr ? new Date(dateStr).toISOString().slice(0,10) : '';
      const matchQ = !q || nombre.includes(q);
      const matchF = !f || asunto === f;
      const matchDf = !df || rowDate >= df;
      const matchDt = !dt || rowDate <= dt;
      const match = matchQ && matchF && matchDf && matchDt;
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    const countEl = document.getElementById('msgVisibleCount');
    if (countEl) countEl.textContent = `${visible} mensaje${visible !== 1 ? 's' : ''}`;
  }

  document.getElementById('msgDateFrom')?.addEventListener('change', filterMessages);
