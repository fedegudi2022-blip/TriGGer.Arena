    inpV('rulesTitle') && (inpV('rulesTitle')!.value = rs.section_title ?? '');
    inpV('rulesSub')   && (inpV('rulesSub')!.value   = rs.section_sub   ?? '');
    renderRulesEditor(rs.rules ?? []);

    const ef = cbData.effexo || {};
    inpV('effexoBadge')    && (inpV('effexoBadge')!.value    = ef.badge        ?? '');
    inpV('effexoTitle')    && (inpV('effexoTitle')!.value    = ef.title        ?? '');
    taV('effexoDesc')      && (taV('effexoDesc')!.value      = ef.description  ?? '');
    taV('effexoFeatures')  && (taV('effexoFeatures')!.value  = Array.isArray(ef.features) ? ef.features.join('\n') : '');
    inpV('effexoBtnLabel') && (inpV('effexoBtnLabel')!.value = ef.btn_label    ?? '');
    inpV('effexoBtnUrl')   && (inpV('effexoBtnUrl')!.value   = ef.btn_url      ?? '');

    const sc = cbData.social || {};
    inpV('socialTitle') && (inpV('socialTitle')!.value = sc.section_title ?? '');
    inpV('socialSub')   && (inpV('socialSub')!.value   = sc.section_sub   ?? '');
    inpV('socialDiscordHandle')   && (inpV('socialDiscordHandle')!.value   = sc.discord?.handle   ?? '');
    inpV('socialDiscordDesc')     && (inpV('socialDiscordDesc')!.value     = sc.discord?.desc     ?? '');
    inpV('socialWhatsappHandle')  && (inpV('socialWhatsappHandle')!.value  = sc.whatsapp?.handle  ?? '');
    inpV('socialWhatsappDesc')    && (inpV('socialWhatsappDesc')!.value    = sc.whatsapp?.desc    ?? '');
    inpV('socialInstagramHandle') && (inpV('socialInstagramHandle')!.value = sc.instagram?.handle ?? '');
    inpV('socialInstagramDesc')   && (inpV('socialInstagramDesc')!.value   = sc.instagram?.desc   ?? '');

    const ft = cbData.footer || {};
    taV('footerTagline') && (taV('footerTagline')!.value = ft.tagline ?? '');
  }

  function renderRulesEditor(rules: any[]) {
    const container = document.getElementById('rulesEditor');
    if (!container) return;
    container.innerHTML = '';
    rules.forEach((r, i) => appendRuleRow(container, r, i));
  }

  function appendRuleRow(container: HTMLElement, r: any = {}, i: number) {
    const div = document.createElement('div');
    div.className = 'rule-row';
    div.innerHTML = `
      <div class="rule-row-head">
        <span class="tag">${r.id ?? String(i + 1).padStart(2, '0')}</span>
        <button type="button" class="icon-btn danger remove-rule-row" title="Eliminar"><i class="ti ti-trash"></i></button>
      </div>
      <div class="rule-grid">
        <div class="field"><label>Título</label><input type="text" class="re-title" value="${(r.title ?? '').replace(/"/g, '&quot;')}" /></div>
        <div class="field"><label>Tag</label><input type="text" class="re-tag" value="${(r.tag ?? '').replace(/"/g, '&quot;')}" /></div>
        <div class="field"><label>Ícono (ti-*)</label><input type="text" class="re-icon" value="${r.icon ?? 'ti-ban'}" /></div>
        <div class="field"><label>Severidad</label>
          <select class="re-severity">
            <option value="high" ${r.severity === 'high' ? 'selected' : ''}>Alta</option>
            <option value="mid"  ${r.severity === 'mid'  ? 'selected' : ''}>Media</option>
            <option value="low"  ${r.severity === 'low'  ? 'selected' : ''}>Baja</option>
          </select>
        </div>
        <div class="field full"><label>Descripción</label><textarea class="re-body" rows="2">${r.body ?? ''}</textarea></div>
      </div>`;
    div.querySelector('.remove-rule-row')?.addEventListener('click', () => div.remove());
    container.appendChild(div);
  }

  document.getElementById('addRuleBtn')?.addEventListener('click', () => {
    const container = document.getElementById('rulesEditor');
    if (container) appendRuleRow(container, {}, container.children.length);
  });

  function collectRules(): any[] {
    return Array.from(document.querySelectorAll('.rule-row')).map((row, i) => ({
      id: String(i + 1).padStart(2, '0'),
      icon: (row.querySelector('.re-icon') as HTMLInputElement)?.value.trim() || 'ti-ban',
      severity: (row.querySelector('.re-severity') as HTMLSelectElement)?.value || 'low',
      tag: (row.querySelector('.re-tag') as HTMLInputElement)?.value.trim() || '',
      title: (row.querySelector('.re-title') as HTMLInputElement)?.value.trim() || '',
      body: (row.querySelector('.re-body') as HTMLTextAreaElement)?.value.trim() || '',
    }));
  }

  (window as any).saveContentBlock = async function (key: string) {
    const btn = document.getElementById(`${key}SaveBtn`) as HTMLButtonElement | null;
    const errEl = document.getElementById(`${key}Err`);
    if (errEl) errEl.textContent = '';
    let value: any;
    if (key === 'hero') {
      value = { eyebrow: inpV('heroEyebrow')?.value.trim() ?? '', title: inpV('heroTitle')?.value.trim() ?? '', subtitle: taV('heroSubtitle')?.value.trim() ?? '', btn_label: inpV('heroBtnLabel')?.value.trim() ?? '', stat1_val: inpV('heroStat1Val')?.value.trim() ?? '', stat1_key: inpV('heroStat1Key')?.value.trim() ?? '', stat2_val: inpV('heroStat2Val')?.value.trim() ?? '', stat2_key: inpV('heroStat2Key')?.value.trim() ?? '', stat3_val: inpV('heroStat3Val')?.value.trim() ?? '', stat3_key: inpV('heroStat3Key')?.value.trim() ?? '' };
    } else if (key === 'howto') {
      value = { section_title: inpV('howtoTitle')?.value.trim() ?? '', section_sub: inpV('howtoSub')?.value.trim() ?? '', step1: { title: inpV('howtoStep1Title')?.value.trim() ?? '', body: taV('howtoStep1Body')?.value.trim() ?? '' }, step2: { title: inpV('howtoStep2Title')?.value.trim() ?? '', body: taV('howtoStep2Body')?.value.trim() ?? '' }, step3: { title: inpV('howtoStep3Title')?.value.trim() ?? '', body: taV('howtoStep3Body')?.value.trim() ?? '' } };
    } else if (key === 'rules') {
      value = { section_title: inpV('rulesTitle')?.value.trim() ?? '', section_sub: inpV('rulesSub')?.value.trim() ?? '', rules: collectRules() };
    } else if (key === 'effexo') {
      const featuresRaw = taV('effexoFeatures')?.value.trim() ?? '';
      value = { badge: inpV('effexoBadge')?.value.trim() ?? '', title: inpV('effexoTitle')?.value.trim() ?? '', description: taV('effexoDesc')?.value.trim() ?? '', features: featuresRaw ? featuresRaw.split('\n').map((f: string) => f.trim()).filter(Boolean) : [], btn_label: inpV('effexoBtnLabel')?.value.trim() ?? '', btn_url: inpV('effexoBtnUrl')?.value.trim() ?? '' };
    } else if (key === 'social') {
      value = { section_title: inpV('socialTitle')?.value.trim() ?? '', section_sub: inpV('socialSub')?.value.trim() ?? '', discord: { handle: inpV('socialDiscordHandle')?.value.trim() ?? '', desc: inpV('socialDiscordDesc')?.value.trim() ?? '' }, whatsapp: { handle: inpV('socialWhatsappHandle')?.value.trim() ?? '', desc: inpV('socialWhatsappDesc')?.value.trim() ?? '' }, instagram: { handle: inpV('socialInstagramHandle')?.value.trim() ?? '', desc: inpV('socialInstagramDesc')?.value.trim() ?? '' } };
    } else if (key === 'footer') {
      value = { tagline: taV('footerTagline')?.value.trim() ?? '' };
    } else return;

    if (btn) { btn.disabled = true; btn.classList.add('loading'); }
    try {
      const res  = await fetch('/api/content-blocks', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key, value }) });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { if (errEl) errEl.textContent = data.error ?? 'Error al guardar.'; if (btn) { btn.disabled = false; btn.classList.remove('loading'); } return; }
      if (btn) { btn.classList.remove('loading'); btn.classList.add('success'); }
      toast('Contenido guardado');
      cbData[key] = value;
      setTimeout(() => { if (btn) { btn.classList.remove('success'); btn.disabled = false; } }, 2000);
    } catch {
      if (errEl) errEl.textContent = 'Error de conexión.';
      if (btn) { btn.disabled = false; btn.classList.remove('loading'); }
    }
  };

  document.querySelectorAll<HTMLButtonElement>('.ctab').forEach(tab =>
    tab.addEventListener('click', () => {
      const key = tab.dataset.ctab!;
      document.querySelectorAll('.ctab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.ctab-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`ctab-${key}`)?.classList.add('active');
    })
  );

  // ── Audit log filters ──────────────────────────────────────
  function filterLogs() {
    const q      = (document.getElementById('logQ') as HTMLInputElement)?.value.toLowerCase() ?? '';
    const action = (document.getElementById('logAction') as HTMLSelectElement)?.value ?? '';
    const type   = (document.getElementById('logType') as HTMLSelectElement)?.value ?? '';
    document.querySelectorAll<HTMLTableRowElement>('#logsBody tr').forEach(row => {
      const admin  = (row.dataset.admin  ?? '').toLowerCase();
      const rowAct = row.dataset.action ?? '';
      const rowTyp = row.dataset.type   ?? '';
      const show   = (!q || admin.includes(q)) && (!action || rowAct === action) && (!type || rowTyp === type);
      row.style.display = show ? '' : 'none';
    });
  }
  ['logQ','logAction','logType'].forEach(id =>
    document.getElementById(id)?.addEventListener('input', filterLogs)
  );

  // ── Report status update ────────────────────────────────────
  document.querySelectorAll<HTMLSelectElement>('.report-status-sel').forEach(sel => {
    sel.addEventListener('change', async () => {
      const id = sel.dataset.id!;
      const status = sel.value;
      try {
        await fetch('/api/admin-reports', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status }),
        });
      } catch { /* silencioso */ }
    });
  });

  // ── Report delete ───────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.report-del-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('¿Eliminar este reporte?')) return;
      const id = btn.dataset.id!;
      try {
        const res = await fetch('/api/admin-reports', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (res.ok) btn.closest('tr')?.remove();
      } catch { /* silencioso */ }
    });
  });
</script>