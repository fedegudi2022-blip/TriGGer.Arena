  // ── Mini charts (sparkline SVG en stat cards) ─────────────
  function drawSparkline(canvas: HTMLElement, values: number[], color: string) {
    if (!values.length) return;
    const max = Math.max(...values, 1);
    const w = 80, h = 40, pts = values.length;
    const xs = values.map((_, i) => (i / (pts - 1)) * w);
    const ys = values.map(v => h - (v / max) * (h - 4) - 2);
    const path = xs.map((x, i) => `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${ys[i].toFixed(1)}`).join(' ');
    const areaPath = path + ` L${w},${h} L0,${h} Z`;
    canvas.innerHTML = `<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" width="${w}" height="${h}">
      <defs><linearGradient id="sg${color.replace('#','')}" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="${color}" stop-opacity="0.4"/>
        <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
      </linearGradient></defs>
      <path d="${areaPath}" fill="url(#sg${color.replace('#','')})" />
      <path d="${path}" stroke="${color}" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`;
  }

  function drawDonut(canvas: HTMLElement, value: number, total: number, color: string) {
    const pct = total === 0 ? 0 : value / total;
    const r = 14, cx = 19, cy = 19, circ = 2 * Math.PI * r;
    const dash = pct * circ;
    canvas.innerHTML = `<svg viewBox="0 0 38 38" xmlns="http://www.w3.org/2000/svg" width="38" height="38">
      <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="4"/>
      <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${color}" stroke-width="4"
        stroke-dasharray="${dash.toFixed(1)} ${circ.toFixed(1)}" stroke-dashoffset="${(circ * 0.25).toFixed(1)}"
        stroke-linecap="round"/>
    </svg>`;
  }

  function initStatCharts() {
    const DATA_ATTR = 'data-activity';
    // Sparklines
    document.querySelectorAll<HTMLElement>('.stat-mini-chart').forEach(el => {
      const raw = el.getAttribute(DATA_ATTR);
      if (!raw) return;
      try {
        const activity: Array<{msgs: number; users: number}> = JSON.parse(raw);
        const key = el.getAttribute('data-chart');
        const values = activity.map(a => key === 'msgs' ? a.msgs : a.users);
        const color = key === 'msgs' ? '#38bdf8' : '#2563eb';
        drawSparkline(el, values, color);
      } catch {}
    });
    // Donuts
    document.querySelectorAll<HTMLElement>('.stat-donut').forEach(el => {
      const admins = parseInt(el.getAttribute('data-admins') ?? '0');
      const total  = parseInt(el.getAttribute('data-total') ?? '0');
      drawDonut(el, admins, total, '#a78bfa');
    });
  }
  initStatCharts();

  // ── Activity bar chart (canvas) ───────────────────────────
  // Polyfill roundRect for older browsers
  if (!CanvasRenderingContext2D.prototype.roundRect) {
    (CanvasRenderingContext2D.prototype as any).roundRect = function(x: number, y: number, w: number, h: number, r: number | number[]) {
      const radius = Array.isArray(r) ? r[0] : r;
      this.beginPath();
      this.moveTo(x + radius, y);
      this.lineTo(x + w - radius, y);
      this.quadraticCurveTo(x + w, y, x + w, y + radius);
      this.lineTo(x + w, y + h);
      this.lineTo(x, y + h);
      this.lineTo(x, y + radius);
      this.quadraticCurveTo(x, y, x + radius, y);
      this.closePath();
    };
  }
  function initActivityChart() {
    const canvas = document.getElementById('activityChart') as HTMLCanvasElement | null;
    if (!canvas) return;
    const raw = canvas.getAttribute('data-activity');
    if (!raw) return;
    let activity: Array<{label: string; msgs: number; users: number}> = [];
    try { activity = JSON.parse(raw); } catch { return; }
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const dpr = window.devicePixelRatio || 1;
    const W = canvas.offsetWidth || 400, H = 130;
    canvas.width = W * dpr; canvas.height = H * dpr; ctx.scale(dpr, dpr);
    canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
    const n = activity.length;
    const barW = Math.floor((W - 40) / n * 0.35);
    const maxVal = Math.max(...activity.map(a => Math.max(a.msgs, a.users)), 1);
    const chartH = H - 30;
    const ACCENT = '#38bdf8', BLUE = '#2563eb';
    const slotW = (W - 40) / n;
    ctx.clearRect(0, 0, W, H);
    // Grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth = 1;
    [0.25, 0.5, 0.75, 1].forEach(f => {
      const y = chartH - chartH * f + 4;
      ctx.beginPath(); ctx.moveTo(30, y); ctx.lineTo(W - 10, y); ctx.stroke();
      ctx.fillStyle = 'rgba(138,152,181,0.5)'; ctx.font = '9px Inter,sans-serif'; ctx.textAlign = 'right';
      ctx.fillText(String(Math.round(maxVal * f)), 27, y + 3);
    });
    activity.forEach((a, i) => {
      const x = 30 + slotW * i + slotW / 2;
      const msgH = a.msgs / maxVal * chartH;
      const usrH = a.users / maxVal * chartH;
      // Bars
      ctx.fillStyle = ACCENT;
      ctx.beginPath(); ctx.roundRect(x - barW - 1, chartH - msgH + 4, barW, msgH, [3, 3, 0, 0]); ctx.fill();
      ctx.fillStyle = BLUE;
      ctx.beginPath(); ctx.roundRect(x + 1, chartH - usrH + 4, barW, usrH, [3, 3, 0, 0]); ctx.fill();
      // Labels
      ctx.fillStyle = 'rgba(138,152,181,0.8)'; ctx.font = '9px Inter,sans-serif'; ctx.textAlign = 'center';
      ctx.fillText(a.label, x, H - 6);
    });
  }
  initActivityChart();
  window.addEventListener('resize', initActivityChart);

