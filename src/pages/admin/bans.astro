---
export const prerender = false;
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';

import { requireAdmin } from '../../lib/api';

const { user, profile, error } = await requireAdmin(Astro.request, Astro.cookies);
if (error) return Astro.redirect('/');

const displayName = profile?.username ?? user?.email ?? 'Admin';
const avatarUrl   = profile?.avatar_url ?? '';
---

<!DOCTYPE html>
<html lang="es-AR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bans — TriGGer.Arena Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/webp" href="/trigger_fondo.webp" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" />
</head>
<body>

<div class="shell">

  <!-- ══ SIDEBAR ══ -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-top">
      <a href="/" class="brand">
        <img src="/trigger_fondo.webp" alt="" width="22" height="22" class="brand-img" />
        <span class="brand-txt">TriGGer<span class="brand-dot">.</span>Arena</span>
      </a>
      <span class="brand-tag">PANEL</span>
    </div>

    <nav class="side-nav">
      <a class="nav-item" href="/admin#dashboard"><i class="ti ti-layout-dashboard"></i><span>Dashboard</span></a>
      <a class="nav-item" href="/admin#mensajes"><i class="ti ti-inbox"></i><span>Mensajes</span></a>
      <a class="nav-item" href="/admin#usuarios"><i class="ti ti-users"></i><span>Usuarios</span></a>
      <a class="nav-item" href="/admin#planes"><i class="ti ti-diamond"></i><span>Planes</span></a>
      <a class="nav-item" href="/admin#servidores"><i class="ti ti-server"></i><span>Servidores</span></a>
      <a class="nav-item" href="/admin#descargas"><i class="ti ti-download"></i><span>Descargas</span></a>
      <a class="nav-item" href="/admin#contenido"><i class="ti ti-writing"></i><span>Contenido</span></a>
      <a class="nav-item" href="/admin#configuracion"><i class="ti ti-settings"></i><span>Config</span></a>
      <a class="nav-item" href="/admin#reportes"><i class="ti ti-flag-3"></i><span>Reportes</span></a>
      <a class="nav-item active" href="/admin/bans"><i class="ti ti-ban"></i><span>Bans</span></a>
      <a class="nav-item" href="/admin#logs"><i class="ti ti-history"></i><span>Audit Logs</span></a>
      <div class="nav-divider"></div>
      <a class="nav-item nav-item-portal" href="/usuario"><i class="ti ti-user-circle"></i><span>Mi Portal</span></a>
    </nav>

    <div class="sidebar-bottom">
      <div class="side-user">
        {avatarUrl
          ? <img src={avatarUrl} alt="" width="30" height="30" class="side-avatar" />
          : <span class="side-avatar side-avatar-fb"><i class="ti ti-user"></i></span>}
        <span class="side-uname">{displayName.split(' ')[0]}</span>
      </div>
      <button class="side-logout" id="logoutBtn" title="Cerrar sesión"><i class="ti ti-logout"></i></button>
    </div>
  </aside>

  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- ══ MAIN ══ -->
  <div class="content">

    <header class="topbar">
      <button class="topbar-menu" id="menuBtn" aria-label="Menú"><i class="ti ti-menu-2"></i></button>
      <div class="topbar-crumb">
        <a class="crumb-link" href="/admin">Admin</a>
        <i class="ti ti-chevron-right"></i>
        <a class="crumb-link" href="/admin#reportes">Reportes</a>
        <i class="ti ti-chevron-right"></i>
        <span class="crumb-current">Bans</span>
      </div>
      <div class="topbar-actions">
        <a href="/baneados" target="_blank" class="btn-ghost btn-sm">
          <i class="ti ti-external-link"></i> Ver página pública
        </a>
      </div>
    </header>

    <main class="main">
      <div class="page-section">

        <div class="page-head">
          <div>
            <h1><i class="ti ti-ban" style="color:#f87171;font-size:1.1rem;vertical-align:middle;margin-right:6px"></i>Gestionar Bans</h1>
            <p>Los cambios se reflejan en <code class="mono-inline">/baneados</code> de inmediato.</p>
          </div>
          <div class="head-actions">
            <button class="btn-ghost" id="btnRefresh">
              <i class="ti ti-refresh"></i> Actualizar lista
            </button>
          </div>
        </div>

        <!-- Grid principal -->
        <div class="bans-grid">

          <!-- ─── Formulario nuevo ban ─── -->
          <div class="card" id="formCard">
            <div class="card-head">
              <h2><i class="ti ti-plus"></i> Nuevo ban</h2>
            </div>
            <div class="form-pad">
              <div class="form-row">
                <div class="field">
                  <label>Nick <span class="req">*</span></label>
                  <input id="b-nick" type="text" placeholder="NickDelJugador" maxlength="80" />
                </div>
                <div class="field">
                  <label>Tag del clan</label>
                  <input id="b-tag" type="text" placeholder="|TAG|" maxlength="40" />
                </div>
              </div>
              <div class="form-row">
                <div class="field">
                  <label>Steam ID</label>
                  <input id="b-steam" type="text" placeholder="STEAM_0:1:12345678" maxlength="30" />
                </div>
                <div class="field">
                  <label>IP <span class="hint">(opcional)</span></label>
                  <input id="b-ip" type="text" placeholder="192.168.1.1" maxlength="45" />
                </div>
              </div>
              <div class="form-row">
                <div class="field">
                  <label>Tipo de infracción <span class="req">*</span></label>
                  <select id="b-tipo">
                    <option value="hack">Hack / Cheat</option>
                    <option value="insultos">Insultos / Toxicidad</option>
                    <option value="bug_abuse">Bug Abuse</option>
                    <option value="trampa">Trampa / Fullbright</option>
                    <option value="otro">Otro</option>
                  </select>
                </div>
                <div class="field">
                  <label>Duración <span class="hint">(vacío = permanente)</span></label>
                  <input id="b-dur" type="text" placeholder="ej: 7 días, 1 mes…" maxlength="40" />
                </div>
              </div>
              <div class="field">
                <label>Motivo <span class="req">*</span></label>
                <textarea id="b-motivo" rows="3" placeholder="Describí brevemente la razón del ban…" maxlength="2000"></textarea>
              </div>
              <p class="error" id="b-err"></p>
              <button class="btn-primary" id="addBanBtn">
                <span class="btn-label"><i class="ti ti-ban"></i> Agregar ban</span>
                <span class="btn-spin"></span>
              </button>
            </div>
          </div>

          <!-- ─── Lista de bans ─── -->
          <div class="card">
            <div class="card-head">
              <h2><i class="ti ti-list"></i> Lista de bans</h2>
              <div class="tools">
                <div class="search">
                  <i class="ti ti-search"></i>
                  <input type="text" id="banSearch" placeholder="Filtrar por nick, steam, IP…" />
                  <button class="search-x" id="banSearchClear" title="Limpiar"><i class="ti ti-x"></i></button>
                </div>
                <select class="select" id="banTipoFilter">
                  <option value="">Todos los tipos</option>
                  <option value="hack">Hack</option>
                  <option value="insultos">Insultos</option>
                  <option value="bug_abuse">Bug Abuse</option>
                  <option value="trampa">Trampa</option>
                  <option value="otro">Otro</option>
                </select>
                <select class="select" id="banActivoFilter">
                  <option value="">Activos e inactivos</option>
                  <option value="1">Solo activos</option>
                  <option value="0">Solo inactivos</option>
                </select>
              </div>
            </div>
            <div id="banListWrap">
              <div class="empty">
                <i class="ti ti-loader-2" id="loadingIcon"></i>
                <p>Cargando…</p>
              </div>
            </div>
            <div class="tbl-foot">
              <span class="mono dim" id="banCount">—</span>
            </div>
          </div>

        </div>
      </div>
    </main>
  </div>
</div>

<!-- ══ MODAL: Confirmar acción ══ -->
<div class="overlay" id="confirmOverlay">
  <div class="modal modal-sm">
    <div class="modal-head">
      <span class="modal-title danger"><i class="ti ti-alert-triangle"></i> Confirmar acción</span>
    </div>
    <div class="form-pad">
      <p class="confirm-msg" id="confirmMsg">¿Estás seguro?</p>
      <div class="modal-foot">
        <button class="btn-ghost" id="confirmCancel">Cancelar</button>
        <button class="btn-danger" id="confirmOk"><i class="ti ti-check"></i> Confirmar</button>
      </div>
    </div>
  </div>
</div>

<!-- ══ TOAST ══ -->
<div class="toast" id="toast" role="status" aria-live="polite">
  <i class="toast-icon ti" id="toastIcon"></i>
  <span id="toastMsg"></span>
  <div class="toast-progress" id="toastProgress"></div>
</div>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:            #0b1220;
    --surface:       #142038;
    --surface-2:     #18233b;
    --border:        #25324f;
    --border-strong: #33466e;
    --ink:           #f4f8ff;
    --ink-soft:      #c8d4ea;
    --muted:         #8a98b5;
    --accent:        #38bdf8;
    --accent-dark:   #0ea5e9;
    --accent-soft:   #0f2433;
    --blue:          #2563eb;
    --success:       #22c55e;
    --success-soft:  #10261a;
    --danger:        #ef4444;
    --danger-soft:   #311515;
    --olive:         #4ade80;
    --olive-soft:    rgba(74,222,128,0.10);
    --violet:        #a78bfa;
    --violet-soft:   rgba(167,139,250,0.10);
    --radius-sm: 5px;
    --radius:    9px;
    --font-mono: 'JetBrains Mono', monospace;
    --header-h:  56px;
    --side-w:    230px;
  }

  html, body {
    background: var(--bg); color: var(--ink);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 14px; -webkit-font-smoothing: antialiased;
  }

  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 3px; }
  a { color: inherit; text-decoration: none; }

  .shell { display: flex; min-height: 100vh; }

  /* ══ SIDEBAR ══ */
  .sidebar {
    width: var(--side-w); flex-shrink: 0;
    background: var(--surface); border-right: 1px solid var(--border);
    display: flex; flex-direction: column;
    position: fixed; top: 0; left: 0; bottom: 0; z-index: 60;
    transition: transform 0.25s ease;
  }
  .sidebar-top {
    padding: 18px 16px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .brand { display: flex; align-items: center; gap: 8px; color: var(--ink); }
  .brand-img { border-radius: 5px; }
  .brand-txt { font-weight: 800; font-size: 0.86rem; letter-spacing: -0.01em; }
  .brand-dot { color: var(--accent); }
  .brand-tag {
    font-family: var(--font-mono); font-size: 0.5rem; letter-spacing: 0.14em;
    color: var(--accent); background: var(--accent-soft); border-radius: 3px; padding: 2px 6px;
  }

  .side-nav {
    flex: 1; padding: 12px 10px; display: flex; flex-direction: column;
    gap: 2px; overflow-y: auto;
  }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 11px; border-radius: var(--radius-sm);
    background: none; color: var(--ink-soft);
    font-family: inherit; font-size: 0.82rem; font-weight: 500;
    cursor: pointer; text-align: left; position: relative;
    border: none; text-decoration: none;
  }
  .nav-item .ti { font-size: 16px; width: 16px; flex-shrink: 0; }
  .nav-item span { flex: 1; }
  .nav-item:hover { background: var(--surface-2); color: var(--ink); }
  .nav-item.active {
    background: var(--accent-soft); color: var(--accent-dark); font-weight: 600;
  }
  .nav-item.active::before {
    content: ''; position: absolute; left: -10px; top: 6px; bottom: 6px;
    width: 3px; background: var(--accent); border-radius: 0 3px 3px 0;
  }
  .nav-divider { height: 1px; background: var(--border); margin: 8px 4px; }
  .nav-item-portal { color: var(--muted); }

  .sidebar-bottom {
    border-top: 1px solid var(--border); padding: 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .side-user { flex: 1; display: flex; align-items: center; gap: 9px; min-width: 0; }
  .side-avatar {
    width: 30px; height: 30px; border-radius: 50%; object-fit: cover;
    border: 1px solid var(--border); flex-shrink: 0;
  }
  .side-avatar-fb {
    display: flex; align-items: center; justify-content: center;
    background: var(--surface-2); color: var(--muted); font-size: 15px;
  }
  .side-uname { font-size: 0.8rem; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .side-logout {
    width: 32px; height: 32px; flex-shrink: 0; border-radius: var(--radius-sm);
    border: 1px solid var(--border); background: none; color: var(--muted);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
  }
  .side-logout:hover { border-color: var(--danger); color: var(--danger); background: var(--danger-soft); }

  .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 55; }
  .sidebar-overlay.show { display: block; }

  /* ══ CONTENT ══ */
  .content { flex: 1; margin-left: var(--side-w); min-width: 0; display: flex; flex-direction: column; }

  .topbar {
    height: var(--header-h); flex-shrink: 0;
    display: flex; align-items: center; gap: 12px; padding: 0 24px;
    background: var(--surface); border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 40;
  }
  .topbar-menu {
    display: none; width: 32px; height: 32px; border-radius: var(--radius-sm);
    border: 1px solid var(--border); background: none; color: var(--ink-soft);
    align-items: center; justify-content: center; cursor: pointer;
  }
  .topbar-crumb { display: flex; align-items: center; gap: 6px; font-size: 0.78rem; flex: 1; }
  .crumb-link { color: var(--muted); transition: color 0.15s; }
  .crumb-link:hover { color: var(--accent); }
  .topbar-crumb .ti { font-size: 12px; color: var(--muted); }
  .crumb-current { font-weight: 700; color: var(--ink); }
  .topbar-actions { display: flex; align-items: center; gap: 8px; margin-left: auto; }

  .main { flex: 1; }
  .page-section { padding: 26px 28px 60px; max-width: 1400px; }

  /* ══ Page head ══ */
  .page-head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 14px; flex-wrap: wrap; margin-bottom: 22px;
  }
  .page-head h1 { font-size: 1.4rem; font-weight: 800; letter-spacing: -0.01em; }
  .page-head p  { font-size: 0.78rem; color: var(--muted); margin-top: 4px; }
  .head-actions { display: flex; align-items: center; gap: 10px; }
  .mono-inline { font-family: var(--font-mono); font-size: 0.78em; color: var(--accent-dark); }

  /* ══ Bans layout ══ */
  .bans-grid { display: grid; grid-template-columns: 360px 1fr; gap: 16px; align-items: start; }

  /* ══ Card ══ */
  .card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); margin-bottom: 0; overflow: hidden;
  }
  .card-head {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 10px; padding: 13px 18px;
    border-bottom: 1px solid var(--border);
  }
  .card-head h2 {
    font-size: 0.86rem; font-weight: 700;
    display: flex; align-items: center; gap: 7px;
  }
  .card-head h2 .ti { color: var(--accent); font-size: 15px; }

  /* ══ Form ══ */
  .form-pad { padding: 18px; display: flex; flex-direction: column; gap: 13px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .field { display: flex; flex-direction: column; gap: 5px; }
  .field label { font-size: 0.66rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
  .field input, .field textarea, .field select {
    padding: 9px 11px; background: var(--surface-2); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--ink); font-family: inherit;
    font-size: 0.84rem; outline: none; width: 100%;
  }
  .field input:focus, .field textarea:focus, .field select:focus {
    border-color: var(--accent); background: var(--surface);
  }
  .field textarea { resize: vertical; min-height: 80px; }
  .field select { cursor: pointer; }
  .hint { font-size: 0.68rem; color: var(--muted); font-weight: 400; text-transform: none; letter-spacing: 0; }
  .req { color: var(--danger); }
  .error { font-size: 0.74rem; color: var(--danger); min-height: 1px; }

  /* ══ Buttons ══ */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 16px; background: var(--accent); color: #0b1220;
    font-family: inherit; font-weight: 700; font-size: 0.78rem;
    border-radius: var(--radius-sm); border: none; cursor: pointer;
    transition: background 0.15s, opacity 0.15s; width: 100%; justify-content: center;
  }
  .btn-primary:hover:not(:disabled) { opacity: 0.88; }
  .btn-primary:disabled { opacity: 0.55; cursor: not-allowed; }
  .btn-primary.loading .btn-label { display: none; }
  .btn-primary.loading .btn-spin  { display: block; }
  .btn-spin {
    display: none; width: 14px; height: 14px;
    border: 2px solid rgba(0,0,0,0.2); border-top-color: #0b1220;
    border-radius: 50%; animation: spin 0.7s linear infinite;
  }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; background: none; border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--ink-soft);
    font-family: inherit; font-size: 0.78rem; cursor: pointer; text-decoration: none;
  }
  .btn-ghost:hover { border-color: var(--border-strong); color: var(--ink); background: var(--surface-2); }

  .btn-danger {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px; background: var(--danger); color: #fff;
    border: none; border-radius: var(--radius-sm);
    font-family: inherit; font-size: 0.78rem; cursor: pointer;
  }
  .btn-danger:hover { background: #c53030; }

  .btn-sm { padding: 5px 10px; font-size: 0.72rem; }

  .icon-btn {
    width: 28px; height: 28px; border-radius: var(--radius-sm);
    border: 1px solid var(--border); background: none; color: var(--muted);
    cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
    font-size: 13px;
  }
  .icon-btn:hover { border-color: var(--border-strong); color: var(--ink); background: var(--surface-2); }
  .icon-btn.danger:hover { border-color: var(--danger); color: var(--danger); background: var(--danger-soft); }
  .icon-btn.warn:hover   { border-color: #f59e0b; color: #f59e0b; background: rgba(245,158,11,0.08); }

  /* ══ Tools / search ══ */
  .tools { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .search {
    display: flex; align-items: center; gap: 7px; padding: 6px 10px;
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }
  .search .ti { font-size: 13px; color: var(--muted); }
  .search input { background: none; border: none; outline: none; font-family: inherit; font-size: 0.8rem; width: 180px; color: var(--ink); }
  .search-x { background: none; border: none; color: var(--muted); cursor: pointer; display: flex; align-items: center; }
  .select {
    padding: 6px 10px; background: var(--surface-2); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--ink-soft);
    font-family: var(--font-mono); font-size: 0.7rem; cursor: pointer; outline: none;
  }
  .select:focus { border-color: var(--accent); }

  /* ══ Table ══ */
  .tbl-wrap { overflow-x: auto; }
  .tbl { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
  .tbl th {
    padding: 9px 14px; text-align: left; font-size: 0.62rem; font-weight: 700;
    color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border); white-space: nowrap;
  }
  .tbl td {
    padding: 10px 14px; border-bottom: 1px solid var(--surface-2);
    vertical-align: middle; color: var(--ink-soft);
  }
  .tbl tbody tr:last-child td { border-bottom: none; }
  .tbl tbody tr:hover { background: var(--surface-2); }
  .tbl tbody tr.inactivo td { opacity: 0.38; }

  .mono { font-family: var(--font-mono); }
  .dim  { color: var(--muted); }
  .bold { color: var(--ink); font-weight: 600; }
  .row-sub { display: block; font-size: 0.7rem; color: var(--muted); margin-top: 2px; }

  .tbl-foot { padding: 10px 16px; border-top: 1px solid var(--border); }
  .tbl-foot span { font-family: var(--font-mono); font-size: 0.66rem; color: var(--muted); }

  /* ══ Tags ══ */
  .tag {
    display: inline-flex; align-items: center; gap: 4px;
    font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.02em;
    border-radius: 4px; padding: 3px 7px; white-space: nowrap;
    color: var(--ink-soft); background: var(--surface-2); border: 1px solid var(--border);
  }
  .tag.hack, .tag.trampa   { color: #f87171; background: var(--danger-soft); border-color: rgba(239,68,68,0.25); }
  .tag.insultos { color: #fb923c; background: rgba(249,115,22,0.10); border-color: rgba(249,115,22,0.25); }
  .tag.bug_abuse { color: #facc15; background: rgba(234,179,8,0.10); border-color: rgba(234,179,8,0.25); }
  .tag.otro     { color: var(--muted); }
  .tag.perm     { color: #f87171; background: var(--danger-soft); border-color: rgba(239,68,68,0.2); }
  .tag.inactivo { color: var(--muted); opacity: 0.6; }

  /* ══ Empty ══ */
  .empty {
    padding: 44px 20px; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 8px; color: var(--muted);
  }
  .empty .ti { font-size: 26px; opacity: 0.35; }
  .empty p { font-size: 0.78rem; }

  /* ══ Modal ══ */
  .overlay {
    position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.5);
    display: flex; align-items: center; justify-content: center; padding: 20px;
    opacity: 0; pointer-events: none; transition: opacity 0.18s;
  }
  .overlay.open { opacity: 1; pointer-events: auto; }
  .modal {
    width: 100%; max-width: 440px; background: var(--surface);
    border: 1px solid var(--border); border-radius: 10px;
    max-height: 90vh; overflow-y: auto;
    transform: translateY(10px); transition: transform 0.2s;
  }
  .modal-sm { max-width: 340px; }
  .overlay.open .modal { transform: translateY(0); }
  .modal-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 18px; border-bottom: 1px solid var(--border);
  }
  .modal-title {
    font-size: 0.86rem; font-weight: 700;
    display: flex; align-items: center; gap: 7px;
  }
  .modal-title.danger .ti { color: var(--danger); }
  .confirm-msg { font-size: 0.84rem; color: var(--ink-soft); line-height: 1.6; }
  .modal-foot { display: flex; justify-content: flex-end; gap: 8px; }

  /* ══ Toast ══ */
  .toast {
    position: fixed; bottom: 22px; left: 50%;
    transform: translateX(-50%) translateY(70px);
    background: var(--ink); color: #fff; border-radius: 8px; padding: 11px 16px;
    font-size: 0.8rem; display: flex; align-items: center; gap: 9px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    transition: transform 0.25s ease, opacity 0.2s;
    z-index: 200; pointer-events: none; min-width: 200px;
    overflow: hidden; opacity: 0; white-space: nowrap;
  }
  .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
  .toast-icon { font-size: 14px; }
  .toast.ok .toast-icon { color: #8fd17a; }
  .toast.err .toast-icon { color: #f08a7a; }
  .toast-progress { position: absolute; bottom: 0; left: 0; height: 2px; background: var(--accent); }
  .toast.show .toast-progress { animation: shrink 3s linear forwards; }

  /* ══ Animations ══ */
  @keyframes spin    { to { transform: rotate(360deg); } }
  @keyframes shrink  { from { width: 100%; } to { width: 0%; } }

  /* ══ Responsive ══ */
  @media (max-width: 960px) {
    .sidebar { transform: translateX(-100%); }
    .sidebar.open { transform: translateX(0); }
    .content { margin-left: 0; }
    .topbar-menu { display: flex; }
  }
  @media (max-width: 900px) {
    .bans-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .page-section { padding: 18px 16px 40px; }
    .form-row { grid-template-columns: 1fr; }
    .search input { width: 120px; }
  }
  @media (max-width: 540px) {
    .tbl th:nth-child(4), .tbl td:nth-child(4),
    .tbl th:nth-child(3), .tbl td:nth-child(3) { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
  }
</style>

<script>
  // ── Helpers ───────────────────────────────────────────────
  const $    = (id: string) => document.getElementById(id)!;
  const inp  = (id: string) => $(id) as HTMLInputElement;
  const sel  = (id: string) => $(id) as HTMLSelectElement;
  const ta   = (id: string) => $(id) as HTMLTextAreaElement;

  const TIPO_LABELS: Record<string, string> = {
    hack: 'Hack', insultos: 'Insultos', bug_abuse: 'Bug Abuse', trampa: 'Trampa', otro: 'Otro',
  };

  // ── Sidebar toggle (mobile) ───────────────────────────────
  const sidebar    = $('sidebar');
  const overlay    = $('sidebarOverlay');
  const menuBtn    = $('menuBtn');
  menuBtn.addEventListener('click', () => {
    const isOpen = sidebar.classList.contains('open');
    sidebar.classList.toggle('open', !isOpen);
    overlay.classList.toggle('show', !isOpen);
  });
  overlay.addEventListener('click', () => {
    sidebar.classList.remove('open');
    overlay.classList.remove('show');
  });

  // ── Logout ────────────────────────────────────────────────
  $('logoutBtn').addEventListener('click', async () => {
    await fetch('/api/signin', { method: 'DELETE' });
    window.location.href = '/auth';
  });

  // ── Toast ─────────────────────────────────────────────────
  let toastTimer: ReturnType<typeof setTimeout>;
  function toast(msg: string, type: 'ok' | 'err' = 'ok') {
    clearTimeout(toastTimer);
    const el = $('toast'), icon = $('toastIcon'), msgEl = $('toastMsg'), prog = $('toastProgress');
    el.classList.remove('show', 'ok', 'err');
    prog.style.animation = 'none'; prog.getBoundingClientRect(); prog.style.animation = '';
    icon.className = `toast-icon ti ${type === 'ok' ? 'ti-check' : 'ti-alert-circle'}`;
    msgEl.textContent = msg;
    el.classList.add(type, 'show');
    toastTimer = setTimeout(() => el.classList.remove('show'), 3200);
  }

  // ── Confirm modal ─────────────────────────────────────────
  let confirmResolve: ((v: boolean) => void) | null = null;
  function confirmAction(msg: string): Promise<boolean> {
    return new Promise(res => {
      confirmResolve = res;
      $('confirmMsg').textContent = msg;
      $('confirmOverlay').classList.add('open');
    });
  }
  $('confirmOk').addEventListener('click', () => {
    $('confirmOverlay').classList.remove('open');
    confirmResolve?.(true);
  });
  $('confirmCancel').addEventListener('click', () => {
    $('confirmOverlay').classList.remove('open');
    confirmResolve?.(false);
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') $('confirmOverlay').classList.remove('open');
  });

  // ── Escape HTML ───────────────────────────────────────────
  function esc(str: unknown): string {
    return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Estado de bans almacenado ─────────────────────────────
  let allBans: any[] = [];

  // ── Filtros ───────────────────────────────────────────────
  function getFiltered(): any[] {
    const q      = inp('banSearch').value.toLowerCase().trim();
    const tipo   = sel('banTipoFilter').value;
    const activo = sel('banActivoFilter').value;
    return allBans.filter(b => {
      const matchQ = !q || [b.nick, b.tag, b.steam_id, b.ip, b.motivo]
        .some(v => v?.toLowerCase().includes(q));
      const matchT = !tipo   || b.tipo    === tipo;
      const matchA = !activo || String(b.activo) === activo;
      return matchQ && matchT && matchA;
    });
  }

  // ── Renderizar tabla ──────────────────────────────────────
  function renderTable() {
    const wrap    = $('banListWrap');
    const counter = $('banCount');
    const filtered = getFiltered();

    if (!filtered.length) {
      wrap.innerHTML = `<div class="empty"><i class="ti ti-ban"></i><p>${
        allBans.length ? 'No hay bans que coincidan con el filtro.' : 'No hay bans registrados.'
      }</p></div>`;
      counter.textContent = '0 bans';
      return;
    }

    counter.textContent = `${filtered.length} ban${filtered.length !== 1 ? 's' : ''}`;

    const rows = filtered.map(b => {
      const tipoClass = b.tipo in TIPO_LABELS ? b.tipo : 'otro';
      return `
        <tr class="${b.activo ? '' : 'inactivo'}" data-id="${esc(b.id)}">
          <td>
            <span class="bold">${esc(b.nick)}</span>
            ${b.tag ? `<span class="row-sub mono">${esc(b.tag)}</span>` : ''}
          </td>
          <td class="mono dim" style="font-size:0.72rem">${b.steam_id ? esc(b.steam_id) : '<span style="opacity:.3">—</span>'}</td>
          <td class="mono dim" style="font-size:0.72rem">${b.ip ? esc(b.ip) : '<span style="opacity:.3">—</span>'}</td>
          <td><span class="tag ${tipoClass}">${esc(TIPO_LABELS[b.tipo] ?? b.tipo)}</span></td>
          <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:0.78rem;color:var(--ink-soft)" title="${esc(b.motivo)}">${esc(b.motivo)}</td>
          <td style="white-space:nowrap">
            ${b.duracion
              ? `<span class="mono dim" style="font-size:0.72rem">${esc(b.duracion)}</span>`
              : `<span class="tag perm">∞ Permanente</span>`}
          </td>
          <td>
            <span class="tag ${b.activo ? '' : 'inactivo'}">${b.activo ? 'Activo' : 'Inactivo'}</span>
          </td>
          <td>
            <div style="display:flex;gap:6px;align-items:center">
              <button class="icon-btn warn btn-toggle" data-id="${esc(b.id)}" data-activo="${b.activo ? '1' : '0'}" title="${b.activo ? 'Desactivar ban' : 'Activar ban'}">
                <i class="ti ${b.activo ? 'ti-eye-off' : 'ti-eye'}"></i>
              </button>
              <button class="icon-btn danger btn-del" data-id="${esc(b.id)}" title="Eliminar ban permanentemente">
                <i class="ti ti-trash"></i>
              </button>
            </div>
          </td>
        </tr>`;
    }).join('');

    wrap.innerHTML = `
      <div class="tbl-wrap">
        <table class="tbl">
          <thead>
            <tr>
              <th>Nick / Tag</th>
              <th>Steam ID</th>
              <th>IP</th>
              <th>Tipo</th>
              <th>Motivo</th>
              <th>Duración</th>
              <th>Estado</th>
              <th></th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      </div>`;

    // Toggle ban
    wrap.querySelectorAll<HTMLButtonElement>('.btn-toggle').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id     = btn.dataset.id!;
        const activo = btn.dataset.activo === '1' ? 0 : 1;
        const res = await fetch('/api/admin-bans', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, activo }),
        });
        if (res.ok) {
          const ban = allBans.find(b => String(b.id) === id);
          if (ban) { ban.activo = activo; renderTable(); }
          toast(activo ? 'Ban activado' : 'Ban desactivado');
        } else {
          toast('Error al actualizar el ban', 'err');
        }
      });
    });

    // Eliminar ban
    wrap.querySelectorAll<HTMLButtonElement>('.btn-del').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!await confirmAction('¿Eliminar este ban permanentemente? No se puede deshacer.')) return;
        const id = btn.dataset.id!;
        const res = await fetch('/api/admin-bans', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (res.ok) {
          allBans = allBans.filter(b => String(b.id) !== id);
          renderTable();
          toast('Ban eliminado');
        } else {
          toast('Error al eliminar', 'err');
        }
      });
    });
  }

  // ── Cargar bans desde API ─────────────────────────────────
  async function loadBans() {
    const wrap = $('banListWrap');
    wrap.innerHTML = `<div class="empty"><i class="ti ti-loader-2" style="animation:spin 0.8s linear infinite"></i><p>Cargando…</p></div>`;
    try {
      const res = await fetch('/api/admin-bans');
      const j   = await res.json();
      if (!j.ok) {
        wrap.innerHTML = `<div class="empty"><i class="ti ti-wifi-off"></i><p>Error: ${esc(j.error)}</p></div>`;
        return;
      }
      allBans = j.bans ?? [];
      renderTable();
    } catch {
      wrap.innerHTML = `<div class="empty"><i class="ti ti-wifi-off"></i><p>Error de red al cargar bans.</p></div>`;
    }
  }

  // ── Filtros en tiempo real ────────────────────────────────
  inp('banSearch').addEventListener('input', renderTable);
  sel('banTipoFilter').addEventListener('change', renderTable);
  sel('banActivoFilter').addEventListener('change', renderTable);
  $('banSearchClear').addEventListener('click', () => { inp('banSearch').value = ''; renderTable(); });
  $('btnRefresh').addEventListener('click', loadBans);

  // ── Agregar ban ───────────────────────────────────────────
  $('addBanBtn').addEventListener('click', async () => {
    const btn   = $('addBanBtn') as HTMLButtonElement;
    const errEl = $('b-err');
    errEl.textContent = '';

    const nick    = inp('b-nick').value.trim();
    const tag     = inp('b-tag').value.trim();
    const steam   = inp('b-steam').value.trim();
    const ip      = inp('b-ip').value.trim();
    const tipo    = sel('b-tipo').value;
    const dur     = inp('b-dur').value.trim();
    const motivo  = ta('b-motivo').value.trim();

    if (!nick)               { errEl.textContent = 'El nick es obligatorio.'; return; }
    if (motivo.length < 3)   { errEl.textContent = 'El motivo es obligatorio (mínimo 3 caracteres).'; return; }

    btn.disabled = true;
    btn.classList.add('loading');

    try {
      const res = await fetch('/api/admin-bans', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nick, tipo, motivo,
          tag:      tag    || null,
          steam_id: steam  || null,
          ip:       ip     || null,
          duracion: dur    || null,
        }),
      });
      const j = await res.json();
      if (res.ok && j.ok) {
        inp('b-nick').value = '';
        inp('b-tag').value  = '';
        inp('b-steam').value = '';
        inp('b-ip').value   = '';
        inp('b-dur').value  = '';
        ta('b-motivo').value = '';
        toast('Ban agregado correctamente');
        await loadBans();
      } else {
        errEl.textContent = j.error || 'Error al agregar el ban.';
      }
    } catch {
      errEl.textContent = 'Error de red.';
    }

    btn.disabled = false;
    btn.classList.remove('loading');
  });

  // ── Enter en campos dispara submit ────────────────────────
  ['b-nick', 'b-steam', 'b-ip', 'b-dur'].forEach(id => {
    document.getElementById(id)?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') ($('addBanBtn') as HTMLButtonElement).click();
    });
  });

  // ── Init ──────────────────────────────────────────────────
  loadBans();
</script>