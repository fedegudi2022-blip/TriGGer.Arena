---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { query } from '../../lib/db';

interface BanRow {
  id: string;
  nick: string;
  tag: string | null;
  steam_id: string | null;
  ip: string | null;
  motivo: string;
  tipo: 'hack' | 'insultos' | 'bug_abuse' | 'trampa' | 'otro';
  admin_nick: string | null;
  fecha_ban: string;
  duracion: string | null;
  activo: number;
}

const PAGE_SIZE = 20;
const page   = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1'));
const search = Astro.url.searchParams.get('q')?.trim() ?? '';
const offset = (page - 1) * PAGE_SIZE;

let bans: BanRow[] = [];
let total = 0;
let dbError: string | null = null;

const TABLE_SQL = `
  CREATE TABLE IF NOT EXISTS bans (
    id         VARCHAR(36)  NOT NULL PRIMARY KEY,
    nick       VARCHAR(80)  NOT NULL,
    tag        VARCHAR(40)  NULL,
    steam_id   VARCHAR(30)  NULL,
    ip         VARCHAR(45)  NULL,
    motivo     TEXT         NOT NULL,
    tipo       ENUM('hack','insultos','bug_abuse','trampa','otro') NOT NULL DEFAULT 'otro',
    admin_nick VARCHAR(80)  NULL,
    fecha_ban  DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP,
    duracion   VARCHAR(40)  NULL,
    activo     TINYINT(1)   NOT NULL DEFAULT 1,
    INDEX idx_nick (nick),
    INDEX idx_steam (steam_id),
    INDEX idx_activo (activo)
  ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
`;

try {
  await query(TABLE_SQL);
  // Migrations
  for (const sql of [
    `ALTER TABLE bans ADD COLUMN IF NOT EXISTS tag VARCHAR(40) NULL AFTER nick`,
    `ALTER TABLE bans ADD COLUMN IF NOT EXISTS steam_id VARCHAR(30) NULL AFTER tag`,
    `ALTER TABLE bans ADD COLUMN IF NOT EXISTS ip VARCHAR(45) NULL AFTER steam_id`,
  ]) {
    try { await query(sql); } catch { /* ya existe */ }
  }

  const where = search
    ? `WHERE activo = 1 AND (nick LIKE :q OR tag LIKE :q OR steam_id LIKE :q)`
    : `WHERE activo = 1`;

  const params = search ? { q: `%${search}%`, limit: PAGE_SIZE, offset } : { limit: PAGE_SIZE, offset };

  const [rows, countRows] = await Promise.all([
    query<BanRow>(
      `SELECT id, nick, tag, steam_id, motivo, tipo, admin_nick, fecha_ban, duracion, activo
         FROM bans ${where}
        ORDER BY fecha_ban DESC
        LIMIT :limit OFFSET :offset`,
      params
    ),
    query<{ total: number }>(
      `SELECT COUNT(*) as total FROM bans ${where}`,
      search ? { q: `%${search}%` } : {}
    ),
  ]);

  bans  = rows;
  total = countRows[0]?.total ?? 0;
} catch (e: any) {
  dbError = e?.message ?? 'Error de base de datos';
  console.error('[baneados]', e);
}

const totalPages = Math.ceil(total / PAGE_SIZE);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('es-AR', {
    day: '2-digit', month: '2-digit', year: 'numeric',
  });
}

const tipoLabel: Record<string, string> = {
  hack:      'Hack / Cheat',
  insultos:  'Insultos',
  bug_abuse: 'Bug Abuse',
  trampa:    'Trampa',
  otro:      'Otro',
};
const tipoColor: Record<string, string> = {
  hack:      'ban-tag--red',
  insultos:  'ban-tag--orange',
  bug_abuse: 'ban-tag--yellow',
  trampa:    'ban-tag--red',
  otro:      'ban-tag--muted',
};
---

<Layout title="Baneados — TriGGer.Arena" noindex>
  <Navbar />

  <main class="bans-main">

    <div class="bans-hero">
      <div class="bans-hero-bg" aria-hidden="true"></div>
      <div class="container">
        <div class="bans-hero-inner">
          <div class="bans-eyebrow">
            <i class="ti ti-ban" aria-hidden="true"></i>
            Lista de sancionados
          </div>
          <h1 class="bans-title">Jugadores Baneados</h1>
          <p class="bans-sub">
            Registro público de sanciones activas. Podés buscar por nick, tag o Steam ID.
          </p>
          <form class="bans-search" method="get" action="/baneados">
            <div class="search-wrap">
              <i class="ti ti-search search-icon" aria-hidden="true"></i>
              <input
                type="search"
                name="q"
                class="search-inp"
                placeholder="Buscar por nick, tag o Steam ID…"
                value={search}
                maxlength="80"
                autocomplete="off"
              />
              {search && (
                <a href="/baneados" class="search-clear" title="Limpiar búsqueda">
                  <i class="ti ti-x"></i>
                </a>
              )}
            </div>
            <button type="submit" class="search-btn">Buscar</button>
          </form>
        </div>
      </div>
    </div>

    <div class="container bans-body">

      {dbError && (
        <div class="ban-alert">
          <i class="ti ti-alert-triangle"></i>
          Error al cargar los datos. Intentá de nuevo más tarde.
        </div>
      )}

      <div class="bans-meta">
        {search
          ? <span>{total} resultado{total !== 1 ? 's' : ''} para "<strong>{search}</strong>"</span>
          : <span>{total} sanción{total !== 1 ? 'es' : ''} activa{total !== 1 ? 's' : ''}</span>
        }
        {totalPages > 1 && <span class="bans-meta-page">Página {page} de {totalPages}</span>}
      </div>

      {bans.length === 0 && !dbError ? (
        <div class="bans-empty">
          <i class="ti ti-mood-happy" aria-hidden="true"></i>
          <p>{search ? 'No se encontraron bans para esa búsqueda.' : 'No hay sanciones activas.'}</p>
          {search && <a href="/baneados" class="bans-empty-link">Ver todos los baneados</a>}
        </div>
      ) : (
        <>
          <div class="bans-table-wrap">
            <table class="bans-table">
              <thead>
                <tr>
                  <th>Nick</th>
                  <th>Tag</th>
                  <th>Steam ID</th>
                  <th>Tipo</th>
                  <th>Motivo</th>
                  <th>Duración</th>
                  <th>Fecha</th>
                  <th>Admin</th>
                </tr>
              </thead>
              <tbody>
                {bans.map(ban => (
                  <tr>
                    <td class="ban-nick">
                      <i class="ti ti-user-x" aria-hidden="true"></i>
                      {ban.nick}
                    </td>
                    <td class="ban-tag-cell">
                      {ban.tag
                        ? <span class="ban-clan-tag">{ban.tag}</span>
                        : <span class="ban-empty-cell">—</span>
                      }
                    </td>
                    <td class="ban-steam">
                      {ban.steam_id
                        ? <code class="steam-code">{ban.steam_id}</code>
                        : <span class="ban-empty-cell">—</span>
                      }
                    </td>
                    <td>
                      <span class={`ban-tag ${tipoColor[ban.tipo] ?? 'ban-tag--muted'}`}>
                        {tipoLabel[ban.tipo] ?? ban.tipo}
                      </span>
                    </td>
                    <td class="ban-motivo">{ban.motivo}</td>
                    <td class="ban-dur">
                      {ban.duracion
                        ? <span class="ban-dur-temp">{ban.duracion}</span>
                        : <span class="ban-dur-perm"><i class="ti ti-infinity" aria-hidden="true"></i> Permanente</span>
                      }
                    </td>
                    <td class="ban-date">{formatDate(ban.fecha_ban)}</td>
                    <td class="ban-admin">{ban.admin_nick ?? '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {totalPages > 1 && (
            <nav class="bans-pagination" aria-label="Paginación">
              {page > 1 && (
                <a href={`/baneados?page=${page - 1}${search ? `&q=${encodeURIComponent(search)}` : ''}`} class="page-btn">
                  <i class="ti ti-chevron-left"></i> Anterior
                </a>
              )}
              <span class="page-info">{page} / {totalPages}</span>
              {page < totalPages && (
                <a href={`/baneados?page=${page + 1}${search ? `&q=${encodeURIComponent(search)}` : ''}`} class="page-btn">
                  Siguiente <i class="ti ti-chevron-right"></i>
                </a>
              )}
            </nav>
          )}
        </>
      )}

    </div>
  </main>

  <Footer />
</Layout>

<style>
  .bans-main { min-height: 80vh; padding-bottom: 80px; }

  .bans-hero {
    position: relative; padding: 80px 0 48px; text-align: center;
    border-bottom: 1px solid var(--border);
  }
  .bans-hero-bg {
    position: absolute; inset: 0; z-index: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(239,68,68,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
  .bans-hero-inner { max-width: 620px; margin: 0 auto; }

  .bans-eyebrow {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em;
    text-transform: uppercase; color: #ef4444;
    padding: 5px 14px; border-radius: 999px;
    background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);
    margin-bottom: 18px;
  }
  .bans-title {
    font-family: var(--font-display); font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 700; color: var(--text); margin-bottom: 12px; line-height: 1.1;
  }
  .bans-sub { font-size: 0.9rem; color: var(--muted-2); margin-bottom: 28px; }

  .bans-search { display: flex; gap: 8px; max-width: 520px; margin: 0 auto; }
  .search-wrap {
    flex: 1; position: relative; display: flex; align-items: center;
    background: var(--surface-1, var(--surface)); border: 1px solid var(--border); border-radius: var(--radius);
  }
  .search-wrap:focus-within { border-color: var(--accent); }
  .search-icon { position: absolute; left: 12px; font-size: 15px; color: var(--muted); pointer-events: none; }
  .search-inp {
    flex: 1; background: none; border: none; outline: none;
    padding: 10px 36px 10px 36px; font-size: 0.85rem; color: var(--text);
    font-family: var(--font-body);
  }
  .search-inp::placeholder { color: var(--muted); }
  .search-clear {
    position: absolute; right: 10px; font-size: 14px; color: var(--muted);
    text-decoration: none; line-height: 1;
  }
  .search-clear:hover { color: var(--text); }
  .search-btn {
    padding: 10px 18px; background: var(--accent); color: #06080d;
    font-weight: 700; font-size: 0.8rem; border: none; border-radius: var(--radius);
    cursor: pointer; letter-spacing: 0.06em; text-transform: uppercase;
    transition: opacity 0.15s;
  }
  .search-btn:hover { opacity: 0.85; }

  .bans-body { padding-top: 28px; }
  .ban-alert {
    background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);
    border-radius: var(--radius); padding: 12px 16px; color: #ef4444;
    font-size: 0.85rem; display: flex; align-items: center; gap: 8px; margin-bottom: 20px;
  }
  .bans-meta {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 0.78rem; color: var(--muted); margin-bottom: 16px;
  }
  .bans-meta strong { color: var(--text); }

  .bans-empty {
    text-align: center; padding: 64px 24px;
    color: var(--muted); font-size: 0.9rem;
  }
  .bans-empty i { font-size: 40px; display: block; margin-bottom: 12px; }
  .bans-empty-link {
    display: inline-block; margin-top: 12px; color: var(--accent);
    font-size: 0.8rem; text-decoration: none;
  }
  .bans-empty-link:hover { text-decoration: underline; }

  .bans-table-wrap { overflow-x: auto; border-radius: var(--radius-lg); border: 1px solid var(--border); }
  .bans-table {
    width: 100%; border-collapse: collapse; font-size: 0.82rem;
    background: var(--surface-1, var(--surface));
  }
  .bans-table th {
    font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--muted); padding: 10px 14px;
    border-bottom: 1px solid var(--border); text-align: left;
    background: var(--surface-0, var(--surface-2)); white-space: nowrap;
  }
  .bans-table td {
    padding: 11px 14px; border-bottom: 1px solid var(--border);
    color: var(--text); vertical-align: middle;
  }
  .bans-table tr:last-child td { border-bottom: none; }
  .bans-table tr:hover td { background: rgba(255,255,255,0.02); }

  .ban-nick {
    font-family: var(--font-mono); font-weight: 600;
    display: flex; align-items: center; gap: 7px; white-space: nowrap;
  }
  .ban-nick i { color: #ef4444; font-size: 14px; }

  .ban-clan-tag {
    display: inline-block; font-family: var(--font-mono); font-size: 0.72rem;
    font-weight: 700; color: var(--accent); background: rgba(56,189,248,0.08);
    border: 1px solid rgba(56,189,248,0.2); border-radius: 4px;
    padding: 2px 7px; white-space: nowrap;
  }
  .ban-steam { white-space: nowrap; }
  .steam-code {
    font-family: var(--font-mono); font-size: 0.72rem; color: var(--muted-2);
    background: var(--surface-2, var(--surface)); border-radius: 3px;
    padding: 2px 6px;
  }
  .ban-empty-cell { color: var(--muted); opacity: 0.4; }
  .ban-motivo { color: var(--muted-2) !important; max-width: 220px; font-size: 0.8rem; }
  .ban-date, .ban-admin { color: var(--muted) !important; white-space: nowrap; font-size: 0.76rem; }
  .ban-tag-cell { white-space: nowrap; }

  .ban-tag {
    display: inline-block; font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.07em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 999px; white-space: nowrap;
    border: 1px solid transparent;
  }
  .ban-tag--red    { background: rgba(239,68,68,0.12); color: #f87171; border-color: rgba(239,68,68,0.25); }
  .ban-tag--orange { background: rgba(249,115,22,0.12); color: #fb923c; border-color: rgba(249,115,22,0.25); }
  .ban-tag--yellow { background: rgba(234,179,8,0.12); color: #facc15; border-color: rgba(234,179,8,0.25); }
  .ban-tag--muted  { background: var(--surface-2, var(--surface)); color: var(--muted); border-color: var(--border); }

  .ban-dur-perm {
    display: inline-flex; align-items: center; gap: 4px;
    color: #ef4444; font-size: 0.75rem; font-weight: 600;
  }
  .ban-dur-temp { color: var(--muted-2); font-size: 0.78rem; }

  .bans-pagination {
    display: flex; align-items: center; justify-content: center; gap: 12px;
    margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border);
  }
  .page-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 8px 16px; border-radius: var(--radius);
    border: 1px solid var(--border); background: var(--surface-1, var(--surface));
    color: var(--text); font-size: 0.8rem; text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .page-btn:hover { border-color: var(--accent); }
  .page-info { font-size: 0.78rem; color: var(--muted); }

  /* Hide IP column publicly — only admins see it in admin panel */
  @media (max-width: 768px) {
    .bans-table th:nth-child(3), .bans-table td:nth-child(3),
    .bans-table th:nth-child(8), .bans-table td:nth-child(8) { display: none; }
  }
  @media (max-width: 540px) {
    .bans-table th:nth-child(2), .bans-table td:nth-child(2) { display: none; }
    .bans-search { flex-direction: column; }
    .search-btn { width: 100%; }
  }
</style>
