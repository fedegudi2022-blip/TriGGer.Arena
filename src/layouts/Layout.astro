---
// ✅ OPTIMIZACIÓN: Fuentes críticas únicamente. JetBrains Mono (~60KB) eliminado.
//    Se usa solo en .s-label-text y .loader-text → fallback monospace es imperceptible.
//    Inter 400+600 y Rajdhani 600+700 cubren el 99% del diseño.
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/rajdhani/600.css';
import '@fontsource/rajdhani/700.css';
import { ClientRouter } from 'astro:transitions';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, DISCORD_URL, INSTAGRAM_URL, WHATSAPP_URL } from '../config';

export interface Props {
  title?: string;
  description?: string;
  /** Pone noindex,nofollow en páginas que no deberían aparecer en buscadores. */
  noindex?: boolean;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  noindex = false,
} = Astro.props;

// Canonical y OG image calculados por página (antes quedaban fijos en la
// home en TODAS las páginas, lo cual confundía a los buscadores).
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).toString();
const OG_IMAGE = new URL('/trigger_fondo.webp', SITE_URL).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'TriGGer.Arena',
      url: SITE_URL,
      logo: OG_IMAGE,
      sameAs: [DISCORD_URL, INSTAGRAM_URL, WHATSAPP_URL],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      name: SITE_TITLE,
      url: SITE_URL,
      publisher: { '@id': `${SITE_URL}/#organization` },
      inLanguage: 'es-AR',
    },
  ],
};
---
<!DOCTYPE html>
<html lang="es-AR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0b1220" />
  <meta name="author" content="TriGGer.Arena" />
  <meta name="keywords" content="Counter-Strike 1.6, CS 1.6, servidor, comunidad argentina, gaming" />
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:image:width" content="1254" />
  <meta property="og:image:height" content="1254" />
  <meta property="og:image:alt" content="TriGGer.Arena — Comunidad CS 1.6" />
  <meta property="og:image:type" content="image/webp" />
  <meta property="og:locale" content="es_AR" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={OG_IMAGE} />
  <meta property="twitter:image:alt" content="TriGGer.Arena — Comunidad CS 1.6" />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />
 <link rel="icon" type="image/webp" href="/trigger_fondo.webp" />

  <!-- Datos estructurados (Organization + WebSite) -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Preload LCP image con alta prioridad -->
  <link rel="preload" href="/trigger_fondo.webp" as="image" type="image/webp" fetchpriority="high" />

  <!-- Preconnect CDN (evita DNS lookup en el critical path) -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

  <!-- Tabler Icons: no-bloqueante (los íconos no son críticos para LCP) -->
  <link rel="preload" as="style" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" /></noscript>

  <!-- Client Router (View Transitions) entre páginas -->
  <ClientRouter />

  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>

  <!--
    PERF: Fondo decorativo como elementos reales en lugar de body::before/after.
    Los pseudo-elementos del body se repintan en cada scroll porque están en
    la misma capa que el contenido. Estos divs se pueden promover a su propia
    capa de composición y el browser no los vuelve a pintar.
  -->
    
  <!-- ── Pantalla de carga temática ── -->
  <div id="site-loader" aria-hidden="true">
    <div class="loader-crosshair">
      <span class="lch-ring lch-ring--outer"></span>
      <span class="lch-ring lch-ring--inner"></span>
      <span class="lch-seg lch-top"></span>
      <span class="lch-seg lch-bottom"></span>
      <span class="lch-seg lch-left"></span>
      <span class="lch-seg lch-right"></span>
      <span class="lch-dot"></span>
    </div>
    <span class="loader-text">CARGANDO<span class="loader-dots"><span>.</span><span>.</span><span>.</span></span></span>
  </div>

  <slot />
  <WhatsAppFloat />

  <!-- ── Indicador lateral de sección ── -->
  <nav class="section-dots" id="sectionDots" aria-label="Navegación de secciones">
    <button class="sdot" data-target="inicio"      aria-label="Inicio"></button>
    <button class="sdot" data-target="redes"        aria-label="Redes"></button>
    <button class="sdot" data-target="servidores"   aria-label="Servidores"></button>
    <button class="sdot" data-target="descargas"    aria-label="Descargas"></button>
    <button class="sdot" data-target="effexo"       aria-label="Effexo"></button>
    <button class="sdot" data-target="ventas"       aria-label="Planes"></button>
    <button class="sdot" data-target="howto"        aria-label="Cómo jugar"></button>
    <button class="sdot" data-target="reglas"       aria-label="Reglas"></button>
    <button class="sdot" data-target="contacto"     aria-label="Contacto"></button>
  </nav>

  <!-- ── Toast de notificaciones ── -->
  <div id="toast-container" role="status" aria-live="polite" aria-atomic="true"></div>

  <style is:global>
    /* ────────────────────────────────────────────────────────
       LOADER
    ──────────────────────────────────────────────────────── */
    #site-loader {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: var(--bg);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 28px;
      transition: opacity 0.4s ease, visibility 0.4s ease;
    }
    #site-loader.hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .loader-crosshair {
      position: relative;
      width: 72px;
      height: 72px;
      /* ✅ Promueve a capa de composición propia — evita repaint del resto del DOM */
      will-change: transform;
      contain: strict;
    }

    .lch-ring {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      border: 1px solid rgba(56,182,255,0.25);
      will-change: transform;
      /* PERF: contain:strict solo en el wrapper padre (loader-crosshair).
         En los rings solo necesitamos el hint de composición */
    }
    .lch-ring--outer {
      width: 72px; height: 72px;
      animation: lch-spin 3s linear infinite;
      border-top-color: rgba(56,182,255,0.7);
    }
    .lch-ring--inner {
      width: 46px; height: 46px;
      animation: lch-spin 2s linear infinite reverse;
      border-right-color: rgba(56,182,255,0.5);
    }
    @keyframes lch-spin { to { transform: translate(-50%,-50%) rotate(360deg); } }

    .lch-seg {
      position: absolute;
      background: rgba(56,182,255,0.55);
    }
    .lch-top    { width: 1px; height: 14px; top: 4px;    left: 50%; transform: translateX(-50%); }
    .lch-bottom { width: 1px; height: 14px; bottom: 4px; left: 50%; transform: translateX(-50%); }
    .lch-left   { height: 1px; width: 14px; left: 4px;   top: 50%;  transform: translateY(-50%); }
    .lch-right  { height: 1px; width: 14px; right: 4px;  top: 50%;  transform: translateY(-50%); }
    .lch-dot {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%,-50%);
      width: 4px; height: 4px;
      background: #38b6ff;
      border-radius: 50%;
      box-shadow: 0 0 8px #38b6ff, 0 0 16px rgba(56,182,255,0.4);
      animation: lch-pulse 1.4s ease-in-out infinite;
    }
    @keyframes lch-pulse { 0%,100% { opacity:0.4; } 50% { opacity:1; } }

    .loader-text {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      color: rgba(56,182,255,0.6);
      text-transform: uppercase;
    }
    .loader-dots span {
      animation: lch-blink 1.2s step-end infinite;
    }
    .loader-dots span:nth-child(2) { animation-delay: 0.2s; }
    .loader-dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes lch-blink { 0%,100%{opacity:1} 50%{opacity:0} }

    /* ────────────────────────────────────────────────────────
       INDICADOR LATERAL DE SECCIONES
    ──────────────────────────────────────────────────────── */
    .section-dots {
      position: fixed;
      right: 18px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 90;
      display: flex;
      flex-direction: column;
      gap: 8px;
      opacity: 0;
      transition: opacity 0.4s ease;
    }
    .section-dots.visible { opacity: 1; }

    .sdot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(56,182,255,0.22);
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s, height 0.2s;
      flex-shrink: 0;
    }
    .sdot:hover {
      background: rgba(56,182,255,0.55);
      transform: scale(1.4);
    }
    .sdot.active {
      background: #38b6ff;
      height: 18px;
      border-radius: 3px;
      box-shadow: 0 0 6px rgba(56,182,255,0.5);
    }

    @media (max-width: 900px) {
      .section-dots { display: none; }
    }

    /* ────────────────────────────────────────────────────────
       TOAST NOTIFICATIONS
    ──────────────────────────────────────────────────────── */
    #toast-container {
      position: fixed;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 9998;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      pointer-events: none;
    }

    .toast {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 20px;
      border-radius: 6px;
      font-family: 'Inter', sans-serif;
      font-size: 0.82rem;
      font-weight: 500;
      color: #e8eeff;
      background: var(--surface);
      border: 1px solid rgba(56,182,255,0.2);
      box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(56,182,255,0.06);
      pointer-events: auto;
      animation: toast-in 0.3s cubic-bezier(0.34,1.56,0.64,1) forwards;
      max-width: 340px;
      text-align: center;
    }
    .toast.toast--success { border-color: rgba(74,222,128,0.35); }
    .toast.toast--success .toast-icon { color: #4ade80; }
    .toast.toast--error   { border-color: rgba(248,113,113,0.35); }
    .toast.toast--error   .toast-icon { color: #f87171; }
    .toast.toast--info    { border-color: rgba(56,182,255,0.35); }
    .toast.toast--info    .toast-icon { color: #38b6ff; }
    .toast-icon { font-size: 16px; flex-shrink: 0; }

    .toast.toast--out {
      animation: toast-out 0.25s ease forwards;
    }

    @keyframes toast-in {
      from { opacity: 0; transform: translateY(12px) scale(0.95); }
      to   { opacity: 1; transform: translateY(0)    scale(1); }
    }
    @keyframes toast-out {
      to { opacity: 0; transform: translateY(8px) scale(0.95); }
    }

    /* ────────────────────────────────────────────────────────
       BOTÓN: FEEDBACK DE CLICK (ripple)
    ──────────────────────────────────────────────────────── */
    .hero-btn-main {
      position: relative;
      overflow: hidden;
    }
    .hero-btn-main::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255,255,255,0.18);
      border-radius: inherit;
      opacity: 0;
      transform: scale(0.8);
      transition: opacity 0.15s, transform 0.15s;
    }
    .hero-btn-main:active::after {
      opacity: 1;
      transform: scale(1);
      transition: none;
    }
  </style>

  <script>
    if (history.scrollRestoration) history.scrollRestoration = 'manual';
    window.scrollTo(0, 0);

    /* ── Loader ───────────────────────────────────────────────────────
       IMPORTANTE: este script vive en Layout.astro, o sea que es
       idéntico en TODAS las páginas. Con <ClientRouter /> (navegación
       SPA), Astro reconoce un script inline como "ya ejecutado" y no lo
       vuelve a correr en transiciones soft — solo en la carga inicial.
       Por eso NO podemos usar DOMContentLoaded (solo dispara una vez en
       toda la sesión). Hay que usar el evento de ciclo de vida
       `astro:page-load`, que Astro dispara tanto en la carga inicial
       como después de cada transición soft. Y hay que volver a buscar
       el elemento #site-loader en cada ejecución (no cachearlo afuera),
       porque cada página trae su propia instancia fresca tras el swap
       del DOM — la de la página anterior ya fue removida del árbol. ── */
    function hideLoader() {
      const loader = document.getElementById('site-loader');
      if (!loader) return;
      loader.classList.add('hidden');
      setTimeout(() => loader.remove(), 400);
    }
    document.addEventListener('astro:page-load', hideLoader);

    /* ── Indicador lateral de secciones ──────────────────────────
       Mismo problema que el loader: dotsNav/dots/sections se
       capturaban una sola vez y quedaban obsoletos tras la primera
       navegación SPA. Se reinicializa en cada astro:page-load. ── */
    let dotsAbort: AbortController | null = null;

    function initSectionDots() {
      dotsAbort?.abort();
      dotsAbort = new AbortController();
      const { signal } = dotsAbort;

      const dotsNav = document.getElementById('sectionDots');
      const dots    = dotsNav ? Array.from(dotsNav.querySelectorAll<HTMLButtonElement>('.sdot')) : [];

      function activateDot(target: string) {
        dots.forEach(d => d.classList.toggle('active', d.dataset.target === target));
      }

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const id = dot.dataset.target;
          if (!id) return;
          const el = document.getElementById(id);
          if (!el) return;
          const offset = 58 + 16;
          const top = el.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        }, { signal });
      });

      // Mostrar dots después de hacer scroll — throttled con rAF
      let dotsVisible = false;
      let dotsRaf: number | null = null;
      window.addEventListener('scroll', () => {
        if (dotsRaf) return;
        dotsRaf = requestAnimationFrame(() => {
          if (!dotsNav) { dotsRaf = null; return; }
          if (!dotsVisible && window.scrollY > 200) {
            dotsVisible = true;
            dotsNav.classList.add('visible');
          } else if (dotsVisible && window.scrollY <= 200) {
            dotsVisible = false;
            dotsNav.classList.remove('visible');
          }
          dotsRaf = null;
        });
      }, { passive: true, signal });

      // Activar dot según sección visible
      const sections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
      const sectionObserver = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) activateDot(e.target.id);
        });
      }, { threshold: 0.35 });
      sections.forEach(s => sectionObserver.observe(s));
      signal.addEventListener('abort', () => sectionObserver.disconnect());
    }

    initSectionDots();
    document.addEventListener('astro:page-load', initSectionDots);

    /* ── Toast global ─────────────────────────────────── */
    type ToastType = 'success' | 'error' | 'info';
    const ICONS: Record<ToastType, string> = {
      success: 'ti-circle-check',
      error:   'ti-circle-x',
      info:    'ti-info-circle',
    };

    window.showToast = function(message: string, type: ToastType = 'info', duration = 3500) {
      const container = document.getElementById('toast-container');
      if (!container) return;

      const toast = document.createElement('div');
      toast.className = `toast toast--${type}`;
      toast.innerHTML = `<i class="ti ${ICONS[type]} toast-icon" aria-hidden="true"></i><span>${message}</span>`;
      container.appendChild(toast);

      setTimeout(() => {
        toast.classList.add('toast--out');
        setTimeout(() => toast.remove(), 300);
      }, duration);
    };

    /* ── Scroll con offset correcto para navbar fija ──── */
    document.addEventListener('click', (e) => {
      const anchor = (e.target as Element).closest<HTMLAnchorElement>('a[href^="#"]');
      if (!anchor) return;
      const hash = anchor.getAttribute('href');
      if (!hash || hash === '#') return;
      const target = document.querySelector(hash);
      if (!target) return;
      e.preventDefault();
      const offset = 58 + 16;
      const top = target.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  </script>
</body>
</html>