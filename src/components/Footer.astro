---
import { DEFAULT_CONTENT_BLOCKS } from '../lib/site-data';

const year = new Date().getFullYear();
const f = Astro.locals.contentBlocks?.footer ?? DEFAULT_CONTENT_BLOCKS.footer;
const isOperativo = (Astro.locals.siteSettings?.site_status ?? 'operativo') === 'operativo';
---
<footer class="footer">
  <div class="footer-accent-line" aria-hidden="true"></div>

  <div class="container footer-grid">

    <div class="footer-col footer-brand">
      <button class="footer-logo back-to-top" id="back-to-top" aria-label="Volver al inicio de la página">
        <img src="/trigger_fondo.webp" alt="TriGGer.Arena" width="28" height="28" loading="lazy" fetchpriority="low" />
        <span>Tri<span class="accent">GG</span>er<span class="accent">.Arena</span></span>
      </button>
      <p class="footer-tagline">{f.tagline}</p>
    </div>

    <nav class="footer-col footer-links" aria-label="Navegación del pie de página">
      <span class="footer-col-title">Navegación</span>
      <a href="#servidores"># Servidores</a>
      <a href="#reglas"># Reglas</a>
      <a href="#descargas"># Descargas</a>
      <a href="#ventas"># Planes</a>
      <a href="/quejas"># Reportar jugador</a>
    </nav>

    <div class="footer-col footer-status">
      {/* FIX: tildes correctas en "Página" y "Página Operativa" */}
      <span class="footer-col-title">Estado de la Página</span>
      <span class={`status-pill ${isOperativo ? '' : 'status-pill--warn'}`}>
        <span
          class={`status-dot ${isOperativo ? '' : 'status-dot--warn'}`}
          role="img"
          aria-label={isOperativo ? 'En línea' : 'En mantenimiento'}
        ></span>
        {isOperativo ? 'Página Operativa' : 'En mantenimiento'}
      </span>
      {/*
        FIX: un solo handler de scroll-to-top compartido por ambos botones.
        Antes había dos IDs distintos (back-to-top / back-to-top-alt) con
        listeners separados. Ahora usamos la clase .back-to-top y un único
        querySelectorAll en el script.
      */}
      <button class="back-to-top-link back-to-top" aria-label="Volver al inicio de la página">
        # Volver arriba
      </button>
    </div>

  </div>

  <div class="footer-divider" aria-hidden="true"></div>

  <div class="container footer-bottom">
    <p class="footer-copy">© {year} Tri<span class="footer-copy-gg">GG</span>er<span class="footer-copy-arena">.Arena</span> | Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    padding: 56px 0 28px;
  }

  .footer-accent-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--border);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: var(--spacing-2xl);
    margin-bottom: 36px;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col-title {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }

  /* ── Marca ── */
  .footer-logo {
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    padding: 0;
    align-self: flex-start;
    border-radius: 6px;
    outline: none;
    transition: opacity 0.18s;
  }

  .footer-logo:hover { opacity: 0.7; }

  /* Focus visible para navegación por teclado */
  .footer-logo:focus-visible {
    opacity: 1;
    box-shadow: 0 0 0 2px rgba(56,182,255,0.5);
  }

  .footer-logo img {
    width: 28px;
    height: 28px;
    object-fit: contain;
    border-radius: 50%;
  }

  .accent { color: var(--accent); }

  .footer-tagline {
    font-size: 0.82rem;
    color: var(--muted-2);
    line-height: 1.6;
    max-width: 320px;
  }

  /* ── Navegación ── */
  .footer-links a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted-2);
    padding: 2px 0;
    width: fit-content;
    transition: color 0.18s;
    border-radius: 3px;
    outline: none;
  }

  .footer-links a:hover       { color: var(--accent); }
  .footer-links a:focus-visible {
    color: var(--accent);
    box-shadow: 0 0 0 2px rgba(56,182,255,0.4);
    padding-inline: 4px;
  }

  /* ── Estado ── */
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--muted-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 6px 12px;
    width: fit-content;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    /*
      PERF + A11Y: la animación solo corre si el usuario no tiene
      prefers-reduced-motion activo. El estado operativo/warn ya se
      comunica por texto, así que el pulse es puramente decorativo.
    */
    animation: pulse 2.5s infinite;
  }

  .status-pill--warn {
    color: #fbbf24;
    border-color: rgba(251,191,36,0.3);
  }
  .status-dot--warn {
    background: #fbbf24;
    animation: pulse-warn 2.5s infinite;
  }

  @keyframes pulse      { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  @keyframes pulse-warn { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  .back-to-top-link {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--muted);
    padding: 4px 0;
    width: fit-content;
    transition: color 0.18s;
    border-radius: 3px;
    outline: none;
    text-align: left;
  }

  .back-to-top-link:hover        { color: var(--accent); }
  .back-to-top-link:focus-visible {
    color: var(--accent);
    box-shadow: 0 0 0 2px rgba(56,182,255,0.4);
    padding-inline: 4px;
  }

  /* ── Línea + copyright ── */
  .footer-divider {
    width: 100%;
    height: 1px;
    background: var(--border);
    margin-bottom: 20px;
  }

  .footer-bottom {
    display: flex;
    justify-content: center;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    opacity: 0.5;
    letter-spacing: 0.04em;
    text-align: center;
  .footer-copy-gg, .footer-copy-arena { color: var(--accent); }
  }

  /* ── prefers-reduced-motion ── */
  @media (prefers-reduced-motion: reduce) {
    .status-dot,
    .status-dot--warn { animation: none; }
    .footer-logo,
    .footer-links a,
    .back-to-top-link { transition: none; }
  }

  /* ── forced-colors (modo alto contraste Windows) ── */
  @media (forced-colors: active) {
    .status-dot       { forced-color-adjust: none; background: green; }
    .status-dot--warn { forced-color-adjust: none; background: yellow; }
    .footer-accent-line { display: none; }
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
      text-align: left;
    }
  }
</style>

<script>
  // Mismo fix que el resto — ver comentario en SlidePanel.astro.
  function initFooter() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function scrollToTop() {
      window.scrollTo({
        top: 0,
        behavior: prefersReducedMotion ? 'auto' : 'smooth',
      });
    }

    // Un único selector para ambos botones en lugar de dos IDs separados
    document.querySelectorAll<HTMLButtonElement>('.back-to-top').forEach(btn => {
      btn.addEventListener('click', scrollToTop);
    });
  }

  initFooter();
  document.addEventListener('astro:page-load', initFooter);
</script>