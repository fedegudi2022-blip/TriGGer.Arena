---
const { user, profile, siteSettings } = Astro.locals;
const isAdmin = profile?.role === 'admin';
const isMaintenance = siteSettings?.site_status === 'mantenimiento';

const accountName = user
  ? (profile?.username ?? user.email?.split('@')[0] ?? 'Cuenta')
  : null;
const avatarUrl = profile?.avatar_url ?? '';
const accountHref  = isAdmin ? '/admin' : '/usuario';

// Mapa: id de sección pública → ruta (hash) dentro del panel admin.
// Le da al admin un acceso directo de "Editar" sobre cada sección mientras
// navega el sitio público, sin tener que buscar la pestaña correspondiente
// a mano dentro de /admin.
const SECTION_ADMIN_MAP: Record<string, string> = {
  inicio:     'contenido:hero',
  servidores: 'servidores',
  descargas:  'descargas',
  redes:      'contenido:social',
  reglas:     'contenido:rules',
  ventas:     'planes',
  effexo:     'contenido:effexo',
};
---

<header class="nb" id="nb" data-admin={isAdmin ? '1' : '0'} data-admin-edit-map={isAdmin ? JSON.stringify(SECTION_ADMIN_MAP) : undefined}>
  <div class="nb-progress" id="nbProgress" aria-hidden="true"></div>

  <div class="container nb-inner">

    <!-- Logo -->
    <button class="nb-logo" id="nbLogo" aria-label="Inicio">
      <div class="nb-logo-img">
        <img src="/trigger_fondo.webp" alt="TriGGer.Arena" width="30" height="30" loading="eager" />
        <span class="nb-logo-ring" aria-hidden="true"></span>
      </div>
      <span class="nb-logo-text">TriGGer<span class="nb-logo-dot">.Arena</span></span>
    </button>

    <!-- Desktop nav -->
    <nav class="nb-links" id="nbLinks" aria-label="Navegación principal">
      {[
        { id: 'inicio',     label: 'Inicio' },
        { id: 'servidores', label: 'Servidores' },
        { id: 'descargas',  label: 'Descargas' },
        { id: 'redes',      label: 'Redes' },
        { id: 'reglas',     label: 'Reglamento' },
        { id: 'ventas',     label: 'Planes' },
        { id: 'effexo',     label: 'Effexo' },
      ].map(item => (
        <span class="nb-link-wrap">
          <a href={`#${item.id}`} class="nb-link" data-section={item.id}><span>{item.label}</span></a>
          {isAdmin && (
            <button
              class="nb-edit-pencil"
              title={`Editar "${item.label}" en el panel admin`}
              aria-label={`Editar ${item.label}`}
              data-panel-url={`/admin#${SECTION_ADMIN_MAP[item.id]}`}
              data-panel-title={`Editar · ${item.label}`}
            >
              <i class="ti ti-pencil" aria-hidden="true"></i>
            </button>
          )}
        </span>
      ))}
    </nav>

    <!-- Right side -->
    <div class="nb-right">
      {user ? (
        <div class="nb-user" id="nbUser">
          <!-- Botón dedicado para abrir el panel directamente -->
          <button
            class="nb-panel-btn"
            id="nbPanelBtn"
            aria-label={isAdmin ? 'Abrir panel admin' : 'Abrir mi cuenta'}
            title={isAdmin ? 'Panel Admin' : 'Mi Cuenta'}
            data-panel-url={isAdmin ? '/admin' : '/usuario'}
            data-panel-title={isAdmin ? 'Panel Admin' : 'Mi Cuenta'}
          >
            {avatarUrl
              ? <img src={avatarUrl} alt="" width="22" height="22" class="nb-panel-btn-avatar" />
              : <i class={isAdmin ? 'ti ti-layout-dashboard' : 'ti ti-user-circle'} aria-hidden="true"></i>
            }
            {isAdmin && <span class="nb-admin-dot nb-admin-dot--btn" title="Admin" aria-label="Admin"></span>}
            <span class="nb-panel-btn-label">{isAdmin ? 'Admin' : accountName?.split(' ')[0]}</span>
            <i class="ti ti-chevron-right nb-panel-btn-chevron" aria-hidden="true"></i>
          </button>

          <button class="nb-user-btn nb-user-btn--opts" id="nbUserBtn" aria-haspopup="menu" aria-expanded="false" aria-controls="nbUserMenu" title="Opciones" aria-label="Más opciones">
            <i class="ti ti-dots-vertical" aria-hidden="true"></i>
          </button>

          <div class="nb-dropdown" id="nbUserMenu" role="menu" aria-hidden="true">
            <div class="nb-dropdown-header">
              <span class="nb-dropdown-email">{user.email}</span>
              {isAdmin && <span class="nb-dropdown-badge">Admin</span>}
            </div>
            {isAdmin && isMaintenance && (
              <a href="/admin#configuracion" class="nb-dropdown-maintenance" role="menuitem"
                 data-panel-url="/admin#configuracion"
                 data-panel-title="Configuración"
              >
                <i class="ti ti-tool" aria-hidden="true"></i>
                <span>Sitio en mantenimiento — gestionar</span>
              </a>
            )}
            <div class="nb-dropdown-sep"></div>
            <a href={accountHref} class="nb-dropdown-item" role="menuitem"
               data-panel-url={accountHref}
               data-panel-title={isAdmin ? 'Panel Admin' : 'Mi Cuenta'}
            >
              <i class={isAdmin ? 'ti ti-layout-dashboard' : 'ti ti-user'} aria-hidden="true"></i>
              <span>{isAdmin ? 'Panel admin' : 'Mi cuenta'}</span>
              <i class="ti ti-arrow-bar-right nb-panel-arrow" aria-hidden="true"></i>
            </a>
            {isAdmin && (
              <>
                <a href="/usuario" class="nb-dropdown-item" role="menuitem"
                   data-panel-url="/usuario"
                   data-panel-title="Mi Perfil"
                >
                  <i class="ti ti-user-circle" aria-hidden="true"></i>
                  <span>Mi perfil</span>
                  <i class="ti ti-arrow-bar-right nb-panel-arrow" aria-hidden="true"></i>
                </a>
                <a href="/admin#contenido" class="nb-dropdown-item" role="menuitem"
                   data-panel-url="/admin#contenido"
                   data-panel-title="Editar Contenido"
                >
                  <i class="ti ti-edit" aria-hidden="true"></i>
                  <span>Editar contenido del sitio</span>
                  <i class="ti ti-arrow-bar-right nb-panel-arrow" aria-hidden="true"></i>
                </a>
              </>
            )}
            <div class="nb-dropdown-sep"></div>
            <button class="nb-dropdown-item nb-dropdown-item--danger" id="nbLogout" role="menuitem">
              <i class="ti ti-logout" aria-hidden="true"></i>
              <span>Cerrar sesión</span>
            </button>
          </div>
        </div>
      ) : (
        <div class="nb-guest">
          <span class="nb-guest-label">
            <i class="ti ti-shield-check" aria-hidden="true"></i>
            Invitado
          </span>
          <a href="/auth" class="nb-login-btn">
            <i class="ti ti-login-2" aria-hidden="true"></i>
            Ingresar
          </a>
        </div>
      )}

      <!-- Hamburger -->
      <button class="nb-toggle" id="nbToggle" aria-label="Menú" aria-expanded="false" aria-controls="nbMenu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="nb-mobile" id="nbMenu" aria-hidden="true">
    <nav class="nb-mobile-links">
      <a href="#inicio"     class="nb-mobile-link"><i class="ti ti-home-2"></i><span>Inicio</span></a>
      <a href="#servidores" class="nb-mobile-link"><i class="ti ti-server"></i><span>Servidores</span></a>
      <a href="#descargas"  class="nb-mobile-link"><i class="ti ti-download"></i><span>Descargas</span></a>
      <a href="#redes"      class="nb-mobile-link"><i class="ti ti-share"></i><span>Redes</span></a>
      <a href="#reglas"     class="nb-mobile-link"><i class="ti ti-shield"></i><span>Reglamento</span></a>
      <a href="#ventas"     class="nb-mobile-link"><i class="ti ti-diamond"></i><span>Planes</span></a>
      <a href="#effexo"     class="nb-mobile-link"><i class="ti ti-bolt"></i><span>Effexo</span></a>
    </nav>
    <div class="nb-mobile-foot">
      {user ? (
        <>
          {isAdmin && isMaintenance && (
            <a href="/admin#configuracion" class="nb-mobile-maintenance"
               data-panel-url="/admin#configuracion"
               data-panel-title="Configuración"
            >
              <i class="ti ti-tool"></i>
              Sitio en mantenimiento — gestionar
            </a>
          )}
          <button
            class="nb-mobile-account"
            id="nbMobilePanelBtn"
            data-panel-url={isAdmin ? '/admin' : '/usuario'}
            data-panel-title={isAdmin ? 'Panel Admin' : 'Mi Cuenta'}
          >
            <div class="nb-mobile-avatar">
              {avatarUrl ? <img src={avatarUrl} alt="" width="36" height="36" /> : <i class="ti ti-user"></i>}
            </div>
            <div>
              <span class="nb-mobile-name">{accountName}</span>
              <span class="nb-mobile-role">{isAdmin ? '⚡ Administrador' : 'Jugador'}</span>
            </div>
            <i class="ti ti-arrow-right" style="margin-left:auto;opacity:.4"></i>
          </button>
          {isAdmin && (
            <a href="/admin#contenido" class="nb-mobile-edit"
               data-panel-url="/admin#contenido"
               data-panel-title="Editar Contenido"
            >
              <i class="ti ti-edit"></i>
              Editar contenido del sitio
            </a>
          )}
          <button class="nb-mobile-logout" id="nbLogoutMobile">
            <i class="ti ti-logout"></i>
            Cerrar sesión
          </button>
        </>
      ) : (
        <a href="/auth" class="nb-mobile-login">
          <i class="ti ti-login-2"></i>
          Ingresar a tu cuenta
        </a>
      )}
    </div>
  </div>
</header>

<div class="nb-overlay" id="nbOverlay" aria-hidden="true"></div>

<style>
  .nb {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 200;
    height: 60px;
    background: rgba(7,9,15,0.85);
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s, background 0.25s;
    contain: layout style;
  }
  .nb.scrolled {
    background: rgba(7,9,15,0.97);
    border-bottom-color: var(--border);
  }

  /* Progress bar — sin glow */
  .nb-progress {
    position: absolute; top: 0; left: 0; height: 1.5px; width: 0%;
    background: var(--accent);
    transition: width 0.08s linear;
    z-index: 2;
    border-radius: 0 1px 1px 0;
    opacity: 0.7;
  }

  .nb-inner {
    display: flex; align-items: center;
    justify-content: space-between;
    height: 60px; position: relative; z-index: 1;
    gap: 12px;
  }

  /* Logo */
  .nb-logo {
    background: none; border: none; cursor: pointer; padding: 0;
    display: flex; align-items: center; gap: 9px; flex-shrink: 0;
    transition: opacity 0.15s ease;
  }
  .nb-logo:hover { opacity: 0.8; }
  .nb-logo-img { position: relative; width: 28px; height: 28px; flex-shrink: 0; }
  .nb-logo-img img { width: 100%; height: 100%; object-fit: contain; border-radius: 50%; }
  .nb-logo-ring { display: none; }
  .nb-logo-text { font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: var(--text); }
  .nb-logo-dot { color: var(--accent); }

  /* Links */
  .nb-links { display: flex; align-items: center; gap: 0; }
  .nb-link-wrap { position: relative; display: flex; align-items: center; }
  .nb-link {
    position: relative; padding: 6px 11px;
    font-size: 0.7rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--muted); border-radius: var(--radius);
    transition: color 0.15s ease;
  }
  .nb-link span { position: relative; z-index: 1; }
  .nb-link:hover { color: var(--text); }
  .nb-link.active { color: var(--text); }
  .nb-link.active::after {
    content: '';
    position: absolute;
    bottom: 2px; left: 50%;
    transform: translateX(-50%);
    width: 14px; height: 1.5px;
    background: var(--accent);
    border-radius: 1px;
  }

  /* Lápiz de edición admin */
  .nb-edit-pencil {
    display: flex; align-items: center; justify-content: center;
    width: 16px; height: 16px; margin-left: -2px;
    border-radius: 3px;
    color: var(--muted);
    opacity: 0; transform: scale(0.85);
    transition: opacity 0.15s, transform 0.15s, color 0.15s;
    background: none; border: none; padding: 0; cursor: pointer; font: inherit;
  }
  .nb-edit-pencil .ti { font-size: 10px; }
  .nb-link-wrap:hover .nb-edit-pencil { opacity: 1; transform: scale(1); }
  .nb-edit-pencil:hover { color: var(--accent); }
  .nb-edit-pencil:focus-visible { opacity: 1; transform: scale(1); outline: 1px solid var(--border-accent); }

  /* Right */
  .nb-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }

  /* Guest */
  .nb-guest { display: flex; align-items: center; gap: 9px; }
  .nb-guest-label {
    display: flex; align-items: center; gap: 4px;
    font-size: 0.64rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted); border: 1px solid var(--border);
    border-radius: 20px; padding: 3px 9px;
  }
  .nb-guest-label .ti { font-size: 10px; color: var(--muted); }
  .nb-login-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px;
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--accent); background: var(--accent-dim);
    border: 1px solid var(--border-accent); border-radius: var(--radius);
    transition: background 0.15s, border-color 0.15s;
  }
  .nb-login-btn:hover {
    background: rgba(56, 182, 255, 0.13);
    border-color: rgba(56, 182, 255, 0.3);
  }
  .nb-login-btn .ti { font-size: 13px; }

  /* User */
  .nb-user { position: relative; display: flex; align-items: center; gap: 4px; }

  /* Botón principal de panel */
  .nb-panel-btn {
    position: relative;
    display: flex; align-items: center; gap: 8px;
    padding: 5px 10px 5px 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius); cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    font-family: inherit;
  }
  .nb-panel-btn:hover {
    background: var(--surface-2);
    border-color: rgba(56, 182, 255, 0.2);
  }
  .nb-panel-btn:active { opacity: 0.85; }
  .nb-panel-btn-avatar {
    width: 22px; height: 22px; border-radius: 50%;
    object-fit: cover; border: 1px solid var(--border);
    flex-shrink: 0;
  }
  .nb-panel-btn .ti { font-size: 14px; color: var(--muted-2); flex-shrink: 0; }
  .nb-panel-btn-label {
    font-size: 0.74rem; font-weight: 600; letter-spacing: 0.03em;
    color: var(--text); white-space: nowrap;
    max-width: 80px; overflow: hidden; text-overflow: ellipsis;
  }
  .nb-panel-btn-chevron {
    font-size: 11px !important;
    color: var(--muted);
    transition: transform 0.2s;
  }
  .nb-panel-btn:hover .nb-panel-btn-chevron { transform: translateX(2px); }
  .nb-admin-dot {
    position: absolute; bottom: -1px; right: -1px;
    width: 7px; height: 7px; border-radius: 50%;
    background: #f59e0b; border: 1.5px solid var(--bg);
  }
  .nb-admin-dot--btn {
    position: absolute; top: 4px; left: 4px;
    width: 6px; height: 6px;
    border: 1.5px solid var(--bg);
  }

  /* Botón de opciones */
  .nb-user-btn--opts {
    display: flex; align-items: center; justify-content: center;
    width: 28px; height: 28px;
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius); cursor: pointer;
    color: var(--muted);
    transition: background 0.15s, color 0.15s;
    font-family: inherit;
  }
  .nb-user-btn--opts:hover {
    background: var(--surface);
    color: var(--muted-2);
  }
  .nb-user-btn--opts[aria-expanded="true"] {
    background: var(--surface);
    border-color: var(--border-accent);
    color: var(--accent);
  }
  .nb-user-btn--opts .ti { font-size: 14px; }

  /* Dropdown */
  .nb-dropdown {
    position: absolute; top: calc(100% + 8px); right: 0;
    min-width: 210px; z-index: 300;
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    overflow: hidden;
    opacity: 0; visibility: hidden; transform: translateY(-4px);
    transform-origin: top right;
    transition: opacity 0.15s, transform 0.15s, visibility 0.15s;
  }
  .nb-dropdown.open {
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .nb-dropdown-header { padding: 12px 14px 10px; }
  .nb-dropdown-email { display: block; font-size: 0.7rem; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .nb-dropdown-badge {
    display: inline-flex; align-items: center; margin-top: 4px;
    padding: 2px 8px; border-radius: 20px; font-size: 0.58rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25); color: #f59e0b;
  }
  .nb-dropdown-sep { height: 1px; background: var(--border); margin: 0; }
  .nb-dropdown-maintenance {
    display: flex; align-items: center; gap: 8px;
    margin: 2px 8px 8px; padding: 8px 10px;
    border-radius: var(--radius); font-size: 0.7rem; font-weight: 600;
    background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2); color: #f59e0b;
    text-decoration: none; transition: background 0.12s;
  }
  .nb-dropdown-maintenance:hover { background: rgba(245,158,11,0.14); }
  .nb-dropdown-maintenance .ti { font-size: 12px; flex-shrink: 0; }
  .nb-dropdown-item {
    display: flex; align-items: center; gap: 9px;
    width: 100%; padding: 9px 14px;
    font-size: 0.8rem; font-weight: 500; color: var(--text);
    background: none; border: none; cursor: pointer;
    font-family: inherit; text-align: left; text-decoration: none;
    transition: background 0.12s;
  }
  .nb-dropdown-item .ti { font-size: 13px; color: var(--muted); flex-shrink: 0; }
  .nb-dropdown-item:hover { background: rgba(255,255,255,0.04); }
  .nb-dropdown-item--danger:hover { background: rgba(248,113,113,0.07); color: #f87171; }
  .nb-dropdown-item--danger:hover .ti { color: #f87171; }
  .nb-panel-arrow { margin-left: auto; opacity: 0.3; font-size: 12px !important; }

  /* Toggle */
  .nb-toggle {
    display: none; flex-direction: column; gap: 5px;
    padding: 8px; background: none; border: none; cursor: pointer;
    width: 38px; height: 38px; align-items: center; justify-content: center;
  }
  .nb-toggle span {
    display: block; width: 18px; height: 1.5px;
    background: var(--muted); border-radius: 2px;
    transition: transform 0.22s ease, opacity 0.22s ease, background 0.15s;
  }
  .nb-toggle:hover span { background: var(--text); }
  .nb-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nb-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nb-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Mobile menu */
  .nb-mobile {
    display: flex;
    position: absolute; top: 60px; left: 0; right: 0;
    background: rgba(7,9,15,0.98); border-bottom: 1px solid var(--border);
    padding: 8px 16px 16px; flex-direction: column; gap: 4px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    pointer-events: none;
  }
  .nb-mobile.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }
  .nb-mobile-links { display: flex; flex-direction: column; gap: 2px; }
  .nb-mobile-link {
    display: flex; align-items: center; gap: 12px;
    padding: 11px 12px;
    font-size: 0.85rem; font-weight: 500; color: var(--muted);
    border-radius: var(--radius); transition: color 0.15s;
  }
  .nb-mobile-link:hover { color: var(--text); }
  .nb-mobile-link .ti { font-size: 16px; color: var(--muted); flex-shrink: 0; }
  .nb-mobile-foot {
    margin-top: 8px; padding-top: 12px;
    border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 6px;
  }
  .nb-mobile-account {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 12px; border-radius: var(--radius);
    background: var(--surface); border: 1px solid var(--border);
    transition: background 0.12s; cursor: pointer;
    width: 100%; text-align: left; font-family: inherit;
  }
  .nb-mobile-account:hover { background: var(--surface-2); }
  .nb-mobile-avatar {
    width: 34px; height: 34px; border-radius: 50%;
    background: var(--surface-2); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; overflow: hidden; color: var(--muted);
    font-size: 15px;
  }
  .nb-mobile-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .nb-mobile-name { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text); }
  .nb-mobile-role { display: block; font-size: 0.65rem; color: var(--muted); margin-top: 1px; }
  .nb-mobile-maintenance {
    display: flex; align-items: center; gap: 9px;
    padding: 10px 12px; border-radius: var(--radius);
    font-size: 0.76rem; font-weight: 600; color: #f59e0b;
    background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2);
    transition: background 0.12s;
  }
  .nb-mobile-maintenance:hover { background: rgba(245,158,11,0.14); }
  .nb-mobile-maintenance .ti { font-size: 14px; flex-shrink: 0; }
  .nb-mobile-edit {
    display: flex; align-items: center; gap: 9px;
    padding: 10px 12px; border-radius: var(--radius);
    font-size: 0.78rem; font-weight: 600; color: var(--accent);
    background: var(--accent-dim); border: 1px solid var(--border-accent);
    transition: background 0.12s;
  }
  .nb-mobile-edit:hover { background: rgba(56, 182, 255, 0.12); }
  .nb-mobile-edit .ti { font-size: 14px; flex-shrink: 0; }
  .nb-mobile-logout {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 11px; border-radius: var(--radius);
    font-size: 0.8rem; font-weight: 600; color: #f87171;
    background: rgba(248,113,113,0.05); border: 1px solid rgba(248,113,113,0.12);
    cursor: pointer; transition: background 0.12s;
  }
  .nb-mobile-logout:hover { background: rgba(248,113,113,0.1); }
  .nb-mobile-login {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 12px; border-radius: var(--radius);
    font-size: 0.85rem; font-weight: 700; color: var(--accent);
    background: var(--accent-dim); border: 1px solid var(--border-accent);
    transition: background 0.12s;
  }
  .nb-mobile-login:hover { background: rgba(56, 182, 255, 0.13); }

  /* Overlay */
  .nb-overlay {
    display: none; position: fixed; inset: 60px 0 0 0;
    z-index: 199; background: rgba(0,0,0,0.5);
  }
  .nb-overlay.open { display: block; }

  @media (max-width: 900px) {
    .nb-links { display: none; }
    .nb-toggle { display: flex; }
    .nb-guest-label { display: none; }
    .nb-panel-btn-label { display: none; }
    .nb-panel-btn-chevron { display: none; }
    .nb-panel-btn { padding: 5px 7px; gap: 0; }
  }
  @media (max-width: 480px) {
    .nb-user-btn--opts { display: none; }
  }
</style>

<script>
  // ─── Helpers ───────────────────────────────────────────────────────────────
  const nb        = document.getElementById('nb')!;
  const progress  = document.getElementById('nbProgress')!;
  const logo      = document.getElementById('nbLogo')!;
  const toggle    = document.getElementById('nbToggle')!;
  const menu      = document.getElementById('nbMenu')!;
  const overlay   = document.getElementById('nbOverlay')!;
  const userBtn   = document.getElementById('nbUserBtn') as HTMLButtonElement | null;
  const dropdown  = document.getElementById('nbUserMenu');
  const panelBtn  = document.getElementById('nbPanelBtn') as HTMLButtonElement | null;
  const links     = document.querySelectorAll<HTMLAnchorElement>('.nb-link');
  const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('.nb-mobile-link');
  const sections  = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));

  // ─── Scroll: progress bar + scrolled class ─────────────────────────────────
  // Un solo rAF por scroll; no importa cuán rápido sea el monitor.
  let scrollRaf: number | null = null;

  function onScrollFrame() {
    const y    = window.scrollY;
    const docH = document.documentElement.scrollHeight - window.innerHeight;

    nb.classList.toggle('scrolled', y > 24);
    progress.style.width = docH > 0 ? `${Math.min((y / docH) * 100, 100)}%` : '0%';

    scrollRaf = null;
  }

  window.addEventListener('scroll', () => {
    if (!scrollRaf) scrollRaf = requestAnimationFrame(onScrollFrame);
  }, { passive: true });

  onScrollFrame();

  // ─── Active link — IntersectionObserver (robusto, sin magia de offsets) ────
  // Observamos cuándo cada sección cruza el centro superior de la viewport.
  // rootMargin: "-60px 0px -50% 0px"
  //   → arriba: 60px (altura del navbar fijo)
  //   → abajo: -50% (solo activa cuando la sección ocupa al menos el 50% superior)
  // Esto evita el "salto" de sección activa que daba el polling con offsetTop.
  let activeSection: string | null = null;

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      // Procesamos todas las entradas y quedamos con la más alta en la página
      // que esté intersectando, para que cuando hay varias a la vez siempre
      // gane la que el usuario está leyendo (la más arriba).
      entries.forEach(entry => {
        if (entry.isIntersecting) activeSection = entry.target.id;
      });

      links.forEach(l => l.classList.toggle('active', l.dataset.section === activeSection));
    },
    { rootMargin: '-60px 0px -50% 0px', threshold: 0 }
  );

  sections.forEach(s => sectionObserver.observe(s));

  // ─── Logo → scroll suave al top ────────────────────────────────────────────
  logo.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    closeMenu();
  });

  // ─── Mobile menu ───────────────────────────────────────────────────────────
  // Usamos clases + transición CSS (ver estilos) en lugar de display:none/flex
  // para que la apertura/cierre tenga animación suave.
  function openMenu() {
    menu.classList.add('open');
    overlay.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden'; // evita scroll de fondo en móvil
  }
  function closeMenu() {
    menu.classList.remove('open');
    overlay.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () =>
    menu.classList.contains('open') ? closeMenu() : openMenu()
  );
  overlay.addEventListener('click', closeMenu);

  // Links del menú mobile → scroll suave + cierre del menú
  mobileLinks.forEach(link => {
    link.addEventListener('click', e => {
      const href = link.getAttribute('href') ?? '';
      if (href.startsWith('#')) {
        e.preventDefault();
        closeMenu();
        const target = document.getElementById(href.slice(1));
        if (target) {
          // Pequeño delay para que el menú cierre antes de hacer scroll
          setTimeout(() => {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 120);
        }
      } else {
        closeMenu();
      }
    });
  });

  // Links del nav desktop → scroll suave también
  links.forEach(link => {
    link.addEventListener('click', e => {
      const href = link.getAttribute('href') ?? '';
      if (href.startsWith('#')) {
        e.preventDefault();
        const target = document.getElementById(href.slice(1));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // ─── Dropdown usuario ──────────────────────────────────────────────────────
  // Problema original: el click en el botón propagaba al document, que
  // inmediatamente lo cerraba. Solución: usamos un flag para ignorar
  // el primer click en document después de abrir.
  let dropdownJustOpened = false;

  function openDropdown() {
    dropdown?.classList.add('open');
    userBtn?.setAttribute('aria-expanded', 'true');
    dropdown?.setAttribute('aria-hidden', 'false');
    dropdownJustOpened = true;
    // Limpiar flag después del frame actual
    requestAnimationFrame(() => { dropdownJustOpened = false; });
  }
  function closeDropdown() {
    dropdown?.classList.remove('open');
    userBtn?.setAttribute('aria-expanded', 'false');
    dropdown?.setAttribute('aria-hidden', 'true');
  }

  userBtn?.addEventListener('click', e => {
    e.stopPropagation();
    dropdown?.classList.contains('open') ? closeDropdown() : openDropdown();
  });

  document.addEventListener('click', e => {
    if (dropdownJustOpened) return;
    if (!dropdown?.classList.contains('open')) return;
    const outside = !userBtn?.contains(e.target as Node) && !dropdown?.contains(e.target as Node);
    if (outside) closeDropdown();
  });

  // Cerrar con Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeMenu(); closeDropdown(); }
  });

  // ─── Panel botón principal ─────────────────────────────────────────────────
  // Espera a que SlidePanel esté disponible (puede cargar después del navbar)
  function openPanel(url: string, title: string) {
    if (typeof (window as any).openSlidePanel === 'function') {
      (window as any).openSlidePanel(url, title);
    } else {
      // Fallback: navegar directo si el panel no cargó
      window.location.href = url;
    }
  }

  panelBtn?.addEventListener('click', () => {
    const url   = panelBtn.dataset.panelUrl   ?? '/usuario';
    const title = panelBtn.dataset.panelTitle ?? 'Panel';
    openPanel(url, title);
  });

  // Links del dropdown que abren el slide panel
  document.querySelectorAll<HTMLElement>('[data-panel-url]:not(#nbPanelBtn):not(#nbMobilePanelBtn)').forEach(el => {
    el.addEventListener('click', e => {
      e.preventDefault();
      const url   = el.dataset.panelUrl   ?? '/usuario';
      const title = el.dataset.panelTitle ?? 'Panel';
      closeDropdown();
      closeMenu();
      openPanel(url, title);
    });
  });

  // Botón mobile de panel
  const mobilePanelBtn = document.getElementById('nbMobilePanelBtn') as HTMLButtonElement | null;
  mobilePanelBtn?.addEventListener('click', () => {
    const url   = mobilePanelBtn.dataset.panelUrl   ?? '/usuario';
    const title = mobilePanelBtn.dataset.panelTitle ?? 'Panel';
    openPanel(url, title);
    closeMenu();
  });

  // Lápices de edición admin
  document.querySelectorAll<HTMLButtonElement>('.nb-edit-pencil[data-panel-url]').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      openPanel(btn.dataset.panelUrl ?? '/admin', btn.dataset.panelTitle ?? 'Panel Admin');
    });
  });

  // ─── Logout ────────────────────────────────────────────────────────────────
  async function doLogout() {
    await fetch('/api/signin', { method: 'DELETE' });
    window.location.reload();
  }
  document.getElementById('nbLogout')?.addEventListener('click', doLogout);
  document.getElementById('nbLogoutMobile')?.addEventListener('click', doLogout);
</script>