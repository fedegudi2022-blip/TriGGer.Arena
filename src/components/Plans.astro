---
import { query } from '../lib/db';
import { WHATSAPP_URL as DEFAULT_WHATSAPP_URL } from '../config';
import SectionBg from './SectionBg.astro';

const WHATSAPP_URL = Astro.locals.siteSettings?.whatsapp_url ?? DEFAULT_WHATSAPP_URL;

interface PlanFeature { ok: boolean; text: string }
interface PlanRow {
  id: string;
  tag: string;
  price: string;
  descripcion: string | null;
  featured: boolean | null;
  badge: string | null;
  cta: string | null;
  features: PlanFeature[] | null;
}

let plans: PlanRow[] = [];
try {
  const rows = await query<PlanRow>('SELECT * FROM plans ORDER BY sort_order ASC');
  plans = rows.map(p => ({ ...p, featured: !!p.featured }));
} catch {
  // Tabla todavía no creada / MySQL no configurado: la sección queda vacía
  // en vez de mostrar precios de ejemplo ("XXX") como página final.
  plans = [];
}
---

<section id="ventas" class="plans-section">

  <!-- Fondo decorativo: diagonal + glow accent arriba derecha -->
  <SectionBg variant="diagonal" glowPos="top-right" />

  <div class="container">

    <div class="s-label fade-in">
      <span class="s-label-line"></span>
      <span class="s-label-text">// Planes</span>
    </div>
    <h2 class="s-title fade-in">Opciones // Beneficios</h2>
    <p class="s-sub fade-in">Conseguí ventajas exclusivas y ayudanos a mantener los servidores.</p>

    {plans.length > 0 ? (
    <div class="plans-grid">
      {plans.map(p => (
        <div class={`plan-card fade-in${p.featured ? ' plan-featured' : ''}`}>

          <!-- Decoraciones internas -->

          <!-- Brackets tácticos (solo featured) -->
          {p.featured && <>
            <span class="pc pc-tl" aria-hidden="true"></span>
            <span class="pc pc-tr" aria-hidden="true"></span>
            <span class="pc pc-bl" aria-hidden="true"></span>
            <span class="pc pc-br" aria-hidden="true"></span>
          </>}

          <!-- Badge -->
          {p.badge && (
            <div class="plan-badge" aria-label={p.badge}>
              {p.badge}
            </div>
          )}

          <!-- Header: tag + precio -->
          <div class="plan-header">
            <div class="plan-tag-wrap">
              <span class="plan-tag">{p.tag}</span>
            </div>
            <div class="plan-price">
              <span class="price-cur">$</span>
              <span class="price-val">{p.price}</span>
              <span class="price-per">/mes</span>
            </div>
          </div>

          <p class="plan-desc">{p.descripcion}</p>

          <!-- Separador -->
          <div class="plan-divider" aria-hidden="true"></div>

          <!-- Features -->
          <ul class="plan-feats">
            {(p.features ?? []).map(f => (
              <li class={f.ok ? '' : 'feat-dim'}>
                {f.ok
                  ? (
                    <svg class="feat-icon feat-ok" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  ) : (
                    <svg class="feat-icon feat-no" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  )
                }
                {f.text}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={WHATSAPP_URL}
            class={`plan-cta${p.featured ? ' cta-primary' : ' cta-ghost'}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="cta-icon-wa" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span class="cta-text">{p.cta}</span>
            <svg class="cta-icon-arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>

          <!-- Método de pago -->
          <div class="plan-payment">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
              <line x1="1" y1="10" x2="23" y2="10"></line>
            </svg>
            Solo MercadoPago
          </div>

        </div>
      ))}
    </div>
    ) : (
      <div class="plans-empty fade-in">
        <i class="ti ti-diamond-off" aria-hidden="true"></i>
        <p>Todavía no hay planes publicados. Volvé pronto.</p>
      </div>
    )}

  </div>
</section>

<style>
  /* ── Sección ─────────────────────────────────────────────────── */
  .plans-section {
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .plans-section .container {
    position: relative;
    z-index: 1;
  }

  /* ── Grid ── */
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    align-items: start;
  }

  /* ── Cards ── */
  .plan-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: border-color 0.2s ease;
  }
  .plan-card:hover {
    border-color: rgba(56, 182, 255, 0.25);
  }

  .plan-card.plan-featured {
    border-color: rgba(56, 182, 255, 0.25);
    background: var(--surface-2);
  }
  .plan-card.plan-featured:hover {
    border-color: rgba(56, 182, 255, 0.45);
  }

  /* Badge */
  .plan-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--accent-dim);
    border: 1px solid var(--border-accent);
    margin-bottom: 18px;
    width: fit-content;
  }

  /* Header */
  .plan-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }
  .plan-tag-wrap { display: flex; align-items: center; }
  .plan-tag {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 2px;
    flex-shrink: 0;
  }
  .price-cur {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    font-weight: 500;
  }
  .price-val {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .plan-featured .price-val {
    color: var(--accent);
  }
  .price-per {
    font-size: 0.7rem;
    color: var(--muted);
    font-weight: 500;
    margin-left: 1px;
  }

  .plan-desc {
    font-size: 0.82rem;
    color: var(--muted-2);
    line-height: 1.65;
    margin-bottom: 18px;
  }

  /* Divider */
  .plan-divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 18px;
  }

  /* Features */
  .plan-feats {
    display: flex;
    flex-direction: column;
    gap: 9px;
    margin-bottom: 24px;
    flex: 1;
  }
  .plan-feats li {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.4;
  }
  .feat-icon {
    flex-shrink: 0;
    width: 13px;
    height: 13px;
  }
  .feat-ok { color: var(--green); }
  .feat-no { color: var(--muted); }
  .feat-dim { opacity: 0.45; }
  .feat-dim .feat-ok { color: var(--muted); }

  /* CTA */
  .plan-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 11px 20px;
    border-radius: var(--radius);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.15s ease;
    margin-bottom: 12px;
  }
  .cta-icon-wa { flex-shrink: 0; }
  .cta-icon-arrow { flex-shrink: 0; transition: transform 0.15s ease; }
  .plan-cta:hover .cta-icon-arrow { transform: translateX(3px); }
  .plan-cta:hover { opacity: 0.88; }

  .cta-primary {
    background: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
  }
  .cta-ghost {
    background: transparent;
    color: var(--muted-2);
    border: 1px solid var(--border);
  }
  .cta-ghost:hover {
    opacity: 1;
    border-color: rgba(56,182,255,0.25);
    color: var(--text);
  }

  /* Payment */
  .plan-payment {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    color: var(--muted);
    justify-content: center;
  }

  /* Empty state */
  .plans-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 48px 24px;
    border: 1px dashed var(--border);
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .plans-empty .ti {
    font-size: 28px;
    color: var(--muted);
  }
  .plans-empty p {
    font-size: 0.85rem;
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .plans-grid { grid-template-columns: 1fr; }
    .plan-card.plan-featured { transform: none; }
  }
</style>