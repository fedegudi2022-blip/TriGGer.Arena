---
import SectionBg from './SectionBg.astro';

const faqs = [
  {
    q: '¿Cómo me conecto a los servidores?',
    a: 'Abrí Counter-Strike 1.6, entrá a la consola con la tecla `~` y escribí el comando connect seguido de la IP del servidor. También podés copiarlo directo desde la sección Servidores acá en la web. Asegurate de tener el juego instalado y el anti-cheat activo.',
    icon: 'ti-plug-connected',
  },
  {
    q: '¿Qué beneficios tiene ser VIP?',
    a: 'Los VIPs tienen acceso a comandos exclusivos, skins, prioridad de slot cuando el servidor está lleno, y otras ventajas según el plan elegido. Podés ver todos los detalles en la sección de Planes.',
    icon: 'ti-diamond',
  },
  {
    q: '¿Tienen anti-cheat? ¿Cómo funciona?',
    a: 'Sí, usamos sistemas de detección automática de cheats junto con admins activos en el servidor. Cualquier jugador puede reportar cheaters a través del grupo de WhatsApp o en el formulario de contacto.',
    icon: 'ti-shield-check',
  },
  {
    q: '¿Puedo apelar un ban?',
    a: 'Sí. Si creés que tu ban fue injusto, podés ingresar a la sección de Quejas y completar el formulario de apelación. Un administrador revisará tu caso en un plazo de 48 a 72 horas hábiles.',
    icon: 'ti-gavel',
  },
  {
    q: '¿Cómo pago el VIP?',
    a: 'Actualmente aceptamos pagos exclusivamente por MercadoPago. Una vez elegido el plan, contactanos por WhatsApp y te guiamos en el proceso de pago. Una vez confirmado, el VIP se activa en menos de 24 horas.',
    icon: 'ti-credit-card',
  },
  {
    q: '¿Qué hago si tengo lag o no puedo conectarme?',
    a: 'Primero verificá tu conexión a internet y asegurate de que el servidor esté en línea (lo podés ver en tiempo real en la sección Servidores). Si el problema persiste, contactanos en el grupo de WhatsApp con tu IP y el mensaje de error que muestra el juego.',
    icon: 'ti-wifi-off',
  },
  {
    q: '¿Los servidores son 24/7?',
    a: 'Sí, los servidores funcionan las 24 horas, los 7 días de la semana. Ocasionalmente pueden tener breves cortes por mantenimiento o actualizaciones, que anunciamos con anticipación en nuestro Discord y WhatsApp.',
    icon: 'ti-clock-24',
  },
  {
    q: '¿Cómo me uno a la comunidad?',
    a: 'Podés seguirnos en nuestras redes sociales, unirte al grupo de WhatsApp y, por supuesto, conectarte a los servidores. La comunidad se construye jugando, así que ¡no dudes en entrar y presentarte!',
    icon: 'ti-users-group',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<section id="faq" class="faq-section">
  <SectionBg variant="dots" glowPos="bottom-left" glowColor="var(--accent)" />

  <div class="container">
    <div class="s-label fade-in">
      <span class="s-label-line"></span>
      <span class="s-label-text">// FAQ</span>
    </div>
    <h2 class="s-title fade-in">Preguntas frecuentes</h2>
    <p class="s-sub fade-in">Todo lo que necesitás saber antes de conectarte.</p>

    <div class="faq-grid fade-in" role="list">
      {faqs.map((f, i) => (
        <div class="faq-item" role="listitem">
          <button
            class="faq-trigger"
            aria-expanded="false"
            aria-controls={`faq-body-${i}`}
            id={`faq-trigger-${i}`}
          >
            <span class="faq-icon-wrap" aria-hidden="true">
              <i class={`ti ${f.icon}`}></i>
            </span>
            <span class="faq-q">{f.q}</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </span>
          </button>

          <!--
            El div.faq-body maneja la animación de altura.
            El borde superior sólo aparece cuando el item está abierto,
            evitando que sea visible durante el frame inicial (max-height:0).
          -->
          <div
            class="faq-body"
            id={`faq-body-${i}`}
            role="region"
            aria-labelledby={`faq-trigger-${i}`}
            aria-hidden="true"
          >
            <div class="faq-body-inner">
              <p>{f.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="faq-cta fade-in">
      <span class="faq-cta-text">¿No encontraste lo que buscabas?</span>
      <a href="#contacto" class="faq-cta-btn">
        <i class="ti ti-message-circle-2" aria-hidden="true"></i>
        Contactanos
        <i class="ti ti-arrow-right faq-arrow" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Sección ── */
  .faq-section {
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .faq-section .container {
    position: relative;
    z-index: 1;
  }

  /* ── Grid dos columnas en desktop ── */
  .faq-grid {
    display: grid;
    gap: 6px;
    margin-bottom: 36px;
  }
  @media (min-width: 768px) {
    .faq-grid {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
  }

  /* ── Item ── */
  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    /* overflow:hidden oculta el faq-body cuando max-height es 0
       y también recorta el border-radius correctamente */
    overflow: hidden;
    background: var(--surface);
    transition: border-color 0.2s ease;
  }
  .faq-item:has(.faq-trigger[aria-expanded="true"]) {
    border-color: var(--border-accent);
  }

  /* ── Trigger ── */
  .faq-trigger {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 14px 16px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    outline: none;
    transition: background 0.15s ease;
  }
  .faq-trigger:hover {
    background: var(--surface-2);
  }
  .faq-trigger[aria-expanded="true"] {
    background: var(--surface-2);
  }
  .faq-trigger:focus-visible {
    box-shadow: inset 0 0 0 2px rgba(56, 182, 255, 0.5);
    background: var(--surface-2);
  }

  /* ── Ícono ── */
  .faq-icon-wrap {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-dark);
    border: 1px solid var(--border-accent);
    color: var(--accent);
    font-size: 0.95rem;
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }
  .faq-trigger[aria-expanded="true"] .faq-icon-wrap {
    background: rgba(56, 182, 255, 0.12);
    box-shadow: 0 0 12px rgba(56, 182, 255, 0.15);
  }

  /* ── Pregunta ── */
  .faq-q {
    flex: 1;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
  }

  /* ── Chevron ── */
  .faq-chevron {
    flex-shrink: 0;
    color: var(--muted);
    display: flex;
    align-items: center;
    /*
      Sólo animamos transform y color — propiedades de composición.
      NO animamos height, max-height, padding ni border aquí
      para evitar reflows que causaban el bug de "se bugea".
    */
    transition: transform 0.25s ease, color 0.2s ease;
  }
  .faq-trigger[aria-expanded="true"] .faq-chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }

  /* ── Cuerpo del acordeón ──
     CORRECCIÓN CLAVE:
     - max-height parte en 0 (cerrado).
     - El borde superior se controla con un selector :has
       para que SÓLO aparezca cuando el item está abierto.
       Así no hay borde visible en el frame inicial.
     - Usamos will-change:max-height para que el browser
       no haga reflow en cada frame de la animación.
     - transition sólo en max-height para que el borde
       no tenga su propia animación que cause flash.
  ── */
  .faq-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: max-height;
    /* El borde empieza transparente */
    border-top: 1px solid transparent;
  }
  /* Borde visible sólo cuando está expandido */
  .faq-item:has([aria-expanded="true"]) .faq-body {
    border-top-color: var(--border);
  }

  .faq-body-inner {
    padding: 0 16px 16px 60px;
    background: rgba(56, 182, 255, 0.02);
  }
  .faq-body-inner p {
    font-size: 0.84rem;
    color: var(--muted-2);
    line-height: 1.75;
    margin: 12px 0 0;
  }

  /* ── CTA final ── */
  .faq-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    padding: 20px;
    border: 1px dashed rgba(56, 182, 255, 0.2);
    border-radius: var(--radius-lg);
    background: rgba(56, 182, 255, 0.02);
  }
  .faq-cta-text {
    font-size: 0.86rem;
    color: var(--muted-2);
  }
  .faq-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 18px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius);
    background: var(--accent-dark);
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .faq-cta-btn:hover {
    background: rgba(56, 182, 255, 0.12);
    border-color: var(--accent);
  }
  .faq-arrow {
    font-size: 13px;
    transition: transform 0.18s ease;
  }
  .faq-cta-btn:hover .faq-arrow {
    transform: translateX(3px);
  }

  /* ── Responsive ── */
  @media (max-width: 540px) {
    .faq-body-inner { padding-left: 16px; }
    .faq-trigger    { padding: 12px 14px; }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .faq-body    { transition: none; }
    .faq-chevron { transition: none; }
    .faq-item    { transition: none; }
    .faq-cta-btn { transition: none; }
    .faq-arrow   { transition: none; }
  }
</style>

<script>
  (function () {
    const triggers = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.faq-trigger')
    );

    /* ── Helpers ── */
    function getBody(trigger: HTMLButtonElement): HTMLElement | null {
      const id = trigger.getAttribute('aria-controls');
      return id ? document.getElementById(id) : null;
    }

    function openItem(trigger: HTMLButtonElement) {
      const body = getBody(trigger);
      if (!body) return;
      trigger.setAttribute('aria-expanded', 'true');
      body.setAttribute('aria-hidden', 'false');
      /*
        scrollHeight se lee DESPUÉS de que el contenido es visible
        (aria-hidden ya no oculta para AT, pero el elemento sigue
        en el DOM y tiene altura real). Sumamos 2px para absorber
        sub-pixel rounding sin over-clip.
      */
      body.style.maxHeight = body.scrollHeight + 2 + 'px';
    }

    function closeItem(trigger: HTMLButtonElement) {
      const body = getBody(trigger);
      if (!body) return;
      trigger.setAttribute('aria-expanded', 'false');
      body.setAttribute('aria-hidden', 'true');
      body.style.maxHeight = '0';
    }

    function toggleItem(trigger: HTMLButtonElement) {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      // Cerrar todos los demás primero
      triggers.forEach(t => { if (t !== trigger) closeItem(t); });
      isOpen ? closeItem(trigger) : openItem(trigger);
    }

    /* ── Event listeners ── */
    triggers.forEach((trigger, idx) => {
      trigger.addEventListener('click', () => toggleItem(trigger));

      // Navegación por teclado (ARIA Disclosure pattern)
      trigger.addEventListener('keydown', (e: KeyboardEvent) => {
        let next: HTMLButtonElement | undefined;
        if      (e.key === 'ArrowDown') { e.preventDefault(); next = triggers[idx + 1] ?? triggers[0]; }
        else if (e.key === 'ArrowUp')   { e.preventDefault(); next = triggers[idx - 1] ?? triggers[triggers.length - 1]; }
        else if (e.key === 'Home')      { e.preventDefault(); next = triggers[0]; }
        else if (e.key === 'End')       { e.preventDefault(); next = triggers[triggers.length - 1]; }
        next?.focus();
      });
    });

    /* ── Recalcular max-height en resize ──
       Evita que el contenido quede cortado si el usuario
       redimensiona la ventana con un item abierto.
    ── */
    let raf: number | null = null;
    window.addEventListener('resize', () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        triggers.forEach(trigger => {
          if (trigger.getAttribute('aria-expanded') === 'true') {
            const body = getBody(trigger);
            if (body) body.style.maxHeight = body.scrollHeight + 2 + 'px';
          }
        });
        raf = null;
      });
    }, { passive: true });

    /* ── Soporte de URL hash ──
       Permite links directos del tipo #faq-3
       que abren el item correspondiente con scroll suave.
    ── */
    function openFromHash() {
      const hash = window.location.hash;
      if (!hash.startsWith('#faq-')) return;
      const idx = parseInt(hash.replace('#faq-', ''), 10);
      const trigger = triggers[idx];
      if (!trigger) return;
      openItem(trigger);
      setTimeout(() => {
        const item = trigger.closest('.faq-item') as HTMLElement | null;
        if (!item) return;
        const top = item.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top, behavior: 'smooth' });
      }, 50);
    }

    openFromHash();
    window.addEventListener('hashchange', openFromHash);
  })();
</script>