---
import SectionBg from './SectionBg.astro';

const faqs = [
  {
    q: '¿Cómo me conecto a los servidores?',
    a: 'Abrí Counter-Strike 1.6, entrá a la consola con la tecla `~` y escribí el comando connect seguido de la IP del servidor. También podés copiarlo directo desde la sección Servidores acá en la web. Asegurate de tener el juego instalado y el anti-cheat activo.',
    icon: 'ti-plug-connected',
  },
  {
    q: '¿Qué beneficios tiene ser VIP?',
    a: 'Los VIPs tienen acceso a comandos exclusivos, skins, prioridad de slot cuando el servidor está lleno, y otras ventajas según el plan elegido. Podés ver todos los detalles en la sección de Planes.',
    icon: 'ti-diamond',
  },
  {
    q: '¿Tienen anti-cheat? ¿Cómo funciona?',
    a: 'Sí, usamos sistemas de detección automática de cheats junto con admins activos en el servidor. Cualquier jugador puede reportar cheaters a través del grupo de WhatsApp o en el formulario de contacto.',
    icon: 'ti-shield-check',
  },
  {
    q: '¿Puedo apelar un ban?',
    a: 'Sí. Si creés que tu ban fue injusto, podés ingresar a la sección de Quejas y completar el formulario de apelación. Un administrador revisará tu caso en un plazo de 48 a 72 horas hábiles.',
    icon: 'ti-gavel',
  },
  {
    q: '¿Cómo pago el VIP?',
    a: 'Actualmente aceptamos pagos exclusivamente por MercadoPago. Una vez elegido el plan, contactanos por WhatsApp y te guiamos en el proceso de pago. Una vez confirmado, el VIP se activa en menos de 24 horas.',
    icon: 'ti-credit-card',
  },
  {
    q: '¿Qué hago si tengo lag o no puedo conectarme?',
    a: 'Primero verificá tu conexión a internet y asegurate de que el servidor esté en línea (lo podés ver en tiempo real en la sección Servidores). Si el problema persiste, contactanos en el grupo de WhatsApp con tu IP y el mensaje de error que muestra el juego.',
    icon: 'ti-wifi-off',
  },
  {
    q: '¿Los servidores son 24/7?',
    a: 'Sí, los servidores funcionan las 24 horas, los 7 días de la semana. Ocasionalmente pueden tener breves cortes por mantenimiento o actualizaciones, que anunciamos con anticipación en nuestro Discord y WhatsApp.',
    icon: 'ti-clock-24',
  },
  {
    q: '¿Cómo me uno a la comunidad?',
    a: 'Podés seguirnos en nuestras redes sociales, unirte al grupo de WhatsApp y, por supuesto, conectarte a los servidores. La comunidad se construye jugando, así que ¡no dudes en entrar y presentarte!',
    icon: 'ti-users-group',
  },
];

// JSON-LD generado a partir del mismo array: si cambian las preguntas,
// el rich snippet de Google se actualiza solo.
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<section id="faq" class="faq-section">
  <SectionBg variant="dots" glowPos="bottom-left" glowColor="var(--accent)" />

  <div class="container">
    <div class="s-label fade-in">
      <span class="s-label-line"></span>
      <span class="s-label-text">// FAQ</span>
    </div>
    <h2 class="s-title fade-in">Preguntas frecuentes</h2>
    <p class="s-sub fade-in">Todo lo que necesitás saber antes de conectarte.</p>

    <div class="faq-grid fade-in" role="list">
      {faqs.map((f, i) => (
        <div class="faq-item" data-faq-index={i} role="listitem">
          <button
            class="faq-trigger"
            aria-expanded="false"
            aria-controls={`faq-body-${i}`}
            id={`faq-trigger-${i}`}
            data-faq={i}
          >
            <span class="faq-icon-wrap" aria-hidden="true">
              <i class={`ti ${f.icon}`}></i>
            </span>
            <span class="faq-q">{f.q}</span>
            <span class="faq-chevron" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </span>
          </button>

          {/*
            BUGFIX: border-top estaba en faq-body-inner, lo que hacía que
            el borde fuera visible en el primer frame (antes de que max-height
            animara desde 0). Ahora el borde está en faq-body y solo aparece
            cuando el item tiene aria-expanded=true.
          */}
          <div
            class="faq-body"
            id={`faq-body-${i}`}
            role="region"
            aria-labelledby={`faq-trigger-${i}`}
            aria-hidden="true"
          >
            <div class="faq-body-inner">
              <p>{f.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA al final -->
    <div class="faq-cta fade-in">
      <span class="faq-cta-text">¿No encontraste lo que buscabas?</span>
      <a href="#contacto" class="faq-cta-btn">
        <i class="ti ti-message-circle-2" aria-hidden="true"></i>
        Contactanos
        <i class="ti ti-arrow-right faq-arrow" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .faq-section .container { position: relative; z-index: 1; }

  /* ── Grid de dos columnas en desktop ── */
  .faq-grid {
    display: grid;
    gap: 6px;
    margin-bottom: 36px;
  }

  @media (min-width: 768px) {
    .faq-grid {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
  }

  /* ── Item ── */
  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface);
    transition: border-color 0.18s;
  }
  .faq-item:has(.faq-trigger[aria-expanded="true"]) {
    border-color: var(--border-accent);
  }

  /* ── Trigger ── */
  .faq-trigger {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 14px 16px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
    /* Focus visible para navegación por teclado */
    outline: none;
  }
  .faq-trigger:hover { background: var(--surface-2); }
  .faq-trigger[aria-expanded="true"] { background: var(--surface-2); }
  .faq-trigger:focus-visible {
    box-shadow: inset 0 0 0 2px rgba(56,182,255,0.5);
    background: var(--surface-2);
  }

  .faq-icon-wrap {
    flex-shrink: 0;
    width: 32px; height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-dark);
    border: 1px solid var(--border-accent);
    color: var(--accent);
    font-size: 0.95rem;
    transition: background 0.18s, box-shadow 0.18s;
  }
  .faq-trigger[aria-expanded="true"] .faq-icon-wrap {
    background: rgba(56,182,255,0.12);
    box-shadow: none;
  }

  .faq-q {
    flex: 1;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
  }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--muted);
    transition: transform 0.24s ease, color 0.18s;
    display: flex;
    align-items: center;
  }
  .faq-trigger[aria-expanded="true"] .faq-chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }

  /* ── Cuerpo acordeón ── */
  .faq-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    /*
      BUGFIX: el borde superior se movió aquí desde faq-body-inner
      para que no sea visible cuando max-height es 0. Se activa solo
      cuando el item está abierto via el selector de abajo.
    */
    border-top: 0px solid transparent;
    transition: max-height 0.3s ease, border-color 0.18s;
  }
  .faq-item:has([aria-expanded="true"]) .faq-body {
    border-top: 1px solid var(--border);
  }

  .faq-body-inner {
    padding: 0 16px 16px 60px;
    background: rgba(56,182,255,0.02);
  }
  .faq-body-inner p {
    font-size: 0.84rem;
    color: var(--muted-2);
    line-height: 1.75;
    margin: 12px 0 0;
  }

  /* ── CTA final ── */
  .faq-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    padding: 20px;
    border: 1px dashed rgba(56,182,255,0.2);
    border-radius: var(--radius-lg);
    background: rgba(56,182,255,0.02);
  }
  .faq-cta-text {
    font-size: 0.86rem;
    color: var(--muted-2);
  }
  .faq-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 18px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius);
    background: var(--accent-dark);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
    position: relative;
  }
  /* PERF: box-shadow en ::after con opacity — mismo patrón que Plans/Downloads */
  .faq-cta-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: none;
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
  }
  .faq-cta-btn:hover {
    background: rgba(56,182,255,0.12);
    border-color: var(--accent);
  }
  .faq-cta-btn:hover::after { opacity: 1; }

  .faq-arrow {
    transition: transform 0.18s;
    font-size: 13px;
  }
  .faq-cta-btn:hover .faq-arrow { transform: translateX(3px); }

  /* ── prefers-reduced-motion ── */
  @media (prefers-reduced-motion: reduce) {
    .faq-body       { transition: none; }
    .faq-chevron    { transition: none; }
    .faq-item       { transition: none; }
    .faq-cta-btn    { transition: none; }
    .faq-cta-btn::after { transition: none; }
    .faq-arrow      { transition: none; }
  }

  @media (max-width: 540px) {
    .faq-body-inner { padding-left: 16px; }
    .faq-trigger { padding: 12px 14px; }
  }
</style>

<script>
  const triggers = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.faq-trigger')
  );

  // ── Abrir / cerrar ──────────────────────────────────────────────────────
  function openItem(trigger: HTMLButtonElement) {
    const bodyId = trigger.getAttribute('aria-controls');
    const body   = bodyId ? document.getElementById(bodyId) : null;
    if (!body) return;

    trigger.setAttribute('aria-expanded', 'true');
    body.setAttribute('aria-hidden', 'false');
    // Usamos scrollHeight real en lugar de scrollHeight + 200 arbitrario.
    // Un pequeño padding extra (+ 2px) absorbe sub-pixel rounding sin over-clip.
    body.style.maxHeight = body.scrollHeight + 2 + 'px';
  }

  function closeItem(trigger: HTMLButtonElement) {
    const bodyId = trigger.getAttribute('aria-controls');
    const body   = bodyId ? document.getElementById(bodyId) : null;
    if (!body) return;

    trigger.setAttribute('aria-expanded', 'false');
    body.setAttribute('aria-hidden', 'true');
    body.style.maxHeight = '0';
  }

  function toggleItem(trigger: HTMLButtonElement) {
    const isOpen = trigger.getAttribute('aria-expanded') === 'true';

    // Cerrar todos primero
    triggers.forEach(t => { if (t !== trigger) closeItem(t); });

    // Toggle este
    if (isOpen) {
      closeItem(trigger);
    } else {
      openItem(trigger);
    }
  }

  // ── Navegación por teclado (ARIA Disclosure pattern) ───────────────────
  // ArrowDown/ArrowUp mueve el foco entre triggers.
  // Home/End van al primero/último.
  // Enter/Space ya funciona por defecto en <button>.
  triggers.forEach((trigger, idx) => {
    trigger.addEventListener('click', () => toggleItem(trigger));

    trigger.addEventListener('keydown', (e: KeyboardEvent) => {
      let next: HTMLButtonElement | undefined;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        next = triggers[idx + 1] ?? triggers[0];
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        next = triggers[idx - 1] ?? triggers[triggers.length - 1];
      } else if (e.key === 'Home') {
        e.preventDefault();
        next = triggers[0];
      } else if (e.key === 'End') {
        e.preventDefault();
        next = triggers[triggers.length - 1];
      }

      next?.focus();
    });
  });

  // ── Recalcular max-height en resize ────────────────────────────────────
  // Si el usuario cambia el tamaño de la ventana con un item abierto,
  // scrollHeight puede haber cambiado y el contenido queda cortado.
  let resizeRaf: number | null = null;
  window.addEventListener('resize', () => {
    if (resizeRaf) return;
    resizeRaf = requestAnimationFrame(() => {
      triggers.forEach(trigger => {
        if (trigger.getAttribute('aria-expanded') === 'true') {
          const bodyId = trigger.getAttribute('aria-controls');
          const body   = bodyId ? document.getElementById(bodyId) : null;
          if (body) body.style.maxHeight = body.scrollHeight + 2 + 'px';
        }
      });
      resizeRaf = null;
    });
  }, { passive: true });

  // ── Soporte de URL hash ─────────────────────────────────────────────────
  // Si la URL tiene ?faq=N o #faq con un hash específico, abre ese item.
  // Útil para links directos desde otras secciones o emails.
  function openFromHash() {
    const hash = window.location.hash; // ej: "#faq-3"
    if (!hash.startsWith('#faq-')) return;
    const idx = parseInt(hash.replace('#faq-', ''), 10);
    const trigger = triggers[idx];
    if (!trigger) return;
    openItem(trigger);
    // Scroll suave al item con offset de navbar
    setTimeout(() => {
      const item = trigger.closest('.faq-item') as HTMLElement | null;
      if (!item) return;
      const top = item.getBoundingClientRect().top + window.scrollY - 80;
      window.scrollTo({ top, behavior: 'smooth' });
    }, 50);
  }

  // Ejecutar al cargar y al cambiar el hash en la misma página
  openFromHash();
  window.addEventListener('hashchange', openFromHash);
</script>
