---
import SectionBg from './SectionBg.astro';

const faqs = [
  {
    q: '¿Cómo me conecto a los servidores?',
    a: 'Abrí Counter-Strike 1.6, entrá a la consola con la tecla `~` y escribí el comando connect seguido de la IP del servidor. También podés copiarlo directo desde la sección Servidores acá en la web. Asegurate de tener el juego instalado y el anti-cheat activo.',
    icon: 'ti-plug-connected',
    tag: 'CONEXIÓN',
  },
  {
    q: '¿Tienen anti-cheat? ¿Cómo funciona?',
    a: 'Sí, usamos sistemas de detección automática de cheats junto con admins activos en el servidor. Cualquier jugador puede reportar cheaters a través del grupo de WhatsApp o en el formulario de contacto.',
    icon: 'ti-shield-check',
    tag: 'SEGURIDAD',
  },
  {
    q: '¿Puedo apelar un ban?',
    a: 'Sí. Si creés que tu ban fue injusto, podés ingresar a la sección de Quejas y completar el formulario de apelación. Un administrador revisará tu caso en un plazo de 48 a 72 horas hábiles.',
    icon: 'ti-gavel',
    tag: 'BANS',
  },
  {
    q: '¿Qué hago si tengo lag o no puedo conectarme?',
    a: 'Primero verificá tu conexión a internet y asegurate de que el servidor esté en línea (lo podés ver en tiempo real en la sección Servidores). Si el problema persiste, contactanos en el grupo de WhatsApp con tu IP y el mensaje de error que muestra el juego.',
    icon: 'ti-wifi-off',
    tag: 'SOPORTE',
  },
  {
    q: '¿Los servidores son 24/7?',
    a: 'Sí, los servidores funcionan las 24 horas, los 7 días de la semana. Ocasionalmente pueden tener breves cortes por mantenimiento o actualizaciones, que anunciamos con anticipación en nuestro Discord y WhatsApp.',
    icon: 'ti-clock-24',
    tag: 'SERVIDORES',
  },
  {
    q: '¿Cómo me uno a la comunidad?',
    a: 'Podés seguirnos en nuestras redes sociales, unirte al grupo de WhatsApp y, por supuesto, conectarte a los servidores. La comunidad se construye jugando, así que ¡no dudes en entrar y presentarte!',
    icon: 'ti-users-group',
    tag: 'COMUNIDAD',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<section id="faq" class="faq-section">
  <SectionBg variant="dots" glowPos="bottom-left" glowColor="var(--accent)" />

  <div class="container">
    <div class="s-label fade-in">
      <span class="s-label-line"></span>
      <span class="s-label-text">// FAQ</span>
    </div>
    <h2 class="s-title fade-in">Preguntas frecuentes</h2>
    <p class="s-sub fade-in">Todo lo que necesitás saber antes de conectarte.</p>

    <!-- Panel principal de dos columnas -->
    <div class="faq-panel fade-in" role="region" aria-label="Preguntas frecuentes">

      <!-- Columna izquierda: lista de preguntas -->
      <div class="faq-list" role="list">
        {faqs.map((f, i) => (
          <button
            class={`faq-row${i === 0 ? ' faq-row--active' : ''}`}
            data-index={i}
            role="listitem"
            aria-selected={i === 0 ? 'true' : 'false'}
            id={`faq-row-${i}`}
            aria-controls="faqAnswer"
          >
            <span class="faq-row-indicator" aria-hidden="true"></span>
            <span class="faq-row-icon" aria-hidden="true">
              <i class={`ti ${f.icon}`}></i>
            </span>
            <span class="faq-row-content">
              <span class="faq-row-tag">{f.tag}</span>
              <span class="faq-row-q">{f.q}</span>
            </span>
            <span class="faq-row-arrow" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </span>
          </button>
        ))}
      </div>

      <!-- Columna derecha: respuesta activa -->
      <div class="faq-answer-panel" id="faqAnswer" role="region" aria-live="polite">
        <!-- Header del panel -->
        <div class="faq-answer-header">
          <div class="faq-answer-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <span class="faq-answer-title" id="faqAnswerTitle">
            {faqs[0].tag}
          </span>
          <div class="faq-answer-corner" aria-hidden="true"></div>
        </div>

        <!-- Cuerpo con contenido dinámico -->
        <div class="faq-answer-body" id="faqAnswerBody">
          {faqs.map((f, i) => (
            <div
              class={`faq-answer-item${i === 0 ? ' faq-answer-item--active' : ''}`}
              data-index={i}
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              <div class="faq-answer-icon-wrap" aria-hidden="true">
                <i class={`ti ${f.icon}`}></i>
              </div>
              <h3 class="faq-answer-q">{f.q}</h3>
              <p class="faq-answer-text">{f.a}</p>
              <div class="faq-answer-footer" aria-hidden="true">
                <span class="faq-answer-index">
                  {String(i + 1).padStart(2, '0')} / {String(faqs.length).padStart(2, '0')}
                </span>
                <span class="faq-answer-tag-badge">{f.tag}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- CTA -->
    <div class="faq-cta fade-in">
      <span class="faq-cta-text">¿No encontraste lo que buscabas?</span>
      <a href="#contacto" class="faq-cta-btn">
        <i class="ti ti-message-circle-2" aria-hidden="true"></i>
        Contactanos
        <i class="ti ti-arrow-right faq-arrow" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Sección ── */
  .faq-section {
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .faq-section .container {
    position: relative;
    z-index: 1;
  }

  /* ════════════════════════════════════════
     PANEL PRINCIPAL
  ════════════════════════════════════════ */
  .faq-panel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--surface);
    margin-bottom: 36px;
    /* Sutil línea accent en el tope */
    box-shadow:
      0 0 0 1px rgba(56, 189, 248, 0.04),
      0 24px 48px rgba(0, 0, 0, 0.35);
  }

  /* ════════════════════════════════════════
     LISTA (columna izq)
  ════════════════════════════════════════ */
  .faq-list {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--border);
    /* Scroll si hay muchos items */
    max-height: 480px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .faq-list::-webkit-scrollbar { width: 4px; }
  .faq-list::-webkit-scrollbar-track { background: transparent; }
  .faq-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* ── Fila ── */
  .faq-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: none;
    border: none;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    position: relative;
    transition: background 0.15s ease;
    outline: none;
  }
  .faq-row:last-child { border-bottom: none; }
  .faq-row:hover { background: var(--surface-2); }
  .faq-row:focus-visible {
    box-shadow: inset 0 0 0 2px rgba(56, 189, 248, 0.4);
  }

  /* Indicador lateral izquierdo (línea accent) */
  .faq-row-indicator {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: var(--accent);
    border-radius: 0 2px 2px 0;
    opacity: 0;
    transform: scaleY(0);
    transition: opacity 0.18s ease, transform 0.18s ease;
    transform-origin: center;
  }
  .faq-row--active .faq-row-indicator,
  .faq-row:hover .faq-row-indicator {
    opacity: 1;
    transform: scaleY(1);
  }
  .faq-row--active { background: var(--surface-2); }

  /* Ícono */
  .faq-row-icon {
    flex-shrink: 0;
    width: 30px; height: 30px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(56, 189, 248, 0.06);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.85rem;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .faq-row--active .faq-row-icon {
    background: rgba(56, 189, 248, 0.1);
    border-color: var(--border-accent);
    color: var(--accent);
  }

  /* Contenido texto */
  .faq-row-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .faq-row-tag {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--accent);
    opacity: 0.6;
    transition: opacity 0.15s;
  }
  .faq-row--active .faq-row-tag { opacity: 1; }

  .faq-row-q {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--muted);
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }
  .faq-row--active .faq-row-q,
  .faq-row:hover .faq-row-q { color: var(--text); }

  /* Flecha */
  .faq-row-arrow {
    flex-shrink: 0;
    color: var(--border);
    display: flex;
    align-items: center;
    transition: color 0.15s, transform 0.15s;
  }
  .faq-row--active .faq-row-arrow {
    color: var(--accent);
    transform: translateX(2px);
  }

  /* ════════════════════════════════════════
     PANEL DE RESPUESTA (columna der)
  ════════════════════════════════════════ */
  .faq-answer-panel {
    display: flex;
    flex-direction: column;
    background: var(--surface-2);
    min-height: 480px;
  }

  /* Header estilo "terminal/ventana" */
  .faq-answer-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--surface-3);
    flex-shrink: 0;
  }
  .faq-answer-dots {
    display: flex;
    gap: 5px;
  }
  .faq-answer-dots span {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--border);
  }
  .faq-answer-dots span:first-child  { background: #ef4444; opacity: 0.5; }
  .faq-answer-dots span:nth-child(2) { background: #f59e0b; opacity: 0.5; }
  .faq-answer-dots span:last-child   { background: #4ade80; opacity: 0.5; }

  .faq-answer-title {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--accent);
    flex: 1;
  }
  /* Esquina decorativa tipo crosshair */
  .faq-answer-corner {
    width: 12px; height: 12px;
    border-top: 1.5px solid var(--accent);
    border-right: 1.5px solid var(--accent);
    opacity: 0.4;
    border-radius: 0 2px 0 0;
  }

  /* Body */
  .faq-answer-body {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  /* Item de respuesta (posicionado absoluto para cross-fade) */
  .faq-answer-item {
    position: absolute;
    inset: 0;
    padding: 28px 28px 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  .faq-answer-item--active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* Ícono grande en el panel de respuesta */
  .faq-answer-icon-wrap {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(56, 189, 248, 0.08);
    border: 1px solid var(--border-accent);
    color: var(--accent);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .faq-answer-q {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .faq-answer-text {
    font-size: 0.86rem;
    color: var(--muted-2);
    line-height: 1.8;
    margin: 0;
    flex: 1;
  }

  /* Footer con número de ítem y tag */
  .faq-answer-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .faq-answer-index {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }
  .faq-answer-tag-badge {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--accent);
    background: rgba(56, 189, 248, 0.08);
    border: 1px solid var(--border-accent);
    border-radius: 3px;
    padding: 2px 7px;
  }

  /* ════════════════════════════════════════
     CTA
  ════════════════════════════════════════ */
  .faq-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    padding: 20px;
    border: 1px dashed rgba(56, 189, 248, 0.2);
    border-radius: var(--radius-lg);
    background: rgba(56, 189, 248, 0.02);
  }
  .faq-cta-text {
    font-size: 0.86rem;
    color: var(--muted-2);
  }
  .faq-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 18px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius);
    background: rgba(56, 189, 248, 0.07);
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .faq-cta-btn:hover {
    background: rgba(56, 189, 248, 0.12);
    border-color: var(--accent);
  }
  .faq-arrow {
    font-size: 13px;
    transition: transform 0.18s ease;
  }
  .faq-cta-btn:hover .faq-arrow { transform: translateX(3px); }

  /* ════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════ */
  @media (max-width: 768px) {
    .faq-panel {
      grid-template-columns: 1fr;
    }
    .faq-list {
      border-right: none;
      border-bottom: 1px solid var(--border);
      max-height: 260px;
    }
    .faq-answer-panel {
      min-height: 300px;
    }
    .faq-answer-item {
      padding: 20px 18px 16px;
    }
    .faq-row-q {
      white-space: normal;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .faq-answer-q { font-size: 0.95rem; }
    .faq-answer-text { font-size: 0.82rem; }
  }

  /* ════════════════════════════════════════
     REDUCED MOTION
  ════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .faq-answer-item { transition: none; }
    .faq-row         { transition: none; }
    .faq-row-indicator { transition: none; }
    .faq-cta-btn     { transition: none; }
    .faq-arrow       { transition: none; }
  }
</style>

<script>
  let faqAbort: AbortController | null = null;

  function initFaq() {
    faqAbort?.abort();
    faqAbort = new AbortController();
    const { signal } = faqAbort;

    const rows    = Array.from(document.querySelectorAll<HTMLButtonElement>('.faq-row'));
    const items   = Array.from(document.querySelectorAll<HTMLElement>('.faq-answer-item'));
    const titleEl = document.getElementById('faqAnswerTitle');

    if (rows.length === 0) return;

    // Tags para el header del panel
    const tags = rows.map(r => {
      const tagEl = r.querySelector('.faq-row-tag');
      return tagEl?.textContent?.trim() ?? '';
    });

    function activate(idx: number) {
      rows.forEach((r, i) => {
        const active = i === idx;
        r.classList.toggle('faq-row--active', active);
        r.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      items.forEach((item, i) => {
        const active = i === idx;
        item.classList.toggle('faq-answer-item--active', active);
        item.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      if (titleEl) titleEl.textContent = tags[idx];
    }

    rows.forEach((row, idx) => {
      row.addEventListener('click', () => activate(idx), { signal });

      row.addEventListener('keydown', (e: KeyboardEvent) => {
        let next: HTMLButtonElement | undefined;
        if      (e.key === 'ArrowDown') { e.preventDefault(); next = rows[idx + 1] ?? rows[0]; }
        else if (e.key === 'ArrowUp')   { e.preventDefault(); next = rows[idx - 1] ?? rows[rows.length - 1]; }
        else if (e.key === 'Home')      { e.preventDefault(); next = rows[0]; }
        else if (e.key === 'End')       { e.preventDefault(); next = rows[rows.length - 1]; }
        if (next) { next.focus(); activate(rows.indexOf(next)); }
      }, { signal });
    });

    // URL hash: #faq-N abre el item N
    function openFromHash() {
      const hash = window.location.hash;
      if (!hash.startsWith('#faq-')) return;
      const idx = parseInt(hash.replace('#faq-', ''), 10);
      if (rows[idx]) activate(idx);
    }
    openFromHash();
    window.addEventListener('hashchange', openFromHash, { signal });
  }

  initFaq();
  document.addEventListener('astro:page-load', initFaq);
</script>