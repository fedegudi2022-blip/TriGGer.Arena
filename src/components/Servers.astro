---
import SectionBg from './SectionBg.astro';
import { DEFAULT_SERVERS, serverIp, type ServerRow } from '../lib/site-data';

const serverRows: ServerRow[] = Astro.locals.servers ?? DEFAULT_SERVERS;

const servers = serverRows
  .filter(s => s.active !== false)
  .map(s => {
    const match = s.name.match(/^(#\d+)\s*(.*)$/);
    return {
      id:    s.id,
      mode:  s.mode ?? '',
      ip:    serverIp(s),
      desc:  s.description ?? '',
      num:   match ? match[1] : '',
      label: match ? match[2] : s.name,
    };
  });
---

<section id="servidores" class="servers-section">
  <SectionBg variant="crosshair" glowPos="top-right" glowColor="#4ade80" />

  <div class="container">

    <div class="s-label fade-in">
      <span class="s-label-line"></span>
      <span class="s-label-text">// Servidores</span>
    </div>
    <h2 class="s-title fade-in">Elegí el servidor que quieras.</h2>
    <p class="s-sub fade-in">Copiá el comando y pegalo directo en la consola de Counter-Strike 1.6.</p>

    <!-- Barra de error de red -->
    <div class="net-status" id="netStatus" aria-live="polite" hidden>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 6s4-4 11-4 11 4 11 4"/><path d="M1 12s4-4 11-4 11 4 11 4"/>
        <line x1="1" y1="18" x2="5" y2="18"/><line x1="19" y1="18" x2="23" y2="18"/>
        <line x1="12" y1="18" x2="12.01" y2="18"/>
      </svg>
      <span id="netStatusText">Sin conexión — los datos pueden estar desactualizados</span>
      <button class="net-retry" id="netRetry" aria-label="Reintentar">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>
        </svg>
        Reintentar
      </button>
    </div>

    <div class="servers-grid">
      {servers.map((s, idx) => (
        <div
          class="server-card fade-in-scale"
          style={`transition-delay:${idx * 80}ms`}
          data-server-id={s.id}
        >
          <!-- Spinner de refresco -->
          <span class="refresh-indicator" data-refresh={s.id} aria-label="Actualizando..." aria-hidden="true"></span>

          <!-- Cabecera: estado + modo -->
          <div class="card-header">
            <span class="badge-status badge-loading" data-status={s.id}>
              <span class="badge-dot"></span>
              <span class="badge-label">Consultando</span>
            </span>
            {s.mode && <span class="server-mode">{s.mode}</span>}
          </div>

          <!-- Identidad del servidor -->
          <div class="server-identity">
            <h3 class="server-name">
              {s.num && <span class="server-num">{s.num}</span>}
              <span class="server-label">{s.label}</span>
            </h3>
            {s.desc && <p class="server-desc">{s.desc}</p>}
          </div>

          <!-- Stats: mapa y jugadores -->
          <div class="server-stats" aria-live="polite">

            <div class="stat-block">
              <span class="stat-label">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                </svg>
                Mapa
              </span>
              <span class="stat-value skeleton-text map-skeleton" data-map={s.id}></span>
            </div>

            <div class="stat-divider" aria-hidden="true"></div>

            <div class="stat-block">
              <span class="stat-label">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                </svg>
                Jugadores
              </span>
              <div class="stat-players">
                <div class="capacity-bar">
                  <div class="capacity-fill" data-fill={s.id}></div>
                </div>
                <span class="stat-value skeleton-text players-skeleton" data-players={s.id}></span>
              </div>
            </div>

            <div class="stat-divider" aria-hidden="true"></div>

            <div class="stat-block stat-block--updated">
              <span class="stat-label">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                Actualizado
              </span>
              <span class="stat-value stat-updated skeleton-text updated-skeleton" data-updated-text={s.id}></span>
              <span class="stale-badge" data-stale={s.id} hidden>caché</span>
            </div>

          </div>

          <!-- Acordeón de jugadores -->
          <div class="players-section" data-players-section={s.id} style="display:none">
            <button
              class="players-toggle"
              data-toggle={s.id}
              aria-expanded="false"
              aria-controls={`players-list-${s.id}`}
            >
              <span class="toggle-inner">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <span class="toggle-label">Ver jugadores</span>
              </span>
              <svg class="toggle-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>

            <div
              class="players-list"
              id={`players-list-${s.id}`}
              data-players-list={s.id}
              aria-hidden="true"
            >
              <div class="players-inner" data-players-inner={s.id}></div>
            </div>
          </div>

          <!-- Consola con IP -->
          <div class="console-row">
            <span class="console-prompt" aria-hidden="true">&gt;_</span>
            <code class="console-cmd">connect {s.ip}</code>
            <button
              class="copy-btn"
              data-ip={s.ip}
              aria-label={`Copiar IP de ${s.label}`}
            >
              <svg class="icon-copy" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <svg class="icon-check" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span class="copy-label">Copiar</span>
            </button>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ══════════════════════════════════
     SECCIÓN
  ══════════════════════════════════ */
  .servers-section {
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .servers-section .container {
    position: relative;
    z-index: 1;
  }

  /* ══════════════════════════════════
     GRID
  ══════════════════════════════════ */
  .servers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 16px;
  }
  @media (max-width: 640px) {
    .servers-grid { grid-template-columns: 1fr; }
  }

  /* ══════════════════════════════════
     NET STATUS BAR
  ══════════════════════════════════ */
  .net-status {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 20px;
    padding: 10px 14px;
    border-radius: var(--radius);
    background: rgba(239, 68, 68, 0.05);
    border: 1px solid rgba(239, 68, 68, 0.15);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #f87171;
  }
  .net-status[hidden] { display: none; }
  .net-retry {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-left: auto;
    padding: 3px 9px;
    border-radius: var(--radius);
    font-size: 0.68rem;
    font-weight: 600;
    font-family: inherit;
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.18);
    background: none;
    cursor: pointer;
    transition: background 0.12s;
  }
  .net-retry:hover { background: rgba(239, 68, 68, 0.08); }

  /* ══════════════════════════════════
     CARD
  ══════════════════════════════════ */
  .server-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.22s ease, box-shadow 0.22s ease;
  }
  /* Línea accent superior que se ilumina al hover */
  .server-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(74, 222, 128, 0) 20%,
      rgba(74, 222, 128, 0.5) 50%,
      rgba(74, 222, 128, 0) 80%,
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .server-card:hover {
    border-color: rgba(74, 222, 128, 0.2);
    box-shadow: 0 0 0 1px rgba(74, 222, 128, 0.04),
                0 8px 32px rgba(0, 0, 0, 0.2);
  }
  .server-card:hover::before { opacity: 1; }

  /* Spinner de refresco */
  .refresh-indicator {
    display: none;
    position: absolute;
    top: 16px; right: 16px;
    width: 6px; height: 6px;
    border-radius: 50%;
    border: 1.5px solid rgba(74, 222, 128, 0.5);
    border-top-color: transparent;
    animation: spin 0.7s linear infinite;
  }
  .refresh-indicator.active { display: block; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Header ── */
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  /* Badges */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 8px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .badge-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Loading */
  .badge-status.badge-loading {
    color: var(--muted);
    background: var(--surface-2);
    border: 1px solid var(--border);
  }
  .badge-loading .badge-dot {
    background: var(--muted);
    animation: blink 1.6s ease-in-out infinite;
  }

  /* Online */
  .badge-status.badge-online {
    color: #4ade80;
    background: rgba(74, 222, 128, 0.07);
    border: 1px solid rgba(74, 222, 128, 0.18);
  }
  .badge-online .badge-dot {
    background: #4ade80;
    box-shadow: 0 0 4px rgba(74, 222, 128, 0.6);
    animation: pulse-green 2s ease-in-out infinite;
  }

  /* Offline */
  .badge-status.badge-offline {
    color: #f87171;
    background: rgba(248, 113, 113, 0.06);
    border: 1px solid rgba(248, 113, 113, 0.14);
  }
  .badge-offline .badge-dot { background: #f87171; }

  /* Cached */
  .badge-status.badge-cached {
    color: #fbbf24;
    background: rgba(251, 191, 36, 0.06);
    border: 1px solid rgba(251, 191, 36, 0.14);
  }
  .badge-cached .badge-dot { background: #fbbf24; }

  /* Modo de juego */
  .server-mode {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 2px 7px;
    border-radius: 3px;
    background: var(--surface-2);
    border: 1px solid var(--border);
  }

  /* ── Identidad ── */
  .server-identity {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .server-name {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text);
    letter-spacing: 0.01em;
  }
  .server-num {
    color: #4ade80;
    font-size: 0.85em;
    font-weight: 700;
  }
  .server-desc {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.55;
  }

  /* ══════════════════════════════════
     STATS PANEL
  ══════════════════════════════════ */
  .server-stats {
    display: flex;
    align-items: stretch;
    gap: 0;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .stat-divider {
    width: 1px;
    background: var(--border);
    flex-shrink: 0;
    align-self: stretch;
  }

  .stat-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 11px 13px;
    min-width: 0;
  }
  /* El bloque de "actualizado" es más pequeño */
  .stat-block--updated {
    flex: 0 0 auto;
    min-width: 90px;
  }

  .stat-label {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }
  .stat-label svg { flex-shrink: 0; opacity: 0.6; }

  .stat-value {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .stat-updated {
    font-size: 0.74rem;
    font-weight: 400;
    color: var(--muted-2);
  }

  .stale-badge {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fbbf24;
    background: rgba(251, 191, 36, 0.08);
    border: 1px solid rgba(251, 191, 36, 0.15);
    border-radius: 3px;
    padding: 1px 5px;
    width: fit-content;
  }
  .stale-badge[hidden] { display: none; }

  /* Barra de capacidad */
  .stat-players {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .capacity-bar {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    min-width: 32px;
    max-width: 48px;
  }
  .capacity-fill {
    height: 100%;
    width: 0%;
    background: #4ade80;
    border-radius: 2px;
    transition: width 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .capacity-fill.full { background: #f87171; }

  /* ── Skeleton ── */
  .skeleton-text {
    display: inline-block;
    border-radius: 3px;
    background: var(--border);
    color: transparent !important;
    user-select: none;
    animation: shimmer 1.5s ease-in-out infinite;
  }
  /* Anchos fijos para los skeletons (no colapsan a 0) */
  .map-skeleton { min-width: 80px; height: 0.82rem; }
  .players-skeleton { min-width: 36px; height: 0.82rem; }
  .updated-skeleton { min-width: 44px; height: 0.74rem; }

  @keyframes shimmer {
    0%   { opacity: 0.35; }
    50%  { opacity: 0.6; }
    100% { opacity: 0.35; }
  }

  /* ══════════════════════════════════
     ACORDEÓN JUGADORES
  ══════════════════════════════════ */
  .players-section {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .players-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 9px 12px;
    background: var(--surface-2);
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s ease;
    outline: none;
  }
  .players-toggle:hover { background: var(--surface-3, var(--surface-2)); }
  .players-toggle:focus-visible {
    box-shadow: inset 0 0 0 2px rgba(74, 222, 128, 0.3);
  }

  .toggle-inner {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--muted-2);
    font-size: 0.72rem;
    font-weight: 500;
  }
  .toggle-inner svg { opacity: 0.6; }

  .toggle-chevron {
    color: var(--muted);
    flex-shrink: 0;
    transition: transform 0.22s ease;
  }
  .players-toggle[aria-expanded="true"] .toggle-chevron { transform: rotate(180deg); }

  .players-list {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-top: 1px solid transparent;
  }
  .players-section:has([aria-expanded="true"]) .players-list {
    border-top-color: var(--border);
  }
  .players-list[aria-hidden="false"] { max-height: 240px; }

  .players-inner {
    display: flex;
    flex-direction: column;
    padding: 6px 0;
    overflow-y: auto;
    max-height: 238px;
  }

  /* ══════════════════════════════════
     CONSOLA
  ══════════════════════════════════ */
  .console-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    background: color-mix(in srgb, var(--bg, #0a0c10) 60%, var(--surface));
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-top: auto;
    /* Micro-detalle: borde izquierdo accent */
    border-left: 2px solid rgba(74, 222, 128, 0.25);
    transition: border-left-color 0.2s ease;
  }
  .server-card:hover .console-row {
    border-left-color: rgba(74, 222, 128, 0.5);
  }

  .console-prompt {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #4ade80;
    opacity: 0.7;
    flex-shrink: 0;
    letter-spacing: -0.04em;
  }
  .console-cmd {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted-2);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    user-select: all;
  }

  /* Botón copiar */
  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    font-size: 0.68rem;
    font-weight: 600;
    font-family: inherit;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: none;
    cursor: pointer;
    flex-shrink: 0;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .copy-btn:hover {
    color: var(--text);
    border-color: rgba(74, 222, 128, 0.25);
    background: rgba(74, 222, 128, 0.04);
  }
  .copy-btn.copied {
    color: #4ade80;
    border-color: rgba(74, 222, 128, 0.25);
    background: rgba(74, 222, 128, 0.06);
  }

  .icon-check { display: none; }
  .copy-btn.copied .icon-copy  { display: none; }
  .copy-btn.copied .icon-check { display: block; }
  .copy-label { font-size: 0.67rem; }

  /* ══════════════════════════════════
     ANIMACIONES
  ══════════════════════════════════ */
  @keyframes blink {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 1; }
  }
  @keyframes pulse-green {
    0%, 100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.5); }
    50%       { box-shadow: 0 0 0 3px rgba(74, 222, 128, 0); }
  }

  /* ══════════════════════════════════
     ACCESIBILIDAD
  ══════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .badge-dot,
    .skeleton-text,
    .refresh-indicator { animation: none; }
    .players-list,
    .capacity-fill,
    .server-card,
    .copy-btn,
    .players-toggle,
    .toggle-chevron { transition: none; }
  }
</style>

<script>
  const REFRESH_INTERVAL   = 30_000;
  const RELATIVE_TIME_TICK = 5_000;
  const FETCH_TIMEOUT_MS   = 10_000;
  const MAX_RETRIES        = 3;

  interface ServerStatus {
    id: number;
    online: boolean;
    map?: string;
    players?: number;
    maxPlayers?: number;
    updatedAt?: number;
    stale?: boolean;
    playerList?: string[];
  }

  const lastUpdated = new Map<number, number>();
  let fetchFailCount = 0;
  let refreshTimer: ReturnType<typeof setInterval> | null = null;
  let relativeTimer: ReturnType<typeof setInterval> | null = null;

  function createPlayerTag(name: string): HTMLElement {
    const row = document.createElement('div');
    row.className = 'player-row';
    const dot = document.createElement('span');
    dot.className = 'player-dot';
    dot.setAttribute('aria-hidden', 'true');
    const label = document.createElement('span');
    label.className = 'player-name';
    label.textContent = name;
    row.appendChild(dot);
    row.appendChild(label);
    return row;
  }

  function formatRelativeTime(ms: number): string {
    const diff    = Math.max(0, Date.now() - ms);
    const seconds = Math.round(diff / 1000);
    if (seconds < 5)  return 'Recién';
    if (seconds < 60) return `${seconds}s`;
    const minutes = Math.round(seconds / 60);
    if (minutes < 60) return `${minutes} min`;
    return `${Math.round(minutes / 60)} h`;
  }

  function renderRelativeTimes() {
    lastUpdated.forEach((ts, id) => {
      const el = document.querySelector<HTMLElement>(`[data-updated-text="${id}"]`);
      if (el) {
        el.textContent = formatRelativeTime(ts);
        el.classList.remove('skeleton-text', 'updated-skeleton');
      }
    });
  }

  function setNetStatus(show: boolean, message?: string) {
    const bar  = document.getElementById('netStatus');
    const text = document.getElementById('netStatusText');
    if (!bar) return;
    if (show) {
      if (message && text) text.textContent = message;
      bar.removeAttribute('hidden');
    } else {
      bar.setAttribute('hidden', '');
    }
  }

  function clearSkeleton(el: HTMLElement | null, className: string) {
    if (!el) return;
    el.classList.remove('skeleton-text', className);
  }

  function applyServerData(server: ServerStatus) {
    const badge   = document.querySelector(`[data-status="${server.id}"]`);
    const players = document.querySelector<HTMLElement>(`[data-players="${server.id}"]`);
    const fill    = document.querySelector<HTMLElement>(`[data-fill="${server.id}"]`);
    const map     = document.querySelector<HTMLElement>(`[data-map="${server.id}"]`);
    const stale   = document.querySelector<HTMLElement>(`[data-stale="${server.id}"]`);
    const section = document.querySelector<HTMLElement>(`[data-players-section="${server.id}"]`);
    const inner   = document.querySelector<HTMLElement>(`[data-players-inner="${server.id}"]`);
    if (!badge) return;

    const badgeLabel = badge.querySelector('.badge-label');

    // Limpiar skeletons
    clearSkeleton(map,     'map-skeleton');
    clearSkeleton(players, 'players-skeleton');

    if (server.online) {
      badge.className = 'badge-status badge-online';
      if (badgeLabel) badgeLabel.textContent = 'En línea';

      if (map) map.textContent = server.map ?? '–';

      if (players) {
        players.textContent = `${server.players ?? 0}/${server.maxPlayers ?? '?'}`;
      }
      if (fill && server.maxPlayers) {
        const pct = Math.min(100, ((server.players ?? 0) / server.maxPlayers) * 100);
        fill.style.width = `${pct}%`;
        fill.classList.toggle('full', pct > 85);
      }

      if (section) section.style.display = 'block';

      if (inner) {
        inner.textContent = '';
        const list = server.playerList ?? [];
        if (list.length > 0) {
          list.forEach(name => inner.appendChild(createPlayerTag(name)));
        } else {
          const empty = document.createElement('div');
          empty.className = 'players-empty';
          empty.textContent = 'Sin jugadores en este momento';
          inner.appendChild(empty);
        }
      }

    } else {
      badge.className = 'badge-status badge-offline';
      if (badgeLabel) badgeLabel.textContent = 'Fuera de línea';
      if (map)    map.textContent    = '–';
      if (players) players.textContent = '–';
      if (fill)   fill.style.width   = '0%';
      if (section) section.style.display = 'none';

      const toggle = document.querySelector(`[data-toggle="${server.id}"]`);
      const plist  = document.querySelector(`[data-players-list="${server.id}"]`);
      if (toggle) toggle.setAttribute('aria-expanded', 'false');
      if (plist)  plist.setAttribute('aria-hidden', 'true');
    }

    if (stale) stale.hidden = !server.stale;
    if (server.stale) {
      badge.className = 'badge-status badge-cached';
      if (badgeLabel) badgeLabel.textContent = 'En caché';
    }

    if (typeof server.updatedAt === 'number') {
      lastUpdated.set(server.id, server.updatedAt);
    }
    renderRelativeTimes();
  }

  function pausePolling() {
    if (refreshTimer)  { clearInterval(refreshTimer);  refreshTimer  = null; }
    if (relativeTimer) { clearInterval(relativeTimer); relativeTimer = null; }
  }

  function resumePolling() {
    if (refreshTimer || relativeTimer) return;
    fetchServerStatus();
    refreshTimer  = setInterval(fetchServerStatus,   REFRESH_INTERVAL);
    relativeTimer = setInterval(renderRelativeTimes, RELATIVE_TIME_TICK);
  }

  document.addEventListener('visibilitychange', () => {
    document.hidden ? pausePolling() : resumePolling();
  });

  document.querySelectorAll('.players-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const id   = btn.getAttribute('data-toggle');
      const list = document.querySelector(`[data-players-list="${id}"]`);
      if (!list) return;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      list.setAttribute('aria-hidden', String(isOpen));
      const label = btn.querySelector('.toggle-label');
      if (label) label.textContent = isOpen ? 'Ver jugadores' : 'Ocultar jugadores';
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    let resetTimer: ReturnType<typeof setTimeout> | null = null;
    btn.addEventListener('click', async () => {
      const ip = btn.getAttribute('data-ip');
      if (!ip) return;
      if (resetTimer) { clearTimeout(resetTimer); resetTimer = null; }
      try {
        await navigator.clipboard.writeText(`connect ${ip}`);
        const lbl = btn.querySelector('.copy-label');
        btn.classList.add('copied');
        btn.setAttribute('aria-label', 'IP copiada');
        if (lbl) lbl.textContent = 'Copiado';
        if (typeof window.showToast === 'function') {
          window.showToast(`connect ${ip} — copiado al portapapeles`, 'success', 2800);
        }
        resetTimer = setTimeout(() => {
          btn.classList.remove('copied');
          btn.setAttribute('aria-label', `Copiar IP de ${ip}`);
          if (lbl) lbl.textContent = 'Copiar';
          resetTimer = null;
        }, 2000);
      } catch {
        if (typeof window.showToast === 'function') {
          window.showToast('No se pudo copiar. Copiá la IP manualmente.', 'error');
        }
      }
    });
  });

  async function fetchServerStatus() {
    if (document.hidden) return;
    document.querySelectorAll<HTMLElement>('[data-refresh]').forEach(el => el.classList.add('active'));
    const controller = new AbortController();
    const timeoutId  = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);
    try {
      const res = await fetch('/api/servers.json', { cache: 'no-store', signal: controller.signal });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data: ServerStatus[] = await res.json();
      data.forEach(applyServerData);
      fetchFailCount = 0;
      setNetStatus(false);
    } catch (err: unknown) {
      clearTimeout(timeoutId);
      fetchFailCount++;
      const isAbort = err instanceof DOMException && err.name === 'AbortError';
      if (fetchFailCount >= MAX_RETRIES) {
        setNetStatus(true, isAbort
          ? 'El servidor tardó demasiado — reintentando más tarde'
          : 'Sin conexión — los datos pueden estar desactualizados'
        );
      }
    } finally {
      document.querySelectorAll<HTMLElement>('[data-refresh]').forEach(el => el.classList.remove('active'));
    }
  }

  document.getElementById('netRetry')?.addEventListener('click', () => {
    fetchFailCount = 0;
    setNetStatus(false);
    fetchServerStatus();
  });

  const serversSection = document.getElementById('servidores');
  const lazyObserver = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      lazyObserver.disconnect();
      fetchServerStatus();
      refreshTimer  = setInterval(fetchServerStatus,   REFRESH_INTERVAL);
      relativeTimer = setInterval(renderRelativeTimes, RELATIVE_TIME_TICK);
    }
  }, { threshold: 0.05 });

  if (serversSection) {
    lazyObserver.observe(serversSection);
  } else {
    fetchServerStatus();
    refreshTimer  = setInterval(fetchServerStatus,   REFRESH_INTERVAL);
    relativeTimer = setInterval(renderRelativeTimes, RELATIVE_TIME_TICK);
  }
</script>

