---
import SectionBg from './SectionBg.astro';
import { DEFAULT_SERVERS, serverIp, type ServerRow } from '../lib/site-data';

const serverRows: ServerRow[] = Astro.locals.servers ?? DEFAULT_SERVERS;

const servers = serverRows
  .filter(s => s.active !== false)
  .map(s => {
    const match = s.name.match(/^(#\d+)\s*(.*)$/);
    return {
      id: s.id,
      mode: s.mode ?? '',
      ip: serverIp(s),
      desc: s.description ?? '',
      num: match ? match[1] : '',
      label: match ? match[2] : s.name,
    };
  });
---

<section id="servidores" class="servers-section">

  <SectionBg variant="crosshair" glowPos="top-right" glowColor="#4ade80" />

  <div class="container">

    <div class="s-label fade-in">
      <span class="s-label-line"></span>
      <span class="s-label-text">// Servidores</span>
    </div>
    <h2 class="s-title fade-in">Elegí el servidor que quieras.</h2>
    <p class="s-sub fade-in">Copiá el comando y pegalo directo en la consola de Counter-Strike 1.6.</p>

    <!-- Barra de estado global: muestra cuando hay error de conexión -->
    <div class="net-status" id="netStatus" aria-live="polite" hidden>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 6s4-4 11-4 11 4 11 4"/><path d="M1 12s4-4 11-4 11 4 11 4"/><line x1="1" y1="18" x2="5" y2="18"/><line x1="19" y1="18" x2="23" y2="18"/><line x1="12" y1="18" x2="12.01" y2="18"/>
      </svg>
      <span id="netStatusText">Sin conexión — los datos pueden estar desactualizados</span>
      <button class="net-retry" id="netRetry" aria-label="Reintentar">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>
        </svg>
        Reintentar
      </button>
    </div>

    <div class="servers-grid">
      {servers.map((s, idx) => (
        <div class="server-card fade-in-scale" style={`transition-delay:${idx * 70}ms`} data-server-id={s.id}>

          <!-- Indicador de refresco en la esquina superior derecha -->
          <span class="refresh-indicator" data-refresh={s.id} aria-label="Actualizando..." aria-hidden="true"></span>

          <div class="card-top">
            <!-- Estado: inicia en "cargando" y JS lo actualiza -->
            <span class="badge-status badge-loading" data-status={s.id}>
              <span class="badge-dot"></span>
              <span class="badge-label">Consultando...</span>
            </span>
            <span class="server-mode">{s.mode}</span>
          </div>

          <h3 class="server-name">
            <span class="server-num">{s.num}</span> {s.label}
          </h3>
          <p class="server-desc">{s.desc}</p>

          <div class="server-readout" aria-live="polite">
            <!-- Mapa -->
            <div class="readout-row">
              <span class="readout-label">Mapa Actual:</span>
              <span class="readout-value">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                </svg>
                <span class="map-name skeleton-text" data-map={s.id}>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
              </span>
            </div>

            <!-- Jugadores -->
            <div class="readout-row">
              <span class="readout-label">Jugadores:</span>
              <span class="readout-value">
                <span class="capacity-inline">
                  <span class="capacity-track">
                    <span class="capacity-fill" data-fill={s.id}></span>
                  </span>
                  <span class="capacity-val skeleton-text" data-players={s.id}>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
                </span>
              </span>
            </div>

            <!-- Última actualización -->
            <div class="readout-row">
              <span class="readout-label">Actualizado:</span>
              <span class="readout-value readout-updated">
                <span class="skeleton-text" data-updated-text={s.id}>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
                <span class="stale-tag" data-stale={s.id} hidden title="Dato en caché, el servidor no respondió">· caché</span>
              </span>
            </div>
          </div>

          <!-- Acordeón de jugadores -->
          <div class="players-section" data-players-section={s.id} style="display:none">
            <button class="players-toggle" data-toggle={s.id} aria-expanded="false" aria-controls={`players-list-${s.id}`}>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
              <span class="toggle-label">Ver jugadores</span>
              <svg class="toggle-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>

            <div class="players-list" id={`players-list-${s.id}`} data-players-list={s.id} aria-hidden="true">
              <div class="players-inner" data-players-inner={s.id}></div>
            </div>
          </div>

          <!-- Consola con IP -->
          <div class="console-row">
            <span class="console-prompt" aria-hidden="true">&gt;</span>
            <code class="console-cmd">connect {s.ip}</code>
            <span class="console-cursor" aria-hidden="true"></span>
            <button
              class="copy-btn"
              data-ip={s.ip}
              aria-label={`Copiar IP de ${s.label}`}
            >
              <svg class="icon-copy" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <svg class="icon-check" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="copy-label">Copiar</span>
            </button>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Sección ── */
  .servers-section {
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .servers-section .container {
    position: relative;
    z-index: 1;
  }
  .servers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }

  /* ── Error de red ── */
  .net-status {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 20px;
    padding: 10px 16px;
    border-radius: var(--radius);
    background: rgba(239, 68, 68, 0.06);
    border: 1px solid rgba(239, 68, 68, 0.18);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: #f87171;
  }
  .net-status[hidden] { display: none; }
  .net-retry {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-left: auto;
    padding: 4px 10px;
    border-radius: var(--radius);
    font-size: 0.7rem;
    font-weight: 600;
    color: #f87171;
    border: 1px solid rgba(239,68,68,0.2);
    background: none;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.12s;
  }
  .net-retry:hover { background: rgba(239,68,68,0.08); }

  /* ── Card ── */
  .server-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 22px 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: border-color 0.2s ease;
  }
  .server-card:hover {
    border-color: rgba(56, 182, 255, 0.2);
  }

  /* Indicador de refresco */
  .refresh-indicator {
    display: none;
    position: absolute;
    top: 14px; right: 14px;
    width: 6px; height: 6px;
    border-radius: 50%;
    border: 1.5px solid var(--accent);
    border-top-color: transparent;
    animation: spin 0.7s linear infinite;
  }
  .refresh-indicator.active { display: block; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Card top */
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    gap: 8px;
  }

  /* Badges de estado */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 9px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--muted);
  }
  .badge-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--muted);
    flex-shrink: 0;
    animation: pulse 1.8s ease-in-out infinite;
  }
  .badge-status.badge-loading { color: var(--muted); }
  .badge-status.badge-online {
    border-color: rgba(74,222,128,0.2);
    background: rgba(74,222,128,0.05);
    color: var(--green);
  }
  .badge-status.badge-online .badge-dot { background: var(--green); }
  .badge-status.badge-offline {
    border-color: rgba(248,113,113,0.15);
    background: rgba(248,113,113,0.04);
    color: #f87171;
  }
  .badge-status.badge-offline .badge-dot {
    background: #f87171;
    animation: none;
  }
  .badge-status.badge-cached {
    border-color: rgba(251,191,36,0.15);
    color: #fbbf24;
  }
  .badge-status.badge-cached .badge-dot { background: #fbbf24; }

  .server-mode {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 2px 8px;
    border-radius: 3px;
    background: var(--surface-3);
    border: 1px solid var(--border);
  }

  /* Server name */
  .server-name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.01em;
    margin-bottom: 6px;
    line-height: 1.2;
  }
  .server-num {
    color: var(--accent);
    font-size: 0.9em;
  }
  .server-desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.55;
    margin-bottom: 16px;
  }

  /* Readout */
  .server-readout {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 14px;
    padding: 12px 14px;
    background: var(--surface-2);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .readout-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    font-size: 0.75rem;
  }
  .readout-label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--muted);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .readout-value {
    display: flex;
    align-items: center;
    gap: 5px;
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 500;
    text-align: right;
  }
  .readout-value svg { color: var(--muted); flex-shrink: 0; }
  .readout-updated { color: var(--muted); font-size: 0.72rem; }
  .stale-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: #fbbf24;
    opacity: 0.8;
  }

  /* Capacity bar */
  .capacity-inline { display: flex; align-items: center; gap: 7px; }
  .capacity-track {
    width: 48px; height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .capacity-fill {
    height: 100%;
    width: 0%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.6s ease;
  }
  .capacity-val { font-size: 0.76rem; font-weight: 600; color: var(--text); }

  /* Skeleton */
  .skeleton-text {
    display: inline-block;
    background: var(--border);
    border-radius: 2px;
    color: transparent;
    animation: shimmer 1.4s ease infinite;
  }
  @keyframes shimmer {
    0%   { opacity: 0.4; }
    50%  { opacity: 0.7; }
    100% { opacity: 0.4; }
  }

  /* Players section */
  .players-section {
    margin-bottom: 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .players-toggle {
    display: flex;
    align-items: center;
    gap: 7px;
    width: 100%;
    padding: 9px 12px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted-2);
    background: var(--surface-2);
    cursor: pointer;
    transition: color 0.15s;
    font-family: inherit;
  }
  .players-toggle:hover { color: var(--text); }
  .toggle-label { flex: 1; text-align: left; font-size: 0.73rem; }
  .toggle-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
    color: var(--muted);
  }
  .players-toggle[aria-expanded="true"] .toggle-chevron { transform: rotate(180deg); }
  .players-list {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .players-list[aria-hidden="false"] { max-height: 240px; }
  .players-inner {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 6px 0;
  }

  /* Console row */
  .console-row {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-top: auto;
  }
  .console-prompt {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    opacity: 0.6;
    flex-shrink: 0;
  }
  .console-cmd {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--muted-2);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    user-select: all;
  }
  .console-cursor { display: none; }

  /* Copy button */
  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: none;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }
  .copy-btn:hover { color: var(--text); border-color: rgba(56,182,255,0.2); }
  .copy-btn.copied { color: var(--green); border-color: rgba(74,222,128,0.2); }
  .icon-check { display: none; }
  .copy-btn.copied .icon-copy { display: none; }
  .copy-btn.copied .icon-check { display: block; }
  .copy-label { font-size: 0.68rem; }

  @keyframes pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }

  @media (prefers-reduced-motion: reduce) {
    .badge-dot, .skeleton-text { animation: none; }
  }

  @media (max-width: 640px) {
    .servers-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const REFRESH_INTERVAL   = 30_000;
  const RELATIVE_TIME_TICK = 5_000;
  const FETCH_TIMEOUT_MS   = 10_000; // AbortController timeout
  const MAX_RETRIES        = 3;

  interface ServerStatus {
    id: number;
    online: boolean;
    map?: string;
    players?: number;
    maxPlayers?: number;
    updatedAt?: number;
    stale?: boolean;
    playerList?: string[];
  }

  // ── Utilidades ─────────────────────────────────────────────────────────
  const lastUpdated = new Map<number, number>();
  let fetchFailCount = 0;
  let refreshTimer: ReturnType<typeof setInterval> | null = null;
  let relativeTimer: ReturnType<typeof setInterval> | null = null;

  // XSS-safe: crea un span con textContent en lugar de innerHTML
  function createPlayerTag(name: string): HTMLSpanElement {
    const span = document.createElement('span');
    span.className = 'player-tag';
    span.textContent = name;
    return span;
  }

  function formatRelativeTime(ms: number): string {
    const diff    = Math.max(0, Date.now() - ms);
    const seconds = Math.round(diff / 1000);
    if (seconds < 5)  return 'Recién';
    if (seconds < 60) return `${seconds}s`;
    const minutes = Math.round(seconds / 60);
    if (minutes < 60) return `${minutes} min`;
    return `${Math.round(minutes / 60)} h`;
  }

  function renderRelativeTimes() {
    lastUpdated.forEach((ts, id) => {
      const el = document.querySelector<HTMLElement>(`[data-updated-text="${id}"]`);
      if (el) {
        el.textContent = formatRelativeTime(ts);
        el.classList.add('loaded');
        el.classList.remove('skeleton-text');
      }
    });
  }

  function setNetStatus(show: boolean, message?: string) {
    const bar  = document.getElementById('netStatus');
    const text = document.getElementById('netStatusText');
    if (!bar) return;
    if (show) {
      if (message && text) text.textContent = message;
      bar.removeAttribute('hidden');
    } else {
      bar.setAttribute('hidden', '');
    }
  }

  function markSkeleton(id: number, done: boolean) {
    const targets = [
      document.querySelector<HTMLElement>(`[data-map="${id}"]`),
      document.querySelector<HTMLElement>(`[data-players="${id}"]`),
      document.querySelector<HTMLElement>(`[data-updated-text="${id}"]`),
    ];
    targets.forEach(el => {
      if (!el) return;
      if (done) {
        el.classList.remove('skeleton-text');
        el.classList.add('loaded');
      } else if (!el.classList.contains('loaded')) {
        el.classList.add('skeleton-text');
      }
    });
  }

  // ── Pausa de polling por visibilidad del tab ───────────────────────────
  // Si el usuario cambia de pestaña o minimiza, pausamos todos los intervalos
  // para no consumir red ni CPU innecesariamente.
  function pausePolling() {
    if (refreshTimer)  { clearInterval(refreshTimer);  refreshTimer  = null; }
    if (relativeTimer) { clearInterval(relativeTimer); relativeTimer = null; }
  }

  function resumePolling() {
    if (refreshTimer || relativeTimer) return; // ya corriendo
    fetchServerStatus(); // fetch inmediato al volver
    refreshTimer  = setInterval(fetchServerStatus,    REFRESH_INTERVAL);
    relativeTimer = setInterval(renderRelativeTimes,  RELATIVE_TIME_TICK);
  }

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      pausePolling();
    } else {
      resumePolling();
    }
  });

  // ── Acordeón jugadores ─────────────────────────────────────────────────
  document.querySelectorAll('.players-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const id   = btn.getAttribute('data-toggle');
      const list = document.querySelector(`[data-players-list="${id}"]`);
      if (!list) return;

      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      list.setAttribute('aria-hidden', String(isOpen));

      const label = btn.querySelector('.toggle-label');
      if (label) label.textContent = isOpen ? 'Ver jugadores' : 'Ocultar jugadores';
    });
  });

  // ── Copiar IP ──────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    let resetTimer: ReturnType<typeof setTimeout> | null = null;

    btn.addEventListener('click', async () => {
      const ip = btn.getAttribute('data-ip');
      if (!ip) return;

      if (resetTimer) { clearTimeout(resetTimer); resetTimer = null; }

      try {
        await navigator.clipboard.writeText(`connect ${ip}`);

        const lbl = btn.querySelector('.copy-label');
        const row = btn.closest('.console-row');

        btn.classList.add('copied');
        row?.classList.add('copied');
        btn.setAttribute('aria-label', 'IP copiada');
        if (lbl) lbl.textContent = 'Copiado';

        if (typeof window.showToast === 'function') {
          window.showToast(`connect ${ip} — copiado al portapapeles`, 'success', 2800);
        }

        resetTimer = setTimeout(() => {
          btn.classList.remove('copied');
          row?.classList.remove('copied');
          btn.setAttribute('aria-label', `Copiar IP de ${ip}`);
          if (lbl) lbl.textContent = 'Copiar';
          resetTimer = null;
        }, 2000);

      } catch {
        if (typeof window.showToast === 'function') {
          window.showToast('No se pudo copiar. Copiá la IP manualmente.', 'error');
        }
      }
    });
  });

  // ── Fetch y render ─────────────────────────────────────────────────────
  function applyServerData(server: ServerStatus) {
    const badge   = document.querySelector(`[data-status="${server.id}"]`);
    const players = document.querySelector<HTMLElement>(`[data-players="${server.id}"]`);
    const fill    = document.querySelector<HTMLElement>(`[data-fill="${server.id}"]`);
    const map     = document.querySelector<HTMLElement>(`[data-map="${server.id}"]`);
    const stale   = document.querySelector<HTMLElement>(`[data-stale="${server.id}"]`);
    const section = document.querySelector<HTMLElement>(`[data-players-section="${server.id}"]`);
    const inner   = document.querySelector<HTMLElement>(`[data-players-inner="${server.id}"]`);

    if (!badge) return;
    const label = badge.querySelector('.badge-label');

    markSkeleton(server.id, true);

    if (server.online) {
      badge.className = 'badge-status badge-online';
      if (label) label.textContent = 'En línea';

      if (players) {
        players.textContent = `${server.players}/${server.maxPlayers}`;
        players.classList.add('has-data');
      }

      if (fill && server.maxPlayers) {
        const pct = Math.min(100, ((server.players ?? 0) / server.maxPlayers) * 100);
        fill.style.width = `${pct}%`;
        fill.classList.toggle('full', pct > 85);
      }

      if (map) map.textContent = server.map ?? '–';
      if (section) section.style.display = 'block';

      // XSS-safe: usamos textContent vía createPlayerTag, nunca innerHTML con datos externos
      if (inner) {
        inner.textContent = ''; // limpiar sin innerHTML
        const list = server.playerList ?? [];
        if (list.length > 0) {
          list.forEach(name => inner.appendChild(createPlayerTag(name)));
        } else {
          const empty = document.createElement('span');
          empty.className = 'players-empty';
          empty.textContent = 'Sin jugadores en este momento';
          inner.appendChild(empty);
        }
      }

    } else {
      badge.className = 'badge-status badge-offline';
      if (label) label.textContent = 'Fuera de línea';

      if (players) {
        players.textContent = '–';
        players.classList.remove('has-data');
      }
      if (fill) fill.style.width = '0%';
      if (map)  map.textContent  = '–';
      if (section) section.style.display = 'none';

      // Cerrar acordeón si estaba abierto
      const toggle = document.querySelector(`[data-toggle="${server.id}"]`);
      const plist  = document.querySelector(`[data-players-list="${server.id}"]`);
      if (toggle) toggle.setAttribute('aria-expanded', 'false');
      if (plist)  plist.setAttribute('aria-hidden', 'true');
    }

    if (stale) stale.hidden = !server.stale;
    if (typeof server.updatedAt === 'number') {
      lastUpdated.set(server.id, server.updatedAt);
    }
  }

  async function fetchServerStatus() {
    // No hacer fetch si el tab está en segundo plano
    if (document.hidden) return;

    document.querySelectorAll<HTMLElement>('[data-refresh]').forEach(el => {
      el.classList.add('spinning');
    });

    // AbortController con timeout de 10s — evita que la UI quede colgada
    // si el endpoint tarda o no responde
    const controller = new AbortController();
    const timeoutId  = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);

    try {
      const res = await fetch('/api/servers.json', {
        cache:  'no-store',
        signal: controller.signal,
      });
      clearTimeout(timeoutId);

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const data: ServerStatus[] = await res.json();
      data.forEach(applyServerData);

      fetchFailCount = 0;
      setNetStatus(false);

    } catch (err: unknown) {
      clearTimeout(timeoutId);
      fetchFailCount++;

      const isAbort = err instanceof DOMException && err.name === 'AbortError';
      console.warn('[Servers] Fetch falló:', isAbort ? 'timeout (10s)' : err);

      if (fetchFailCount >= MAX_RETRIES) {
        const msg = isAbort
          ? 'El servidor tardó demasiado en responder — reintentando más tarde'
          : 'No se pudo conectar con el servidor — los datos pueden estar desactualizados';
        setNetStatus(true, msg);
        // Sacar skeletons para no dejar la UI en blanco
        document.querySelectorAll<HTMLElement>('[data-status]').forEach(badge => {
          const id = badge.getAttribute('data-status');
          if (id) markSkeleton(Number(id), true);
        });
      }

    } finally {
      document.querySelectorAll<HTMLElement>('[data-refresh]').forEach(el => {
        el.classList.remove('spinning');
      });
      renderRelativeTimes();
    }
  }

  // ── Botón reintentar ───────────────────────────────────────────────────
  document.getElementById('netRetry')?.addEventListener('click', () => {
    fetchFailCount = 0;
    setNetStatus(false);
    fetchServerStatus();
  });

  // ── Arranque lazy: fetch solo cuando la sección es visible ────────────
  const serversSection = document.getElementById('servidores');
  const lazyObserver = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      lazyObserver.disconnect();
      fetchServerStatus();
      refreshTimer  = setInterval(fetchServerStatus,   REFRESH_INTERVAL);
      relativeTimer = setInterval(renderRelativeTimes, RELATIVE_TIME_TICK);
    }
  }, { threshold: 0.05 });

  if (serversSection) {
    lazyObserver.observe(serversSection);
  } else {
    fetchServerStatus();
    refreshTimer  = setInterval(fetchServerStatus,   REFRESH_INTERVAL);
    relativeTimer = setInterval(renderRelativeTimes, RELATIVE_TIME_TICK);
  }
</script>