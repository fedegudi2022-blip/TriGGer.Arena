---
import SectionBg from './SectionBg.astro';
import { DEFAULT_CONTENT_BLOCKS } from '../lib/site-data';

const c     = Astro.locals.contentBlocks?.rules ?? DEFAULT_CONTENT_BLOCKS.rules;
const rules = c.rules;

const sevColor: Record<string, string> = {
  high: '#e53e3e',
  mid:  '#d97706',
  low:  'var(--accent)',
};
---

<section id="reglas" class="rules-section">
  <SectionBg variant="crosshair" glowPos="top-left" />

  <div class="container">
    <div class="s-label fade-in">
      <span class="s-label-line"></span>
      <span class="s-label-text">// Reglamento</span>
    </div>
    <h2 class="s-title fade-in">{c.section_title}</h2>
    <p class="s-sub fade-in">{c.section_sub}</p>

    <!-- Botón resumen rápido -->
    <div class="rules-quick-cta fade-in">
      <button class="rules-quick-btn" onclick="window.openModal?.('reglas-resumen')">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.2"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Resumen rápido de reglas
      </button>
    </div>

    <div class="rules-list fade-in" id="rulesAccordion">
      {rules.map(r => (
        <div
          class={`rule-item sev-${r.severity}`}
          style={`--sev-color:${sevColor[r.severity]}`}
        >
          <!-- Barra decorativa superior -->
          <div class="rule-top-bar" aria-hidden="true"></div>

          <button
            class="rule-trigger"
            aria-expanded="false"
            aria-controls={`rule-body-${r.id}`}
            id={`rule-trigger-${r.id}`}
          >
            <span class="rule-left">
              <i class={`ti ${r.icon} rule-icon-ti`} aria-hidden="true"></i>
            </span>

            <span class="rule-center">
              <span class="rule-title-row">
                <span class="rule-num">{r.id}</span>
                <span class="rule-title">{r.title}</span>
              </span>
              <span class={`rule-tag tag-${r.severity}`}>{r.tag}</span>
            </span>

            <span class="rule-chevron" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </span>
          </button>

          <div
            class="rule-body"
            id={`rule-body-${r.id}`}
            role="region"
            aria-labelledby={`rule-trigger-${r.id}`}
            aria-hidden="true"
          >
            <div class="rule-body-inner">
              <p>{r.body}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Sección ── */
  .rules-section {
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .rules-section .container {
    position: relative;
    z-index: 1;
  }

  /* ── Botón resumen ── */
  .rules-quick-cta { margin-bottom: 20px; }
  .rules-quick-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-2);
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .rules-quick-btn:hover {
    color: var(--accent);
    border-color: var(--border-accent);
    background: var(--accent-dark);
  }

  /* ── Lista de reglas ── */
  .rules-list {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  /* ── Item ── */
  .rule-item {
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .rule-item:last-child { border-bottom: none; }

  /* Acento vertical izquierdo */
  .rule-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 3px;
    height: 100%;
    background: var(--sev-color);
    opacity: 0.35;
    transition: opacity 0.2s ease;
    z-index: 1;
    pointer-events: none;
  }
  .rule-item:has(.rule-trigger[aria-expanded="true"])::before {
    opacity: 1;
  }

  /* Barra superior decorativa */
  .rule-top-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--sev-color) 0%,
      color-mix(in srgb, var(--sev-color) 20%, transparent) 55%,
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.22s ease, height 0.22s ease;
    z-index: 1;
    pointer-events: none;
  }
  .rule-item:hover .rule-top-bar { opacity: 0.45; }
  .rule-item:has(.rule-trigger[aria-expanded="true"]) .rule-top-bar {
    opacity: 0.9;
    height: 3px;
  }

  /* Glow de fondo por severidad */
  .rule-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 0% 50%,
      color-mix(in srgb, var(--sev-color) 7%, transparent) 0%,
      transparent 65%
    );
    opacity: 0;
    transition: opacity 0.22s ease;
    pointer-events: none;
  }
  .rule-item:hover::after { opacity: 0.55; }
  .rule-item:has(.rule-trigger[aria-expanded="true"])::after { opacity: 1; }

  /* ── Trigger ── */
  .rule-trigger {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 16px 18px 16px 20px;
    gap: 14px;
    text-align: left;
    background: var(--surface);
    border: none;
    cursor: pointer;
    position: relative;
    z-index: 1;
    transition: background 0.18s ease;
    outline: none;
  }
  .rule-trigger:hover { background: var(--surface-2); }
  .rule-trigger[aria-expanded="true"] { background: var(--surface-2); }
  .rule-trigger:focus-visible {
    box-shadow: inset 0 0 0 2px rgba(56, 182, 255, 0.4);
  }

  /* Ícono izquierdo */
  .rule-left {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }
  .rule-trigger[aria-expanded="true"] .rule-left {
    background: color-mix(in srgb, var(--sev-color) 10%, transparent);
    border-color: color-mix(in srgb, var(--sev-color) 35%, transparent);
    box-shadow: 0 0 14px color-mix(in srgb, var(--sev-color) 18%, transparent);
  }
  .rule-icon-ti {
    font-size: 1rem;
    color: var(--muted-2);
    transition: color 0.2s ease;
  }
  .rule-trigger[aria-expanded="true"] .rule-icon-ti {
    color: var(--sev-color);
  }

  /* Centro */
  .rule-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .rule-title-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .rule-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--accent);
    flex-shrink: 0;
  }
  .rule-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
  }

  /* Tags de severidad */
  .rule-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 999px;
    width: fit-content;
  }
  .tag-high { color: #e53e3e; background: rgba(229,62,62,0.08); border: 1px solid rgba(229,62,62,0.22); }
  .tag-mid  { color: #d97706; background: rgba(217,119,6,0.08); border: 1px solid rgba(217,119,6,0.22); }
  .tag-low  {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
  }

  /* Chevron */
  .rule-chevron {
    color: var(--muted);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    transition: transform 0.26s ease, color 0.2s ease;
  }
  .rule-trigger[aria-expanded="true"] .rule-chevron {
    transform: rotate(180deg);
    color: var(--sev-color);
  }

  /* ── Cuerpo del acordeón ──
     Mismo patrón que FAQ:
     - max-height:0 en cerrado
     - borde superior visible sólo cuando está abierto
     - will-change para evitar reflow en cada frame
  ── */
  .rule-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: max-height;
    position: relative;
    z-index: 1;
    /* Borde parte invisible */
    border-top: 1px solid transparent;
  }
  .rule-item:has([aria-expanded="true"]) .rule-body {
    border-top-color: var(--border);
  }

  .rule-body-inner {
    padding: 12px 20px 18px 68px;
    background: color-mix(in srgb, var(--sev-color) 4%, var(--surface-2));
  }
  .rule-body-inner p {
    font-size: 0.86rem;
    color: var(--muted-2);
    line-height: 1.75;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 540px) {
    .rule-trigger    { padding: 14px 14px 14px 16px; gap: 10px; }
    .rule-body-inner { padding-left: 20px; }
    .rule-left       { width: 28px; height: 28px; }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .rule-body       { transition: none; }
    .rule-chevron    { transition: none; }
    .rule-item       { transition: none; }
    .rule-top-bar    { transition: none; }
    .rule-item::before,
    .rule-item::after { transition: none; }
    .rule-left       { transition: none; }
    .rule-icon-ti    { transition: none; }
    .rules-quick-btn { transition: none; }
  }
</style>

<script>
  // Mismo fix que el resto — ver comentario en SlidePanel.astro.
  let rulesAbort: AbortController | null = null;

  function initRules() {
    rulesAbort?.abort();
    rulesAbort = new AbortController();
    const { signal } = rulesAbort;

    const triggers = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.rule-trigger')
    );
    if (triggers.length === 0) return; // Rules no presente en esta página

    function getBody(trigger: HTMLButtonElement): HTMLElement | null {
      const id = trigger.getAttribute('aria-controls');
      return id ? document.getElementById(id) : null;
    }

    function openItem(trigger: HTMLButtonElement) {
      const body = getBody(trigger);
      if (!body) return;
      trigger.setAttribute('aria-expanded', 'true');
      body.setAttribute('aria-hidden', 'false');
      body.style.maxHeight = body.scrollHeight + 2 + 'px';
    }

    function closeItem(trigger: HTMLButtonElement) {
      const body = getBody(trigger);
      if (!body) return;
      trigger.setAttribute('aria-expanded', 'false');
      body.setAttribute('aria-hidden', 'true');
      body.style.maxHeight = '0';
    }

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        // Cerrar todos
        triggers.forEach(t => closeItem(t));
        // Abrir este si estaba cerrado
        if (!isOpen) openItem(trigger);
      }, { signal });
    });

    // Recalcular max-height en resize
    let raf: number | null = null;
    window.addEventListener('resize', () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        triggers.forEach(trigger => {
          if (trigger.getAttribute('aria-expanded') === 'true') {
            const body = getBody(trigger);
            if (body) body.style.maxHeight = body.scrollHeight + 2 + 'px';
          }
        });
        raf = null;
      });
    }, { passive: true, signal });
  }

  initRules();
  document.addEventListener('astro:page-load', initRules);
</script>