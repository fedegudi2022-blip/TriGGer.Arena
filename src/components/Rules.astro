---
import SectionBg from './SectionBg.astro';
import { DEFAULT_CONTENT_BLOCKS } from '../lib/site-data';

const c = Astro.locals.contentBlocks?.rules ?? DEFAULT_CONTENT_BLOCKS.rules;
const rules = c.rules;

const sevColor: Record<string, string> = {
  high: '#e53e3e',
  mid:  '#d97706',
  low:  'var(--accent)'
};
---

<section id="reglas" class="rules-section">

  <SectionBg variant="crosshair" glowPos="top-left" />

  <div class="container">

    <div class="s-label fade-in">
      <span class="s-label-line"></span>
      <span class="s-label-text">// Reglamento</span>
    </div>
    <h2 class="s-title fade-in">{c.section_title}</h2>
    <p class="s-sub fade-in">{c.section_sub}</p>

    <!-- Botón resumen rápido -->
    <div class="rules-quick-cta fade-in">
      <button class="rules-quick-btn" onclick="window.openModal?.('reglas-resumen')">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Resumen rápido de reglas
      </button>
    </div>

    <div class="rules-list fade-in" id="rulesAccordion">
      {rules.map(r => (
        <div
          class={`rule-item sev-${r.severity}`}
          style={`--sev-color: ${sevColor[r.severity]}`}
        >
          <div class="rule-top-bar" aria-hidden="true"></div>

          <button class="rule-trigger" aria-expanded="false" data-rule={r.id}>

            <span class="rule-left">
              <i class={`ti ${r.icon} rule-icon-ti`} aria-hidden="true"></i>
            </span>

            <span class="rule-center">
              <span class="rule-title-row">
                <span class="rule-num">{r.id}</span>
                <span class="rule-title">{r.title}</span>
              </span>
              <span class={`rule-tag tag-${r.severity}`}>{r.tag}</span>
            </span>

            <span class="rule-chevron" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </span>

          </button>
          <div class="rule-body" role="region">
            <div class="rule-body-inner">
              <p>{r.body}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .rules-section { padding: var(--section-gap) 0; border-top: 1px solid var(--border); position: relative; overflow: hidden; }
  .container { position: relative; z-index: 1; }
  /* Botón resumen modal */
  .rules-quick-cta { margin-bottom: 20px; }
  .rules-quick-btn { display: inline-flex; align-items: center; gap: 7px; padding: 8px 16px; font-family: var(--font-mono); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-2); background: none; border: 1px solid var(--border); border-radius: var(--radius); cursor: pointer; transition: color 0.15s, border-color 0.15s, background 0.15s; }
  .rules-quick-btn:hover { color: var(--accent); border-color: var(--border-accent); background: var(--accent-dark); }
  .rules-list { border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
  .rule-item { border-bottom: 1px solid var(--border); position: relative; }
  .rule-item:last-child { border-bottom: none; }
  .rule-item::before { content: ''; position: absolute; left: 0; top: 0; width: 3px; height: 100%; background: var(--sev-color); opacity: 0.4; transition: opacity 0.18s; z-index: 1; }
  .rule-item:has(.rule-trigger[aria-expanded="true"])::before { opacity: 1; }
  .rule-top-bar { position: absolute; top: 0; left: 0; width: 100%; height: 2px; background: linear-gradient(90deg, var(--sev-color) 0%, color-mix(in srgb, var(--sev-color) 25%, transparent) 60%, transparent 100%); opacity: 0; transition: opacity 0.22s ease, height 0.22s ease; z-index: 1; pointer-events: none; }
  .rule-item:hover .rule-top-bar { opacity: 0.5; }
  .rule-item:has(.rule-trigger[aria-expanded="true"]) .rule-top-bar { opacity: 0.9; height: 3px; }
  .rule-item::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 0% 50%, color-mix(in srgb, var(--sev-color) 7%, transparent) 0%, transparent 65%); opacity: 0; transition: opacity 0.22s ease; pointer-events: none; }
  .rule-item:hover::after { opacity: 0.6; }
  .rule-item:has(.rule-trigger[aria-expanded="true"])::after { opacity: 1; }
  .rule-trigger { display: flex; align-items: center; width: 100%; padding: 16px 18px 16px 20px; gap: 14px; text-align: left; background: var(--surface); transition: background 0.18s; cursor: pointer; border: none; position: relative; z-index: 1; }
  .rule-trigger:hover { background: var(--surface-2); }
  .rule-trigger[aria-expanded="true"] { background: var(--surface-2); }
  .rule-left { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 9px; background: var(--surface-2); border: 1px solid var(--border); transition: border-color 0.18s, background 0.18s, box-shadow 0.18s; }
  .rule-trigger[aria-expanded="true"] .rule-left { background: color-mix(in srgb, var(--sev-color) 10%, transparent); border-color: color-mix(in srgb, var(--sev-color) 35%, transparent); box-shadow: 0 0 14px color-mix(in srgb, var(--sev-color) 20%, transparent); }
  .rule-icon-ti { font-size: 1rem; color: var(--muted-2); transition: color 0.18s; }
  .rule-trigger[aria-expanded="true"] .rule-icon-ti { color: var(--sev-color); }
  .rule-center { flex: 1; display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .rule-title-row { display: flex; align-items: baseline; gap: 8px; }
  .rule-num { font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; color: var(--accent); flex-shrink: 0; }
  .rule-title { font-size: 0.875rem; font-weight: 500; color: var(--text); line-height: 1.4; }
  .rule-tag { font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; padding: 2px 7px; border-radius: 999px; width: fit-content; }
  .tag-high { color: #e53e3e; background: rgba(229,62,62,.08); border: 1px solid rgba(229,62,62,.22); }
  .tag-mid  { color: #d97706; background: rgba(217,119,6,.08); border: 1px solid rgba(217,119,6,.22); }
  .tag-low  { color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent); }
  .rule-chevron { color: var(--muted); flex-shrink: 0; transition: transform 0.25s ease, color 0.18s; display: flex; align-items: center; }
  .rule-trigger[aria-expanded="true"] .rule-chevron { transform: rotate(180deg); color: var(--sev-color); }
  .rule-body { max-height: 0; overflow: hidden; transition: max-height 0.32s ease; position: relative; z-index: 1; }
  .rule-body-inner { padding: 12px 20px 18px 68px; background: color-mix(in srgb, var(--sev-color) 4%, var(--surface-2)); border-top: 1px solid var(--border); }
  .rule-body-inner p { font-size: 0.86rem; color: var(--muted-2); line-height: 1.75; margin: 0; }
  @media (max-width: 540px) { .rule-trigger { padding: 14px 14px 14px 16px; gap: 10px; } .rule-body-inner { padding-left: 20px; } .rule-left { width: 28px; height: 28px; } }
</style>

<script>
  document.querySelectorAll('.rule-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      const body = trigger.nextElementSibling as HTMLElement | null;

      document.querySelectorAll('.rule-trigger').forEach(t => {
        t.setAttribute('aria-expanded', 'false');
        const b = t.nextElementSibling as HTMLElement | null;
        if (b) b.style.maxHeight = '0';
      });

      if (!expanded && body) {
        trigger.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
      }
    });
  });
</script>