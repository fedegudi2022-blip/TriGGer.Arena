---
/**
 * SectionBg — Versión minimalista
 * Mantiene la API pero reduce todo a casi invisible.
 * Sólo un pattern de puntos muy sutil, sin glow, sin noise agresivo.
 */

interface Props {
  variant?:   'dots' | 'grid' | 'crosshair' | 'diagonal' | 'scanlines' | 'circuit';
  glowPos?:   'top-left' | 'top-right' | 'center' | 'bottom-left' | 'bottom-right' | 'none';
  glowColor?: string;
  noise?:     boolean;
}

const {
  variant   = 'dots',
  glowPos   = 'none',  // Default a none en la versión limpia
  glowColor,
  noise     = false,   // Noise desactivado por defecto
} = Astro.props;
---

<div class={`sec-bg sec-bg--${variant}`} aria-hidden="true">
  <div class="sec-pattern"></div>
</div>

<style>
  .sec-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* Patrón de puntos: mínimo, casi invisible */
  .sec-bg--dots .sec-pattern,
  .sec-bg--crosshair .sec-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.05) 1px,
      transparent 1px
    );
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at 50% 0%, black 0%, transparent 65%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 0%, black 0%, transparent 65%);
  }

  /* Grid: líneas muy tenues */
  .sec-bg--grid .sec-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at 50% 0%, black 0%, transparent 60%);
  }

  /* Diagonal, scanlines, circuit: vacíos */
  .sec-bg--diagonal .sec-pattern,
  .sec-bg--scanlines .sec-pattern,
  .sec-bg--circuit .sec-pattern {
    position: absolute;
    inset: 0;
  }

  @media (forced-colors: active) {
    .sec-bg { display: none; }
  }
</style>
