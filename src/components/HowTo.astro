---
import { DEFAULT_CONTENT_BLOCKS } from '../lib/site-data';

const c = Astro.locals.contentBlocks?.howto ?? DEFAULT_CONTENT_BLOCKS.howto;
const steps = [c.step1, c.step2, c.step3];
---
<section id="como-unirse" class="howto-section">
  <div class="container">
    <div class="s-label fade-in">
      <span class="s-label-line"></span>
      <span class="s-label-text">// Cómo jugar</span>
    </div>

    <h2 class="s-title fade-in">{c.section_title}</h2>

    <p class="s-sub fade-in">{c.section_sub}</p>

    <div class="howto-grid">
      {steps.map((step, i) => (
        <article class="howto-step fade-in" style={`--i:${i}`}>
          <div class="howto-step-top">
            <div class="step-icon">
              <span class="step-num">{i + 1}</span>
            </div>
            <div class="step-connector" aria-hidden="true"></div>
          </div>
          <div class="howto-step-body">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
          <div class="howto-step-bar"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .howto-section { padding: var(--section-gap) 0; border-top: 1px solid rgba(255,255,255,0.06); background: linear-gradient(180deg, rgba(7,9,15,0.95) 0%, rgba(7,9,15,0.97) 100%); position: relative; overflow: hidden; }
  .howto-section::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 45% at 50% 75%, rgba(56,182,255,0.045) 0%, transparent 70%); pointer-events: none; }
  .howto-grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); position: relative; }
  .howto-step { padding: 26px; border-radius: 20px; background: rgba(13,18,32,0.82); border: 1px solid rgba(56,182,255,0.08); display: flex; flex-direction: column; gap: 20px; position: relative; overflow: hidden; transition: transform 0.28s ease, border-color 0.28s ease, box-shadow 0.28s ease; animation-delay: calc(var(--i, 0) * 0.1s); }
  .howto-step-bar { position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, rgba(56,182,255,0.6), transparent); transform: scaleX(0); transform-origin: center; transition: transform 0.35s ease; border-radius: 20px 20px 0 0; }
  .howto-step::after { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 110%, rgba(56,182,255,0.07) 0%, transparent 65%); opacity: 0; transition: opacity 0.35s ease; pointer-events: none; }
  .howto-step:hover { transform: translateY(-5px); border-color: rgba(56,182,255,0.2); box-shadow: 0 20px 50px rgba(0,0,0,0.28), 0 0 0 1px rgba(56,182,255,0.06); }
  .howto-step:hover .howto-step-bar { transform: scaleX(1); }
  .howto-step:hover::after { opacity: 1; }
  .howto-step-top { display: flex; align-items: center; gap: 14px; }
  .step-icon { width: 46px; height: 46px; flex-shrink: 0; display: grid; place-items: center; border-radius: 50%; background: rgba(56,182,255,0.1); border: 1px solid rgba(56,182,255,0.18); position: relative; transition: background 0.28s ease, border-color 0.28s ease, box-shadow 0.28s ease; }
  .howto-step:hover .step-icon { background: rgba(56,182,255,0.17); border-color: rgba(56,182,255,0.35); box-shadow: 0 0 14px rgba(56,182,255,0.15); }
  .step-num { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--accent); line-height: 1; }
  .step-connector { flex: 1; height: 1px; background: repeating-linear-gradient(90deg, rgba(56,182,255,0.18) 0px, rgba(56,182,255,0.18) 4px, transparent 4px, transparent 10px); display: none; }
  .howto-step-body { display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .howto-step h3 { margin: 0; font-size: 1.05rem; font-weight: 700; color: var(--text); line-height: 1.3; }
  .howto-step p { margin: 0; color: var(--muted-2); line-height: 1.75; font-size: 0.93rem; }
  @media (min-width: 780px) { .howto-step:not(:last-child) .step-connector { display: block; } }
  @media (max-width: 540px) { .howto-section { padding: 90px 0; } .howto-grid { gap: 12px; } }
</style>