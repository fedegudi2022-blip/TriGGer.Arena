---
import { DEFAULT_CONTENT_BLOCKS } from '../lib/site-data';

const e = Astro.locals.contentBlocks?.effexo ?? DEFAULT_CONTENT_BLOCKS.effexo;
---

<section class="effexo" id="effexo">
  <div class="container effexo-inner">
    <div class="effexo-card">

      <span class="effexo-badge">{e.badge}</span>

      <div class="effexo-logo">
        <div class="logo-bg">
          <span>{e.title.charAt(0)}</span>
        </div>
      </div>

      <h2 class="effexo-title">{e.title}</h2>

      <p class="effexo-desc">{e.description}</p>

      <div class="effexo-features">
        {e.features.map((f: string) => (
          <span><i class="ti ti-bolt" aria-hidden="true"></i> {f}</span>
        ))}
      </div>

      <a
        class="effexo-btn"
        href={e.btn_url}
        target="_blank"
        rel="noopener noreferrer"
      >
        {e.btn_label}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

    </div>
  </div>
</section>

<style>
  .effexo { padding: var(--section-gap) 0; border-top: 1px solid var(--border); position: relative; overflow: hidden; }
  .effexo::before { content: ''; position: absolute; top: -120px; left: 50%; transform: translateX(-50%); width: 700px; height: 500px; background: radial-gradient(circle, rgba(56,182,255,0.07) 0%, transparent 70%); pointer-events: none; }
  .effexo-inner { display: flex; justify-content: center; }
  .effexo-card { position: relative; max-width: 820px; width: 100%; padding: 56px 48px; text-align: center; border-radius: 16px; background: var(--surface); border: 1px solid var(--border); overflow: hidden; transition: border-color 0.25s ease, box-shadow 0.25s ease; }
  .effexo-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 2px; background: linear-gradient(90deg, transparent, var(--accent), transparent); opacity: 0.6; transition: opacity 0.25s; }
  .effexo-card:hover { border-color: var(--border-accent); box-shadow: 0 0 60px rgba(56,182,255,0.07); }
  .effexo-card:hover::before { opacity: 1; }
  .effexo-badge { display: inline-flex; align-items: center; gap: 6px; padding: 5px 14px; border-radius: 999px; background: var(--accent-dark); border: 1px solid var(--border-accent); color: var(--accent); font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; }
  .effexo-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); display: inline-block; animation: pulse 2s infinite; }
  .effexo-logo { margin-top: 28px; display: flex; justify-content: center; }
  .logo-bg { width: 88px; height: 88px; border-radius: var(--radius-lg); background: var(--surface-2); border: 1px solid var(--border-accent); display: flex; align-items: center; justify-content: center; box-shadow: 0 0 24px rgba(56,182,255,0.15); }
  .logo-bg span { color: var(--accent); font-family: var(--font-display); font-size: 3rem; font-weight: 700; line-height: 1; }
  .effexo-title { margin-top: 20px; font-family: var(--font-display); font-size: clamp(2.8rem, 6vw, 4.5rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1; color: var(--text); }
  .effexo-desc { max-width: 640px; margin: 20px auto 0; font-size: 0.92rem; color: var(--muted-2); line-height: 1.85; }
  .effexo-features { margin-top: 28px; display: flex; justify-content: center; flex-wrap: wrap; gap: 8px; }
  .effexo-features span { display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px; border-radius: var(--radius-lg); background: var(--surface-2); border: 1px solid var(--border); color: var(--muted-2); font-size: 0.8rem; font-family: var(--font-mono); transition: border-color 0.18s, color 0.18s; }
  .effexo-features span i { color: var(--accent); font-size: 0.95rem; }
  .effexo-features span:hover { border-color: var(--border-accent); color: var(--text); }
  .effexo-btn { margin-top: 36px; display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; border-radius: var(--radius-lg); font-weight: 600; font-size: 0.92rem; text-decoration: none; background: var(--accent); color: var(--bg); border: 1px solid var(--accent); transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease; }
  .effexo-btn:hover { background: rgba(56,182,255,0.88); box-shadow: 0 8px 24px rgba(56,182,255,0.28); transform: translateY(-2px); }
  .effexo-btn svg { transition: transform 0.18s ease; }
  .effexo-btn:hover svg { transform: translateX(3px); }
  @media (max-width: 540px) { .effexo-card { padding: 36px 20px; } .effexo-features span { font-size: 0.75rem; padding: 6px 10px; } }

  @keyframes pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }
</style>