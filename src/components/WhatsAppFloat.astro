---
import { WHATSAPP_URL as DEFAULT_WHATSAPP_URL, DISCORD_URL as DEFAULT_DISCORD_URL } from '../config';

const WHATSAPP_URL = Astro.locals.siteSettings?.whatsapp_url ?? DEFAULT_WHATSAPP_URL;
const DISCORD_URL  = Astro.locals.siteSettings?.discord_url  ?? DEFAULT_DISCORD_URL;
---

<div class="float-wrap" id="floatWrap" role="group" aria-label="Comunidad TriGGer.Arena">

  <!-- Trigger: siempre visible, un solo botón pequeño -->
  <button class="float-trigger" id="floatTrigger" aria-label="Comunidad" aria-expanded="false">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
      <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>
    <span class="trigger-dot" aria-hidden="true"></span>
  </button>

  <!-- Panel que aparece al hover/focus -->
  <div class="float-panel" id="floatPanel" role="menu" aria-hidden="true">
    <div class="panel-top">
      <span class="panel-label">Comunidad</span>
    </div>

    <a
      href={WHATSAPP_URL}
      class="float-link whatsapp"
      target="_blank"
      rel="noopener noreferrer"
      role="menuitem"
      aria-label="WhatsApp — Grupo de la comunidad"
    >
      <span class="link-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </span>
      <span class="link-body">
        <span class="link-name">WhatsApp</span>
        <span class="link-sub">Grupo de la comunidad</span>
      </span>
    </a>

    <a
      href={DISCORD_URL}
      class="float-link discord"
      target="_blank"
      rel="noopener noreferrer"
      role="menuitem"
      aria-label="Discord — Servidor oficial"
    >
      <span class="link-icon">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
        </svg>
      </span>
      <span class="link-body">
        <span class="link-name">Discord</span>
        <span class="link-sub">Servidor oficial</span>
      </span>
    </a>
  </div>

</div>

<style>
  .float-wrap {
    position: fixed;
    bottom: max(24px, env(safe-area-inset-bottom, 24px));
    right: max(24px, env(safe-area-inset-right, 24px));
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
  }

  /* ── Trigger ── */
  .float-trigger {
    position: relative;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #0c1018;
    border: 1px solid rgba(56,182,255,0.22);
    color: rgba(56,182,255,0.7);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4), 0 0 12px rgba(56,182,255,0.08);
    transition: border-color 0.15s, color 0.15s, box-shadow 0.15s;
  }
  .float-trigger:hover,
  .float-wrap:hover .float-trigger {
    border-color: rgba(56,182,255,0.5);
    color: #38b6ff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4), 0 0 18px rgba(56,182,255,0.18);
  }
  .float-trigger:focus-visible {
    outline: 2px solid rgba(56,182,255,0.5);
    outline-offset: 3px;
  }

  /* Punto verde "activo" */
  .trigger-dot {
    position: absolute;
    top: 4px; right: 4px;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #4ade80;
    border: 1.5px solid #0c1018;
    box-shadow: 0 0 6px rgba(74,222,128,0.6);
    animation: pulse 2.5s infinite;
  }

  /* ── Panel ── */
  .float-panel {
    background: #0c1018;
    border: 1px solid rgba(56,182,255,0.18);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(56,182,255,0.05);
    width: 210px;

    /* Estado oculto */
    opacity: 0;
    transform: translateY(6px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  /* Línea accent superior */
  .float-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(56,182,255,0.45) 50%, transparent);
  }

  /* Abrir con hover sobre el wrap O el panel mismo */
  .float-wrap:hover .float-panel,
  .float-wrap:focus-within .float-panel {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* ── Header del panel ── */
  .panel-top {
    padding: 9px 13px 6px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .panel-label {
    font-size: 0.54rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(56,182,255,0.4);
  }

  /* ── Links ── */
  .float-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 13px;
    text-decoration: none;
    color: #6a8aaa;
    transition: background 0.12s, color 0.12s;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .float-link:last-child { border-bottom: none; }

  .link-icon {
    width: 30px; height: 30px;
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    border: 1px solid transparent;
    transition: background 0.12s, border-color 0.12s;
  }

  .link-body  { flex: 1; min-width: 0; }
  .link-name  { font-size: 0.78rem; font-weight: 600; color: #b8cce0; display: block; transition: color 0.12s; }
  .link-sub   { font-size: 0.6rem; color: #3a5a7a; display: block; margin-top: 1px; }

  /* WhatsApp */
  .float-link.whatsapp .link-icon { background: rgba(37,211,102,0.08); border-color: rgba(37,211,102,0.14); color: #25d366; }
  .float-link.whatsapp:hover { background: rgba(37,211,102,0.05); }
  .float-link.whatsapp:hover .link-icon { background: rgba(37,211,102,0.14); border-color: rgba(37,211,102,0.28); }
  .float-link.whatsapp:hover .link-name { color: #25d366; }

  /* Discord */
  .float-link.discord .link-icon { background: rgba(88,101,242,0.08); border-color: rgba(88,101,242,0.14); color: #7289da; }
  .float-link.discord:hover { background: rgba(88,101,242,0.05); }
  .float-link.discord:hover .link-icon { background: rgba(88,101,242,0.14); border-color: rgba(88,101,242,0.28); }
  .float-link.discord:hover .link-name { color: #7289da; }

  /* ── Mobile ── */
  @media (max-width: 560px) {
    .float-wrap { bottom: 16px; right: 16px; }
    .float-trigger { width: 38px; height: 38px; }
    .float-panel { width: 190px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .float-panel { transition: none; }
    .float-trigger { transition: none; }
    .trigger-dot { animation: none; }
  }
</style>